					case 2: GiveIteam(i, 293, 1, count, 0, "Выдача от админа");
					case 3: AddPlayerData(i, P_BIZ_SLOTS, +, count), UpdatePlayerDatabaseInt(i, "biz_slots", GetPlayerData(playerid, P_BIZ_SLOTS));
					case 4: AddPlayerData(i, P_HOUSE_SLOTS, +, count), UpdatePlayerDatabaseInt(i, "house_slots", GetPlayerData(playerid, P_HOUSE_SLOTS));
					case 5: AddPlayerData(i, P_CAR_SLOTS, +, count), UpdatePlayerDatabaseInt(i, "car_slots", GetPlayerData(playerid, P_CAR_SLOTS));
					case 6: AddPlayerData(i, P_KIOSK_SLOTS, +, count), UpdatePlayerDatabaseInt(i, "kiosk_slots", GetPlayerData(playerid, P_KIOSK_SLOTS));
					case 7: AddPlayerData(i, P_GARDEN_SLOTS, +, count), UpdatePlayerDatabaseInt(i, "garden_slots", GetPlayerData(playerid, P_GARDEN_SLOTS));
					case 8: AddPlayerData(i, P_GARAGE_SLOTS, +, count), UpdatePlayerDatabaseInt(i, "garage_slots", GetPlayerData(playerid, P_GARAGE_SLOTS));
					default: GiveIteam(i, give_item[item][E_GIVE_ITEM_ID], 1, count, 0);

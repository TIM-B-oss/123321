 	extract params -> new to_player, slots; else return SendClientMessage(playerid, 0xCECECEFF, "Используйте: /biz_slot [id игрока] [кол-во слотов]");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))

public: FAMTBL_AddUpgrade(playerid, upgrade, money)
{
    //if(GetFamilyData(GetPlayerFamily(playerid), F_RATING) < 1) return SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Phone').addNotification('[\"Недостаточно очков!\", 5000, 2]')");
	new fmt_str[144];
	SCM(playerid, COLOR_GREEN, "Вы успешно приобрели улучшение для своей семьи!");
	GivePlayerMoneyEx(playerid, -money);
	AddFamilyData(GetPlayerFamily(playerid), F_RATING, -, 1);

	format(fmt_str, sizeof fmt_str, "UPDATE family SET upgrade_%d=1, rating=%d WHERE id=%d", upgrade, GetFamilyData(GetPlayerFamily(playerid), F_RATING),GetPlayerFamily(playerid));
	mysql_query(mysql, fmt_str, false);

	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Phone').addNotification('[\"Вы успешно приобрели это улучшение!\", 5000, 1]')");
	return 1;
}

public: FAMTBL_OnPlayerSetGang(playerid)
{
	new fmt_str[111];
	format(fmt_str, sizeof fmt_str, "UPDATE family SET gang=1 WHERE id=%d", GetPlayerFamily(playerid));
	mysql_query(mysql, fmt_str, false);
}
public: FAMTBL_OnUpgradeBuy(playerid, event, type)
{
	new fam_id = GetPlayerFamily(playerid);
	if(GetPlayerData(playerid, P_FAMILY_RANK) != 10) return SCM(playerid, COLOR_RED, "Улучшать семью/банду может только её лидер!");
	if(g_family[fam_id][F_GANG] != 1) FAMTBL_OnPlayerSetGang(playerid);
	if(event == 0) FAMTBL_AddUpgrade(playerid, 1, 5000000);
	if(event == 1) FAMTBL_AddUpgrade(playerid, 2, 5000000);
	if(event == 2) FAMTBL_AddUpgrade(playerid, 3, 5000000);
	if(event == 3) FAMTBL_AddUpgrade(playerid, 4, 5000000);
	if(event == 4) FAMTBL_AddUpgrade(playerid, 5, 5000000);
	if(event == 5) FAMTBL_AddUpgrade(playerid, 6, 5000000);
	if(event == 6) FAMTBL_AddUpgrade(playerid, 7, 5000000);
	if(event == 7) FAMTBL_AddUpgrade(playerid, 8, 5000000);
	if(event == 8) FAMTBL_AddUpgrade(playerid, 9, 5000000);
	if(event == 9) FAMTBL_AddUpgrade(playerid, 10, 5000000);
	if(event == 10) FAMTBL_AddUpgrade(playerid, 11, 5000000);
	if(event == 11) FAMTBL_AddUpgrade(playerid, 12, 5000000);
	if(event == 12) FAMTBL_AddUpgrade(playerid, 13, 5000000);
	if(event == 13) FAMTBL_AddUpgrade(playerid, 14, 5000000);
	if(event == 14) FAMTBL_AddUpgrade(playerid, 15, 5000000);
	if(event == 15) FAMTBL_AddUpgrade(playerid, 16, 5000000);
	if(event == 16) FAMTBL_AddUpgrade(playerid, 17, 5000000);
	if(event == 17) FAMTBL_AddUpgrade(playerid, 18, 5000000);
	return 1;
}
public: FAMTBL_OnCreateFamily(playerid, color, logo, name[32])
{
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Phone').getCurrentApp().setLoading(0)");

	new query[512],
	Cache: result,
	rows;

	mysql_format(mysql, query, sizeof query, "SELECT * FROM family WHERE name='%s'", name);
	result = mysql_query(mysql, query, true);
	rows = cache_num_rows();
	cache_delete(result);

	if(rows)
	{
		SendClientMessage(playerid, 0xCECECEFF, "Данное имя уже используется");
		return 1;
	}

    new account_id = GetPlayerAccountID(playerid);
    new house_query[256];
    new Cache: result_house;
    new house_id = -1;

    mysql_format(mysql, house_query, sizeof house_query, "SELECT id FROM houses WHERE owner_id=%d LIMIT 1", account_id);
    result_house = mysql_query(mysql, house_query, true);

    if (cache_num_rows() > 0)
    {
        house_id = cache_get_field_content_int(0, "id");
    }
    cache_delete(result_house);

    if (house_id == -1)
    {
        SendClientMessage(playerid, 0xFF0000FF, "У вас нет дома, поэтому вы не можете создать семью.");
        return 1;
    }
    if(GetPlayerData(playerid, P_NAKOLKA) < 7)
    {
        SendClientMessage(playerid, 0xCECECEFF, "* Вы должны иметь ранг-наколку 'Пахан' или выше");
        return 1;
    }
    if(!GetILPlayerInt(GetPlayerMoneyEx(playerid), 5000000))
    {
        SendClientMessage(playerid, 0xFF0000FF, "У вас недостаточно средств для создания семьи.");
        return 1;
    }
	GivePlayerMoneyEx(playerid, -50000000, "Создание семьи",true,true);
	SendClientMessage(playerid, 0x66CC00FF, "Вы успешно создали семью! {"#cGold"}Используйте /fmenu для информации.");

	new time = gettime();
	mysql_format
    (
        mysql, query, sizeof query,
        "INSERT INTO family "\
	    	"(name, u_id, u_name, time, gang, house_id) "\
            "VALUES"\
            "('%e', %d, '%e', %d, 1, %d)",
        name,
        account_id,
        GetPlayerNameEx(playerid),
        time,
        house_id
    );
	result = mysql_query(mysql, query);

	new fam_id = cache_insert_id();

	SetPlayerData(playerid, P_FAMILY, fam_id);
	SetPlayerData(playerid, P_FAMILY_RANK, 10);

	format(query, sizeof query, "UPDATE accounts_1101 SET family=%d, family_rank=%d WHERE id=%d LIMIT 1", GetPlayerData(playerid, P_FAMILY), GetPlayerData(playerid, P_FAMILY_RANK), GetPlayerAccountID(playerid));
	mysql_query(mysql, query, false);

	SetFamilyData(fam_id, F_SQL_ID, fam_id);
	format(g_family[fam_id][F_NAME], 64, "%s", name);
	new text_str[144];
	format(text_str, 144, "{FFB500}%s", name);
	g_player[playerid][P_FAM_LABEL] = CreateDynamic3DTextLabel(text_str, -1, 0.0, 0.0, 0.6, 14.0, playerid, INVALID_VEHICLE_ID, 1);

	new
		hour, minute,second,
		day, month, year;

	gettime(hour, minute,second);
	getdate(year, month, day);

	SetFamilyData(fam_id, F_TIME_DAY, day);
	SetFamilyData(fam_id, F_TIME_MOUNTH, month);
	SetFamilyData(fam_id, F_TIME_YEAR, year);
	SetFamilyData(fam_id, F_TIME_HOUR, hour);
	SetFamilyData(fam_id, F_TIME_MINUTE, minute);
	SetFamilyData(fam_id, F_TIME_SECOND, second);

	SetFamilyData(fam_id, F_GANG, 1);
	SetFamilyData(fam_id, F_FAMILY_CARS, 10);
    SetFamilyData(fam_id, F_HOUSE_ID, house_id);
    SetFamilyData(fam_id, F_USER_ID, account_id);

	format(query, sizeof query, "UPDATE family SET day=%d, mounth=%d,year=%d,hour=%d,minute=%d,second=%d,score=%d,color=%d,gang=1, house_id=%d, family_cars=10 WHERE id=%d LIMIT 1", day, month, year, hour, minute, second, logo, color, house_id, fam_id,  g_family[fam_id][F_SQL_ID]);
	mysql_query(mysql, query, false);

	format(g_family[fam_id][F_RANK1], 32, "Терпила");
	format(g_family[fam_id][F_RANK2], 32, "Шнырь");
	format(g_family[fam_id][F_RANK3], 32, "Босяк");
	format(g_family[fam_id][F_RANK4], 32, "Барыга");
	format(g_family[fam_id][F_RANK5], 32, "Вор");
	format(g_family[fam_id][F_RANK6], 32, "Блатной");
	format(g_family[fam_id][F_RANK7], 32, "Пахан");
	format(g_family[fam_id][F_RANK8], 32, "Командир");
	format(g_family[fam_id][F_RANK9], 32, "Заместитель");
	format(g_family[fam_id][F_RANK10], 32, "Создатель");

	mysql_format(mysql, query, sizeof query, "UPDATE family SET rank1='%e', rank2='%e' WHERE id=%d LIMIT 1",
	GetFamilyData(fam_id, F_RANK1),GetFamilyData(fam_id, F_RANK2), g_family[fam_id][F_SQL_ID]);
	mysql_query(mysql, query, false);

	mysql_format(mysql, query, sizeof query, "UPDATE family SET rank3='%e', rank4='%e' WHERE id=%d LIMIT 1",
	GetFamilyData(fam_id, F_RANK3),GetFamilyData(fam_id, F_RANK4), g_family[fam_id][F_SQL_ID]);
	mysql_query(mysql, query, false);

	mysql_format(mysql, query, sizeof query, "UPDATE family SET rank5='%e', rank6='%e' WHERE id=%d LIMIT 1",
	GetFamilyData(fam_id, F_RANK5),GetFamilyData(fam_id, F_RANK6), g_family[fam_id][F_SQL_ID]);
	mysql_query(mysql, query, false);

	mysql_format(mysql, query, sizeof query, "UPDATE family SET rank7='%e',rank8='%e' WHERE id=%d LIMIT 1",
	GetFamilyData(fam_id, F_RANK7),GetFamilyData(fam_id, F_RANK8), g_family[fam_id][F_SQL_ID]);
	mysql_query(mysql, query, false);

	mysql_format(mysql, query, sizeof query, "UPDATE family SET rank9='%e', rank10='%e' WHERE id=%d LIMIT 1",
	GetFamilyData(fam_id, F_RANK9),GetFamilyData(fam_id, F_RANK10), g_family[fam_id][F_SQL_ID]);
	mysql_query(mysql, query, false);
	g_family_loaded ++;
	cache_delete(result);
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Phone').getCurrentApp().setDisplayParams(0)");
	return 1;
}
public: FAMTBL_OnPropertyChangeTab(playerid, event, type)

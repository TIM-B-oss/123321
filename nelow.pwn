			    SendClientMessage(playerid, 0xFFA500FF, "Цель: {"#cW"}Заработайте 2500 рублей на начальных работах (шахта, лесопилка, завод)");
			    SendPacket_1(playerid, s_CefInterface, t_CefHide, "Quests");
		    }
		    else
		    {
		        Dialog(playerid, DIALOG_QUEST_END, DIALOG_STYLE_MSGBOX, "{C0D897}Предупреждение", "{EBEBEB}Вы действительно хотите отказаться от данного задания?", "Да", "Нет");
		    }
		}
		else GameText(playerid, "~r~Данный тип заданий~n~Нужно выполнять по~n~Порядку", 3000, 2);
	}
	if(quest_id == 2)
	{
	    if(GetPlayerData(playerid, P_QUEST_3_STATS) != 0) return SendClientMessage(playerid, -1, "{EBEBEB}Этот квест уже пройден, его нельзя выполнить снова.");

{
    RS_ID,
    RS_VEHICLE,
    RS_STATUS,
    RS_AREA,
    RS_TIME,
    RS_TICKETS
};

new g_raffleShop[MAX_RAFFLESHOP][E_RAFFLE_SHOP];

new Float: g_pos_car_raffle[MAX_RAFFLESHOP][4] =
{
    {983.79860, 2801.5598, 1001.2399, 182.4524},
    {1014.5068, 2801.6160, 1001.2430, 178.9288}
};


{
	foreach(new i: Player)
	{
		if(GetPlayerFamily(i) != 0)
		{

			new fmt_str[144];

			format(fmt_str, sizeof fmt_str, "%s", message);
			SendClientMessage(i, COLOR_LIGHTRED, fmt_str);
		}
	}
}

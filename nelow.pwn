public: CB_CarsFamily(playerid)
{
    new model_id, rang, id, phone;

    string_dialog[0] = EOS;

    for(new i; i < cache_num_rows(); i++)
    {
		new u_name[21];
		id = cache_get_field_content_int(i, "id");
        model_id = cache_get_field_content_int(i, "model_id");
        rang = cache_get_field_content_int(i, "rang");
		phone = cache_get_field_content_int(i, "phone");
		cache_get_field_content(i, "owner_name", u_name);

        format(string_dialog, sizeof string_dialog, "%s[%d,0,\"%s\",\"%s\",%d,%d,1000],", string_dialog, id, GetVehicleInfo(model_id, VI_NAME), u_name, phone, rang);
    }
    strdel(string_dialog, strlen(string_dialog) - 1, strlen(string_dialog));

    SendClientEventF(playerid, s_CefInterface, t_CefUpdate, "interface('Phone').getCurrentApp().setTransport('[%s]')", string_dialog);
}


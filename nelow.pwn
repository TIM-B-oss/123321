	        }
	    }
	    case 4:
	    {
	        switch(anim_id)
	        {
				case 1: ApplyAnimation(playerid, "PED",				"WALK_DRUNK",			4.0, true,  1, 1, 1, 0), SetPlayerData(playerid, P_USE_ANIM, true), SendPacket_2(playerid, s_CefInterface, t_CefShow, "Interactions", "[[1, \"Выключить анимацию\"]]");
				case 2: ApplyAnimation(playerid, "ped",				"Crouch_Roll_L",		4.0, true,  1, 1, 1, 1), SetPlayerData(playerid, P_USE_ANIM, true), SendPacket_2(playerid, s_CefInterface, t_CefShow, "Interactions", "[[1, \"Выключить анимацию\"]]");
	        }
	    }
	    case 5:
	    {
	        switch(anim_id)

				case 1:
				{
					SCM(playerid, COLOR_YELLOW, "Начинайте работу снегоуборщика, ездите по чекпоинтам и убирайте снег! Вам выпал второй маршрут.");
					SetPlayerRaceCheckpoint(playerid, 0, -280.5028,-1463.0747,40.2893, 0.0,0.0,0.0, 4.0, RCP_ACTION_TYPE_SNOW2_1);
					snow_veh[playerid] = GetPlayerVehicleID(playerid);
				}
			}
		}
		case DIALOG_SELL_ALL_PROPERTY_TO_GOV:
		{
			if(!response) return 1;

			new query[256];

			switch(listitem)
			{
				case 0:
				{
                  for(new i = 0; i < g_house_loaded; i++)
                {
                  if(GetHouseData(i, H_OWNER_ID) == 0) continue;

                  SetHouseData(i, H_IMPROVEMENTS, 0);
                  SetHouseData(i, H_RENT_DATE, 0);
                  SetHouseData(i, H_LOCK_STATUS, false);
                  SetHouseData(i, H_OWNER_ID, 0);

                  CallLocalFunction("EvictHouseRentersAll", "i", i);
                  format(query, sizeof query, "UPDATE houses SET owner_id=0 WHERE id=%d", GetHouseData(i, H_SQL_ID));
                  mysql_query(mysql, query, false);

                  UpdateHouse(i);
                  HouseHealthInit(i);
                  HouseStoreInit(i);
                }
                  SendClientMessage(playerid, 0x66CC33FF, "Все дома переданы в госсобственность.");
                }
				case 1:
                {
                  for(new i = 0; i < g_business_loaded; i++)
                {
                  if(GetBusinessData(i, B_OWNER_ID) == 0) continue;

                  SetBusinessData(i, B_OWNER_ID, 0);
                  SetBusinessData(i, B_IMPROVEMENTS, 0);
                  SetBusinessData(i, B_PRODS, 0);
                  SetBusinessData(i, B_PROD_PRICE, 0);
                  SetBusinessData(i, B_BALANCE, 0);
                  SetBusinessData(i, B_RENT_DATE, 0);
                  SetBusinessData(i, B_ENTER_MUSIC, 0);
                  SetBusinessData(i, B_LOCK_STATUS, false);

                  format(query, sizeof query, "UPDATE business SET owner_id=0 WHERE id=%d", GetBusinessData(i, B_SQL_ID));
                  mysql_query(mysql, query, false);

                  format(query, sizeof query, "DELETE FROM business_gps WHERE bid=%d", i);
                  mysql_query(mysql, query, false);

                  BusinessHealthPickupInit(i);
                  g_business_gps_init = false;
                }
                  SendClientMessage(playerid, 0x66CC33FF, "Все бизнесы переданы в госсобственность.");
                }
                case 2: 
                {
                  for(new i = 0; i < g_garage_loaded; i++)
                {
                  if(GetGarageData(i, G_OWNER_ID) == 0) continue;

                  if(1 <= GetGarageData(i, G_TYPE) <= 3)
                {
                    format(query, sizeof query, "UPDATE accounts_1101 SET car_slots=4 WHERE id=%d", GetGarageData(i, G_OWNER_ID));
                    mysql_query(mysql, query, false);
                }

                  SetGarageData(i, G_OWNER_ID, 0);
                  SetGarageData(i, G_IMPROVEMENTS, 0);
                  SetGarageData(i, G_RENT_DATE, 0);

                  format(query, sizeof query, "UPDATE garage SET owner_id=0,improvements=0 WHERE id=%d", GetGarageData(i, G_SQL_ID));
                  mysql_query(mysql, query, false);

                }
                  SendClientMessage(playerid, 0x66CC33FF, "Все гаражи переданы в госсобственность.");
                }
                case 3: 
                {
                  for(new i = 0; i < g_garden_loaded; i++)
                {
                  if(GetGardenData(i, G_OWNER_ID) == 0) continue;

                  DestroyDynamic3DTextLabel(gardendvlabel[i]);
                  DestroyDynamicObject(gardenobj_1[i]);
                  DestroyDynamic3DTextLabel(gardenobj_1_label[i]);
                  DestroyDynamicObject(gardenobj_2[i]);
                  DestroyObject(gardendver[i]);
                  DestroyObject(gardenobj[i]);

                  gardendver[i] = CreateObject(16563, GetGardenData(i, G_POS_X) + 2.97934, GetGardenData(i, G_POS_Y) + 0.393404, GetGardenData(i, G_POS_Z) - 0.000461, 0.0, 0.0, 0.0);
                  gardenobj[i] = CreateObject(16562, GetGardenData(i, G_POS_X), GetGardenData(i, G_POS_Y), GetGardenData(i, G_POS_Z), 0.0, 0.0, 0.0);
                  gardendvlabel[i] = CreateDynamic3DTextLabel("{FFA500}Двери теплицы", -1, GetGardenData(i, G_POS_X) + 2.97934, GetGardenData(i, G_POS_Y) + 0.393404, GetGardenData(i, G_POS_Z) + 1, 2.0);

                  new max_gryadok = (GetGardenData(i, G_IMPROVEMENTS) >= 3) ? 14 : 10;
                  for(new j = 0; j < max_gryadok; j++)
                {
                  if(j < sizeof(G_HAS_WEED[])) G_HAS_WEED[i][j] = false;
                  if(j < sizeof(G_HAS_YDOB[])) G_HAS_YDOB[i][j] = false;
                  if(j < sizeof(G_HAS_YDOB2[])) G_HAS_YDOB2[i][j] = false;
                  if(j < sizeof(G_HAS_YDOB_YES[])) G_HAS_YDOB_YES[i][j] = false;
                  if(j < MAX_GARDENS_YAM) DestroyDynamic3DTextLabel(gardendyamkalab[i][j]);
                }
                  for(new j = 0; j < 10 && j < MAX_GARDENS_YAM; j++)
                {
                  gardendyamkalab[i][j] = CreateDynamic3DTextLabel("{FFA500}Свободная ямка\n{FFFFFF}Нажмите {FFA500}ALT {FFFFFF}для посадки", -1,
                  GetGardenData(i, G_POS_X) + GardenGryadka_1[j][0],
                  GetGardenData(i, G_POS_Y) + GardenGryadka_1[j][1],
                  GetGardenData(i, G_POS_Z) + GardenGryadka_1[j][2] + 1, 2.0);
                }

                  SetGardenData(i, G_IMPROVEMENTS, 0);
                  SetGardenData(i, G_OWNER_ID, 0);
                  SetGardenData(i, G_RENT_DATE, 0);
                  SetGardenData(i, G_LOCK_STATUS, false);

                  format(query, sizeof query, "UPDATE gardens SET owner_id=0,g_lock=0,improvements=0,owner_name='None' WHERE id=%d", GetGardenData(i, G_SQL_ID));
                  mysql_query(mysql, query, false);

                  format(g_garden[i][G_OWNER_NAME], 21, "Государство");
                }
                  SendClientMessage(playerid, 0x66CC33FF, "Все огороды переданы в госсобственность.");
                }
                case 4:
                {
                  for(new i = 0; i < g_kiosk_loaded; i++)
                {
                  if(GetKioskData(i, K_OWNER_ID) == 0) continue;

                  format(query, sizeof query, "UPDATE accounts_1101 SET kiosk=-1 WHERE id=%d", GetKioskData(i, K_OWNER_ID));
                  mysql_query(mysql, query, false);

                  format(query, sizeof query, "UPDATE kiosk SET owner_id=0,improvements=1,rent=0 WHERE id=%d", GetKioskData(i, K_SQL_ID));

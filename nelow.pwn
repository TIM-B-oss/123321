public: DestroyInteraction(index)
{
    format(g_interactions[index][E_I_NAME], 32, "");

    g_interactions[index][E_I_TYPE] = 0;
    g_interactions[index][E_I_INDEX] = -1;
    g_interactions[index][E_I_POS_X] = 0.0;
    g_interactions[index][E_I_POS_Y] = 0.0;
    g_interactions[index][E_I_POS_Z] = 0.0;
    g_interactions[index][E_WORLD] = 0;
    
    DestroyDynamicArea(g_interactions[index][E_AREA]); 
}
stock ClearAllInteractions()
{
    for(new i; i < MAX_INTERACTIONS; i++)
    {
        g_interactions[i][E_I_TYPE] = 0;
    }
}
stock AddInteraction(const name[], type, world, index, Float: size, Float: x, Float: y, Float: z, playerid, bool: need_veh = false, n_team = TEAM_NONE)
{
    new free_id = SearchFreeInteractionID();

    format(g_interactions[free_id][E_I_NAME], 32, "%s", name);
    g_interactions[free_id][E_I_TYPE] = type;
    g_interactions[free_id][E_I_INDEX] = index;

    g_interactions[free_id][E_I_POS_X] = x;
    g_interactions[free_id][E_I_POS_Y] = y;
    g_interactions[free_id][E_I_POS_Z] = z;

    g_interactions[free_id][E_AREA] = CreateDynamicSphere(x, y, z, size);
	
	g_interactions[free_id][E_I_NEED_VEHICLE] = need_veh;

    if(playerid != -1) AttachDynamicAreaToPlayer(g_interactions[free_id][E_AREA], playerid);

    g_interactions[free_id][E_WORLD] = world;
	g_interactions[free_id][E_I_TEAM_NEED] = n_team;

    return free_id;
}

stock OnPlayerEnterInteractions(playerid, index)
{
    count_player_interactions[playerid]++;

	if(g_interactions[index][E_I_NEED_VEHICLE] == true && !IsPlayerDriver(playerid)) return 1;
	if(g_interactions[index][E_I_TEAM_NEED] != TEAM_NONE && GetPlayerTeamEx(playerid) != g_interactions[index][E_I_TEAM_NEED]) return 1;

    for(new i; i < MAX_PLAYER_INTERACTION; i++)
    {
        if(player_interaction[playerid][i] != 0) continue;

        if(player_interaction[playerid][i] == 0)
        {
            player_interaction[playerid][i] = index;
            break;
        }
    }
    UpdateInteractionsInterface(playerid);

	return 1;
}
public: OnPlayerLeaveInteractions(playerid, interactionID)
{
    for(new i; i < 5; i++)
    {
        if(player_interaction[playerid][i] == interactionID) player_interaction[playerid][i] = 0;
    }
    count_player_interactions[playerid]--;

    UpdateInteractionsInterface(playerid);

    return 1;
}

stock UpdateInteractionsInterface(playerid)
{
    if(count_player_interactions[playerid] != 0)
    {
        string_minimal[0] = EOS;
        str_2[0] = EOS;

        for(new i; i < 5; i++)
        {
            if(player_interaction[playerid][i] != 0)
            {
                format(string_minimal, sizeof string_minimal, "%s[%d, \"%s\"],", string_minimal, player_interaction[playerid][i], g_interactions[player_interaction[playerid][i]][E_I_NAME]);
            }
        }
        strdel(string_minimal, strlen(string_minimal) - 1, strlen(string_minimal));

        format(str_2, sizeof str_2, "interface('Interactions').setInfo('[%s]')", string_minimal);

        SendPacket_1(playerid, s_CefInterface, t_CefShow, "Interactions");
        SendPacket_1(playerid, s_CefInterface, t_CefUpdate, str_2);

		if(count_player_interactions[playerid] == 1)
		{
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "window.setCursorStatus(0, 0)");
			cursor[playerid] = 0;
		}
    }
    else if(count_player_interactions[playerid] == 0)
	{
		SendPacket_1(playerid, s_CefInterface, t_CefHide, "Interactions");
	
		SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "window.setCursorStatus(0, 0)");
		cursor[playerid] = 0;
	}
}

public: Interactions_Key(playerid, key)
{
    if(key == 18)
    {
        if(count_player_interactions[playerid] > 1)
        {
            if(cursor[playerid] == 0) SendPacket_1(playerid, s_CefInterface,  t_CefUpdate, "window.setCursorStatus(0, 1)"), cursor[playerid] = 1;
			else if(cursor[playerid] == 1) SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "window.setCursorStatus(0, 0)"), cursor[playerid] = 0;
        }
        else if(count_player_interactions[playerid] == 1)
        {
            InteractionUse(playerid, player_interaction[playerid][0]);
        }
    }
}
stock SearchFreeInteractionID()
{
    new id = -1;

    for(new i; i < MAX_INTERACTIONS; i++)
    {
        if(g_interactions[i][E_I_TYPE] != 0) continue;

        if(g_interactions[i][E_I_TYPE] == 0)
        {
            id = i;

            break;
        }
    }
    return id;
}

stock ClearAcsses(playerid)
{
	RemovePlayerAttachedObjects(playerid);
	return 1;
}

stock Jail_Init()
{
    JailActor[0] = CreateActor(293, -1726.51, -2806.50, 1001.40, 310.7213);
    SetActorVirtualWorld(JailActor[0], 5);
    CreateDynamic3DTextLabel("Клемент\n{FFFFFF}Подойдите для взаимодействия", 0xFFFFFFFFFFBE5CFF, -1726.51, -2806.50, 1001.40, 2.00);
    AddInteraction("Взаимодействовать", E_TYPE_JAIL_TRADE, 0, 0, 2.0, -1726.51, -2806.50, 1001.40, -1);

    JailActor[1] = CreateActor(293, -1628.36, -2797.26, 1001.40, 126.4795);
    SetActorVirtualWorld(JailActor[1], 5);
    CreateDynamic3DTextLabel("Дэннис\n{FFFFFF}Подойдите для взаимодействия", 0xFFFFFFFFFFBE5CFF, -1628.36, -2797.26, 1001.40, 2.00);
    AddInteraction("Взаимодействовать", E_TYPE_JAIL_TRADE, 0, 0, 2.0, -1628.36, -2797.26, 1001.40, -1);

    AreaJailInterior = CreateDynamicSphere(-1628.36, -2797.26, 1001.40, 250.0);
    AreaJail = CreateDynamicSphere(-1752.2334, -2891.8132, 11.0545, 250.0);

    for(new i; i < sizeof(Toilet_Positions); i++)
    {
        CreateDynamic3DTextLabel("Унитаз\n{FFFFFF}Подойдите для взаимодействия", 0xFFFFFFFFFFBE5CFF, Toilet_Positions[i][0], Toilet_Positions[i][1], Toilet_Positions[i][2], 2.0);
        AddInteraction("Почистить унитаз", E_TYPE_TOILET_CLEAR, 0, 0, 2.0, Toilet_Positions[i][0], Toilet_Positions[i][1], Toilet_Positions[i][2], -1);
    }
    for(new i; i < sizeof(J_IntDoors); i++)
    {
        J_IntDoors[i][J_ObjID] = CreateDynamicObject(J_IntDoors[i][J_ModelID], J_IntDoors[i][J_PosX], J_IntDoors[i][J_POS_Y], J_IntDoors[i][J_POS_Z], 0.0, 0.0, J_IntDoors[i][J_POS_RZ]);
        if(J_IntDoors[i][J_ModelID] != 17134) AddInteraction("Открыть/закрыть дверь", E_TYPE_JAIL_DOORS, 0, 0, 2.0, J_IntDoors[i][J_PosX], J_IntDoors[i][J_POS_Y], J_IntDoors[i][J_POS_Z], -1, false, TEAM_FSIN);
        else AddInteraction("Открыть/закрыть камеру", E_TYPE_JAIL_DOORS, 0, 0, 2.0, J_IntDoors[i][J_PosX], J_IntDoors[i][J_POS_Y], J_IntDoors[i][J_POS_Z], -1, false, TEAM_FSIN);
    }
    for(new i; i < sizeof(J_WorldDoors); i++)
    {
        J_WorldDoors[i][J_ObjID] = CreateDynamicObject(J_WorldDoors[i][J_ModelID], J_WorldDoors[i][J_PosX], J_WorldDoors[i][J_POS_Y], J_WorldDoors[i][J_POS_Z], 0.0, 0.0, J_WorldDoors[i][J_POS_RZ]);
		AddInteraction("Открыть / Закрыть", E_TYPE_JAIL_DOORS_WORLD, 0, 0, 10.0, J_WorldDoors[i][J_PosX], J_WorldDoors[i][J_POS_Y], J_WorldDoors[i][J_POS_Z], -1, false, TEAM_FSIN);
	}
	for(new i; i < sizeof(J_WorldDoor_2); i++)
    {
        J_WorldDoor_2[i][J_ObjID] = CreateDynamicObject(J_WorldDoor_2[i][J_ModelID], J_WorldDoor_2[i][J_PosX], J_WorldDoor_2[i][J_POS_Y], J_WorldDoor_2[i][J_POS_Z], 0.0, 0.0, J_WorldDoor_2[i][J_POS_RZ]);
	}

    CreateDynamic3DTextLabel("Блок управления\n {FFFFFF}Подойдите для взаимодействия", 0xFFFFFFFFFFBE5CFF, -1671.02, -2826.38, 1004.81, 2.00);
    AddInteraction("Сделать оповещение", E_TYPE_JAIL_ALERT, 0, 0, 2.0, -1671.02, -2826.38, 1004.81, -1, false, TEAM_FSIN);
    
    AddInteraction("Посмотреть камеры", E_TYPE_JAIL_CAMERA, 0, 0, 2.0, 2340.9890,-1750.5211,1006.7991, -1, false, TEAM_FSB);
    
}
stock SendClientEventWithArg(playerid, CefStyle:style, CefType:type, string[], string1[])
{
    new
        BitStream:bsn = BS_New();

    BS_WriteValue(bsn, PR_UINT8, ID_CEF_RPC);
    BS_WriteValue(bsn, PR_UINT16, _:style);
	BS_WriteValue(bsn, PR_UINT32, _:type);
	BS_WriteValue(bsn, PR_UINT8, 2);
	BS_WriteValue(
		bsn,
		PR_UINT32, strlen(string),
		PR_STRING, string, strlen(string)
	);
	BS_WriteValue(
		bsn,
		PR_UINT32, strlen(string1),
		PR_STRING, string1, strlen(string1)
	);

    PR_SendPacket(bsn, playerid);
    BS_Delete(bsn);
}
stock ToiletJail(playerid)
{
	if(GetPlayerData(playerid, P_JAIL) <= 0) return SendClientMessage(playerid, 0x999999FF, "Вы должны отбывать срок в исправительной колонии, чтобы почистить унитаз");
    for(new i; i < sizeof(Toilet_Positions); i++)
    {
        if(IsPlayerInRangeOfPoint(playerid, 3.5, Toilet_Positions[i][0], Toilet_Positions[i][1], Toilet_Positions[i][2]))
        {
            if(ToiletStatus[i][0] == 1) return SCM(playerid, 0xCECECEFF, "Унитаз не нуждается в чистке.");
            else
            {
                new ToiletType = RandomEx(0, 2);

                SendClientEventWithArg(playerid, s_CefInterface, t_CefShow, "ToiletCleaning", (str_f("[%d, 5]", ToiletType)));
            }
        }
    }
    return 1;
}
public: ToiletCleaning_OnPlayerEnd(playerid)
{
    for(new i; i < sizeof(Toilet_Positions); i++)
    {
        if(IsPlayerInRangeOfPoint(playerid, 3.5, Toilet_Positions[i][0], Toilet_Positions[i][1], Toilet_Positions[i][2]))
        {
            SendPacket_1(playerid, s_CefInterface, t_CefHide, "ToiletCleaning");

            GameText(playerid, "~g~Успешно", 4000, 2);
			GiveRandomCase(playerid);

            ToiletStatus[i][0] = 1;
            ToiletStatus[i][1] = 240;
        }
    }
}

stock Jail_OnSecondTimer()
{
    for(new i; i < sizeof(Toilet_Positions); i++)
    {
        if(ToiletStatus[i][0] == 1)
        {
            ToiletStatus[i][1]--;

            if(ToiletStatus[i][1] == 0) ToiletStatus[i][0] = 0;
        }
    }
}
stock JailUseDoor(playerid, type)
{
    if(type == 0)
    {
        for(new i; i <  sizeof(J_IntDoors); i++)
        {
            if(IsPlayerInRangeOfPoint(playerid, 2.0, J_IntDoors[i][J_PosX], J_IntDoors[i][J_POS_Y], J_IntDoors[i][J_POS_Z]))
            {
                STRING_GLOBAL[0] = EOS;

                if(J_IntDoors[i][J_Status] == true)
                {
                    MoveDynamicObject(J_IntDoors[i][J_ObjID], J_IntDoors[i][J_PosX], J_IntDoors[i][J_POS_Y], J_IntDoors[i][J_POS_Z] + 0.05, 0.05, 0.0, 0.0, J_IntDoors[i][J_POS_RZ]);
                    J_IntDoors[i][J_Status] = false;

                    if(J_IntDoors[i][J_ModelID] != 17134) format(STRING_GLOBAL, sizeof STRING_GLOBAL, "закрыл(а) дверь");
                    else format(STRING_GLOBAL, sizeof STRING_GLOBAL, "закрыл(а) дверь клетки");

                    return Action(playerid, STRING_GLOBAL);
                }
                if(J_IntDoors[i][J_Status] == false)
                {
                    MoveDynamicObject(J_IntDoors[i][J_ObjID], J_IntDoors[i][J_PosX], J_IntDoors[i][J_POS_Y], J_IntDoors[i][J_POS_Z], 0.05, 0.0, 0.0, J_IntDoors[i][J_POS_RZ] - 150.0);
                    J_IntDoors[i][J_Status] = true;

                    if(J_IntDoors[i][J_ModelID] != 17134) format(STRING_GLOBAL, sizeof STRING_GLOBAL, "открыл(а) дверь");
                    else format(STRING_GLOBAL, sizeof STRING_GLOBAL, "открыл(а) дверь клетки");

                    return Action(playerid, STRING_GLOBAL);
                }
            }
        }
    }
    if(type == 1)
    {
        for(new i; i <  sizeof(J_WorldDoors); i++)
        {
            if(IsPlayerInRangeOfPoint(playerid, 10.0, J_WorldDoors[i][J_PosX], J_WorldDoors[i][J_POS_Y], J_WorldDoors[i][J_POS_Z]))
            {
                switch(J_WorldDoors[i][J_Status])
                {
                    case true:
                    {
                        MoveDynamicObject(J_WorldDoors[i][J_ObjID], J_WorldDoors[i][J_PosX], J_WorldDoors[i][J_POS_Y], J_WorldDoors[i][J_POS_Z] + 0.05, 0.05, 0.0, 0.0, J_WorldDoors[i][J_POS_RZ]);
                        J_WorldDoors[i][J_Status] = false;
                    }
                    case false:
                    {
                        MoveDynamicObject(J_WorldDoors[i][J_ObjID], J_WorldDoors[i][J_PosX], J_WorldDoors[i][J_POS_Y], J_WorldDoors[i][J_POS_Z], 0.05, 0.0, 0.0, J_WorldDoors[i][J_POS_RZ] + 90.0);
                        J_WorldDoors[i][J_Status] = true;
                    }
                }
            }
        }
		for(new i; i <  sizeof(J_WorldDoor_2); i++)
        {
            if(IsPlayerInRangeOfPoint(playerid, 15.0, J_WorldDoor_2[i][J_PosX], J_WorldDoor_2[i][J_POS_Y], J_WorldDoor_2[i][J_POS_Z]))
            {
                switch(J_WorldDoor_2[i][J_Status])
                {
                    case true:
                    {
                        MoveDynamicObject(J_WorldDoor_2[i][J_ObjID], J_WorldDoor_2[i][J_PosX], J_WorldDoor_2[i][J_POS_Y], J_WorldDoor_2[i][J_POS_Z] + 0.05, 0.05, 0.0, 0.0, J_WorldDoor_2[i][J_POS_RZ]);
                        J_WorldDoor_2[i][J_Status] = false;
                    }
                    case false:
                    {
                        MoveDynamicObject(J_WorldDoor_2[i][J_ObjID], J_WorldDoor_2[i][J_PosX], J_WorldDoor_2[i][J_POS_Y], J_WorldDoor_2[i][J_POS_Z], 0.05, 0.0, 0.0, J_WorldDoor_2[i][J_POS_RZ] - 90.0);
                        J_WorldDoor_2[i][J_Status] = true;
                    }
                }
            }
        }
    }
    return 1;
}


	cache_get_field_content(0, "st1", g_ownable_car[idx][OC_ST1], mysql, 200);
	cache_get_field_content(0, "st11", g_ownable_car[idx][OC_ST11], mysql, 200);
	cache_get_field_content(0, "st2", g_ownable_car[idx][OC_ST2], mysql, 200);
	cache_get_field_content(0, "st3", g_ownable_car[idx][OC_ST3], mysql, 200);


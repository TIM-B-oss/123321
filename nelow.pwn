        case DIALOG_CLEARINV:
        {
            if (!response) return 1;
            new query[128];
            mysql_format(mysql, query, sizeof query, "DELETE FROM `items` WHERE `owner_id` = '%d'", GetPlayerAccountID(playerid));
            mysql_tquery(mysql, query);
            DestroyPlayerItems(playerid);
            LoadPlayerItems(playerid);
            SendClientMessage(playerid, 0x55FF55FF, "Ваш инвентарь успешно очищен!");
            return 1;

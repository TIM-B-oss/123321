stock VoiceSetVolume(playerid, handle, volume)
{
    new BitStream:bsV = BS_New();

    BS_WriteValue(bsV,
        PR_UINT8, 215,
        PR_UINT16, 34,
        PR_UINT32, handle,
        PR_FLOAT, float(volume)
    );
    PR_SendPacket(bsV, playerid);
    BS_Delete(bsV);
    return 1;
}
stock VoiceSetVolumeGlobal(playerid, volume)
{
    new BitStream:bsV = BS_New();

    BS_WriteValue(bsV,
        PR_UINT8, 215,
        PR_UINT16, 6,
        PR_UINT32, (5*volume)
    );

    PR_SendPacket(bsV, playerid);
    BS_Delete(bsV);
    return 1;
}

stock CreatePacketRadio(playerid,  handle, Float:volume=1.0) {
    new BitStream:bsV = BS_New();
    BS_WriteValue(bsV,
        PR_UINT8, 215,
        PR_UINT16, 4,
        PR_UINT32, handle,
        PR_FLOAT, volume,
        PR_BOOL, false,
        PR_UINT8, 0
    );

    PR_SendPacket(bsV, playerid);
    BS_Delete(bsV);
    return 1;
}

stock VoiceOpenStream(playerid, handle, Float:volume = 100.0, bool: use3D = false, attach_to = -1)
{
    new BitStream:bsV = BS_New();
    BS_WriteValue(bsV,
        PR_UINT8, 215,
        PR_UINT16, 4,
        PR_UINT32, handle,
        PR_FLOAT, volume,
        PR_BOOL, use3D,
        PR_UINT8, 2,
        PR_UINT32, attach_to
    );
    PR_SendPacket(bsV, playerid);
    BS_Delete(bsV);
    return 1;
}

stock VoiceCloseStream(playerid, handle)
{
    new BitStream:bsV = BS_New();

    BS_WriteValue(bsV,
        PR_UINT8, 215,
        PR_UINT16, 5,
        PR_UINT32, handle
    );

    PR_SendPacket(bsV, playerid);
    BS_Delete(bsV);
    return 1;
}
stock SendPacketVoice(playerid, BitStream: bs)
{
    new BitStream:bsV = BS_New(), bytes;

    BS_WriteValue(bsV,
        PR_UINT8, 215,
        PR_UINT16, 3,
        PR_UINT32, playerid
    );

    BS_SetReadOffset(bs, 24);
    BS_GetNumberOfBytesUsed(bs, bytes);

    BS_WriteValue(bsV, PR_UINT32, bytes);

    for (new i, uint8; i < bytes; i++)
        BS_ReadUint8(bs, uint8), BS_WriteValue(bsV, PR_UINT8, uint8);

    foreach(VoicePlayers[playerid], id) {
        if(GetDistanceBetweenPlayers(playerid, id) > 25.0) continue;
        PR_SendPacket(bsV, id);
    }
    BS_Delete(bsV);
    return 1;
}
stock SendPacketRadio(playerid, handle, BitStream: bs)
{
    new BitStream:bsV = BS_New(), bytes;

    BS_WriteValue(bsV,
        PR_UINT8, 215,
        PR_UINT16, 3,
        PR_UINT32, handle
    );

    BS_SetReadOffset(bs, 24);
    BS_GetNumberOfBytesUsed(bs, bytes);

    BS_WriteValue(bsV, PR_UINT32, bytes - 3);

    for (new i, uint8; i < bytes; i++)
        BS_ReadUint8(bs, uint8), BS_WriteValue(bsV, PR_UINT8, uint8);

    foreach(new i: Player) {
        if(i == playerid) continue;
        if(GetPlayerTeamEx(playerid) != GetPlayerTeamEx(i) || rChannelPlayer{playerid} != rChannelPlayer{i}) continue;
        PR_SendPacket(bsV, i);
    }
    BS_Delete(bsV);
    return 1;
}

case DIALOG_INVITE_PLAYER:
{
    if (!response) return 1;

    switch (listitem)
    {
        case 1:
        {
            new to_player = GetPVarInt(playerid, "invite");

            if (!(GetPlayerTeamEx(playerid) >= 1 && GetPlayerTeamEx(playerid) <= 7))
                return SendClientMessage(playerid, 0xCECECEFF, "* Вам недоступна данная функция");

            if (!(GetPlayerJob(playerid) >= 9 && GetPlayerJob(playerid) <= 10))
                return SendClientMessage(playerid, 0xCECECEFF, "* Функция доступна лидерам организации и их заместителям");

            if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
                return SendClientMessage(playerid, 0xCECECEFF, "* Такого игрока нет");

            if (GetPlayerTeamEx(to_player) >= 1 && GetPlayerTeamEx(to_player) <= 7)
                return SendClientMessage(playerid, 0xCECECEFF, "* Этот игрок уже состоит в организации");

            if (GetPlayerData(to_player, P_WARN))
                return SendClientMessage(playerid, 0xCECECEFF, "* У игрока есть предупреждения");

            if (!IsPlayerInRangeOfPlayer(playerid, to_player, 10.0))
                return SendClientMessage(playerid, 0xCECECEFF, "* Игрок находится слишком далеко");

            SendPlayerOffer(playerid, to_player, OFFER_TYPE_INVITE);
            Action(playerid, "передал(а) комплект специальной униформы");
        }
        case 2:
        {
            new to_player = GetPVarInt(playerid, "invite");

            if (GetPlayerData(playerid, P_FAMILY_RANK) < 9)
                return SCM(playerid, 0xCECECEFF, "* Вам недоступна данная функция");

            if (!GetPlayerData(playerid, P_FAMILY))
                return SendClientMessage(playerid, 0xCECECEFF, "* Вам недоступна данная функция");

            if (!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
                return SendClientMessage(playerid, 0xCECECEFF, "* Такого игрока нет");

            if (GetPlayerData(to_player, P_FAMILY))
                return SendClientMessage(playerid, 0xCECECEFF, "* Игрок состоит в семье");

            if (GetPlayerTeamEx(to_player) >= 1 && GetPlayerTeamEx(to_player) <= 7)
                return SendClientMessage(playerid, 0xCECECEFF, "* Игрок состоит в организации");

            if (GetPlayerData(to_player, P_WARN))
                return SendClientMessage(playerid, 0xFF6600FF, "* У этого игрока есть предупреждения");

            if (!IsPlayerInRangeOfPlayer(playerid, to_player, 10.0))
                return SendClientMessage(playerid, 0xFF6600FF, "* Игрок находится слишком далеко");

            if (g_war[W_STATUS])
            {
                if (g_war[W_ATTACK_TEAM] == GetPlayerFamily(playerid) ||
                    g_war[W_PROTECT_TEAM] == GetPlayerFamily(playerid))
                {
                    return SCM(playerid, -1, "Во время капта нельзя принимать в семью");
                }
            }

            SendPlayerOffer(playerid, to_player, OFFER_TYPE_FINVITE);
        }
    }
    return 1;
}
			case DIALOG_PLAYER_LMENU:
			{
				if(response)
				{
					switch(listitem)
					{
            			case 1:
            			{
                			callcmd::find(playerid, "\1");
            			}
            			case 2:
            			{
             				callcmd::r_channel(playerid);
            			}
           				case 3:
           				{
             				callcmd::blist(playerid, "");
            			}
           				case 4:
            			{
               				callcmd::add_rchannel(playerid);
            			}
            			case 5:
            			{
                			callcmd::invite(playerid, "");
            			}
						default:
							return 1;
					}
				}
			}
        case DIALOG_GLUSHILKA_RADIUS:
        {
            if(!response) return 0;

            new Float:radius = floatstr(inputtext);
            if(radius <= 0.0 || radius > 300.0)
            {
                SendClientMessage(playerid, 0xFF0000FF, "Неверный радиус! Допустимый диапазон: 0.1 - 300.0");
                ShowGlushilkaRadiusDialog(playerid);
                return 1;
            }

            InstallGlushilka(playerid, radius);
            return 1;
        }
        case DIALOG_GLUSHILKA_DEACTIVATE:
        {
            if(!response) return 0;

            DeactivateGlushilka(playerid);
            return 1;
        }
        case DIALOG_BLACKLIST:
        {
            if(response && listitem == 0) ShowBlacklistList(playerid);
            else if(response && listitem == 1) ShowBlacklistAddNick(playerid);
            else if(response && listitem == 2) ShowBlacklistRemoveNick(playerid);
            else return 1;
            return 1;
        }
        case DIALOG_BLACKLIST_NICK:
        {
            if(!response)
            {
                ShowBlacklistMenu(playerid);
                return 1;
            }
            if(strlen(inputtext) < 3 || strlen(inputtext) >= sizeof(g_blacklist_nick[]))
            {
                SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Указан некорректный ник. Ник должен быть от 3 до 23 символов.");
                ShowBlacklistAddNick(playerid);
                return 1;
            }
            new query[128], Cache:result;
            mysql_format(mysql, query, sizeof(query), "SELECT id FROM accounts_1101 WHERE name = '%e' LIMIT 1", inputtext);
            result = mysql_query(mysql, query, true);
            if(!cache_num_rows())
            {
                cache_delete(result);
                SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Аккаунт с таким ником не найден в базе данных. Проверьте правильность написания.");
                ShowBlacklistAddNick(playerid);
                return 1;
            }
            cache_delete(result);
            format(g_blacklist_nick[playerid], sizeof(g_blacklist_nick[]), "%s", inputtext);
            ShowBlacklistAddReason(playerid);
            return 1;
        }
        case DIALOG_BLACKLIST_REASON:
        {
            if(!response)
            {
                ShowBlacklistAddNick(playerid);
                return 1;
            }
            if(strlen(inputtext) < 3 || strlen(inputtext) >= sizeof(g_blacklist_reason[]))
            {
                SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Причина слишком короткая или длинная. Опишите причину (от 3 до 63 символов).");
                ShowBlacklistAddReason(playerid);
                return 1;
            }
            format(g_blacklist_reason[playerid], sizeof(g_blacklist_reason[]), "%s", inputtext);
            ShowBlacklistAddDays(playerid);
            return 1;
        }
        case DIALOG_BLACKLIST_DAYS:
        {
            if(!response)
            {
                ShowBlacklistAddReason(playerid);
                return 1;
            }
            new days = strval(inputtext);
            if(days < 1 || days > 30)
            {
                SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Срок должен быть от 1 до 30 дней.");
                ShowBlacklistAddDays(playerid);
                return 1;
            }
            g_blacklist_days[playerid] = days;
            new to_player = GetPlayerIdByName(g_blacklist_nick[playerid]);
            if(to_player != INVALID_PLAYER_ID)
            {
                ShowBlacklistConfirm(playerid, GetPlayerAccountID(to_player));
            }
            else
            {
                new query[128], Cache:result, accid = 0;
                mysql_format(mysql, query, sizeof(query), "SELECT id FROM accounts_1101 WHERE name = '%e' LIMIT 1", g_blacklist_nick[playerid]);
                result = mysql_query(mysql, query, true);
                if(cache_num_rows())
                {
                    accid = cache_get_field_content_int(0, "id");
                    cache_delete(result);
                    ShowBlacklistConfirm(playerid, accid);
                }
                else
                {
                    cache_delete(result);
                    SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Аккаунт с таким ником не найден в базе данных. Проверьте правильность написания.");
                    ShowBlacklistMenu(playerid);
                }
            }
            return 1;
        }
        case DIALOG_BLACKLIST_CONFIRM:
        {
            if(!response)
            {
                ShowBlacklistAddDays(playerid);
                return 1;
            }
            new accid = GetPVarInt(playerid, "bl_accid");
            if(IsPlayerInBlacklist(g_blacklist_nick[playerid], GetPlayerTeamEx(playerid)))
            {
                SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Этот игрок уже находится в черном списке вашей организации!");
                ShowBlacklistMenu(playerid);
                return 1;
            }
            new to_player = GetPlayerIdByName(g_blacklist_nick[playerid]);
            if(to_player != INVALID_PLAYER_ID)
            {
                AddPlayerToBlacklist(playerid, to_player, g_blacklist_reason[playerid], g_blacklist_days[playerid]);
            }
            else
            {
                AddOfflinePlayerToBlacklist(playerid, g_blacklist_nick[playerid], accid, g_blacklist_reason[playerid], g_blacklist_days[playerid]);
            }
            SendClientMessage(playerid, 0x00FF00FF, "{00FF00}[Успех]{FFFFFF} Игрок успешно добавлен в черный список вашей организации! Теперь он не сможет вступить в нее до истечения срока.");
            return 1;
        }
        case DIALOG_BLACKLIST_LIST:
        {
            if(!response)
            {
                ShowBlacklistMenu(playerid);
                return 1;
            }
            new temp_nick[24];
            new clean_input[128];
            format(clean_input, sizeof(clean_input), "%s", inputtext);
            RemoveColors(clean_input);
            if(sscanf(clean_input, "s[24]", temp_nick))
            {
                new debug_msg[128];
                format(debug_msg, sizeof(debug_msg), "{FF0000}[Ошибка]{FFFFFF} Не удалось извлечь ник: %s", clean_input);
                SendClientMessage(playerid, 0xFF0000FF, debug_msg);
                ShowBlacklistList(playerid);
                return 1;
            }
            if(!IsPlayerInOrgBlacklist(temp_nick, GetPlayerTeamEx(playerid)))
            {
                new debug_msg[128];
                format(debug_msg, sizeof(debug_msg), "{FF0000}[Ошибка]{FFFFFF} Игрок %s не найден в черном списке org_id %d!", temp_nick, GetPlayerTeamEx(playerid));
                SendClientMessage(playerid, 0xFF0000FF, debug_msg);
                ShowBlacklistList(playerid);
                return 1;
            }
            format(g_blacklist_nick[playerid], sizeof(g_blacklist_nick[]), "%s", temp_nick);
            ShowBlacklistDetail(playerid, temp_nick);
            return 1;
        }
        case DIALOG_BLACKLIST_REMOVE_NICK:
        {
            if(!response)
            {
                ShowBlacklistMenu(playerid);
                return 1;
            }
            if(strlen(inputtext) < 3 || strlen(inputtext) >= sizeof(g_blacklist_nick[]))
            {
                SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Указан некорректный ник. Ник должен быть от 3 до 23 символов.");
                ShowBlacklistRemoveNick(playerid);
                return 1;
            }
            if(!IsPlayerInOrgBlacklist(inputtext, GetPlayerTeamEx(playerid)))
            {
                SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} Этот игрок не находится в черном списке вашей организации!");
                ShowBlacklistRemoveNick(playerid);
                return 1;
            }
            format(g_blacklist_nick[playerid], sizeof(g_blacklist_nick[]), "%s", inputtext);
            new reason[64], remaining_days;
            GetBlacklistInfo(inputtext, GetPlayerTeamEx(playerid), reason, remaining_days);
            ShowBlacklistRemoveConfirm(playerid, inputtext, reason, remaining_days);
            return 1;
        }
        case DIALOG_BLACKLIST_REMOVE_CONFIRM:
        {
            if(!response)
            {
                ShowBlacklistRemoveNick(playerid);
                return 1;
            }
            RemoveFromBlacklist(playerid, g_blacklist_nick[playerid]);
            ShowBlacklistMenu(playerid);
            return 1;
        }
        case DIALOG_BLACKLIST_DETAIL:
        {
            if(!response)
            {
                ShowBlacklistList(playerid);
                return 1;
            }
            if(listitem == 5)
            {
                new reason[64], remaining_days;
                GetBlacklistInfo(g_blacklist_nick[playerid], GetPlayerTeamEx(playerid), reason, remaining_days);
                ShowBlacklistRemoveConfirm(playerid, g_blacklist_nick[playerid], reason, remaining_days);
            }
            return 1;
        }
        case DIALOG_RCHANNEL: {
			if(!response || !(0<=listitem<=sizeof rChannelList)) return 1;

			if(!rChannelPlayer{playerid}) {
				SCMF(playerid, -1, "Вы успешно подключились к каналу 10%d.0", listitem);
				SendClientEventF(playerid, s_CefInterface, t_CefUpdate, "interface('Hud').showVoiceChatButton(1)");
				rChannelPlayer{playerid} = listitem+1;
				rChannelList[GetPlayerTeamEx(playerid)-1][listitem]++;

				foreach(new i: Player) {
					if(i == playerid) continue;
					if(GetPlayerTeamEx(playerid) != GetPlayerTeamEx(i) || rChannelPlayer{playerid} != rChannelPlayer{i}) continue;

					CreatePacketRadio(i, (playerid+1000), 100);
					CreatePacketRadio(playerid, (i+1000), 100);
				}
			}
			else if(rChannelPlayer{playerid} == listitem+1) {
				SCM(playerid, -1, "Вы успешно отключились от канала");
				SendClientEventF(playerid, s_CefInterface, t_CefUpdate, "interface('Hud').hideVoiceChatButton(1)");
				rChannelList[GetPlayerTeamEx(playerid)-1][listitem]--;

				foreach(new i: Player) {
					if(i == playerid) continue;
					if(GetPlayerTeamEx(playerid) != GetPlayerTeamEx(i) || rChannelPlayer{playerid} != rChannelPlayer{i}) continue;

					VoiceCloseStream(i, (playerid+1000));
					VoiceCloseStream(playerid, (i+1000));
				}
				rChannelPlayer{playerid} = 0;
			}
			else {
				SCMF(playerid, -1, "Вы успешно сменили канал на 10%d.0", listitem);
				rChannelList[GetPlayerTeamEx(playerid)-1][listitem]++;
				rChannelList[GetPlayerTeamEx(playerid)-1][rChannelPlayer{playerid}-1]--;

				foreach(new i: Player) {
					if(i == playerid) continue;
					if(GetPlayerTeamEx(playerid) != GetPlayerTeamEx(i)) continue;

					if(rChannelPlayer{playerid} == rChannelPlayer{i}) {
						VoiceCloseStream(i, (playerid+1000));
						VoiceCloseStream(playerid, (i+1000));
					}
					else if(rChannelPlayer{i} == (listitem+1)) {
						CreatePacketRadio(i, (playerid+1000), 100);
						CreatePacketRadio(playerid, (i+1000), 100);
					}
				}
				rChannelPlayer{playerid} = listitem+1;
			}
		}
		case DIALOG_RCHANNEL_CREATE:
		{
			if(!response) return 1;

			if(strlen(inputtext) < 3 || strlen(inputtext) > 32)
			{
				SendClientMessage(playerid, 0xFF0000FF, "Название канала должно содержать от 3 до 32 символов");
				Dialog(playerid, DIALOG_RCHANNEL_CREATE, DIALOG_STYLE_INPUT, "Создание канала", "Введите название канала:", "Создать", "Отмена");
				return 1;
			}

			new query[512];
			mysql_format(mysql, query, sizeof(query), "INSERT INTO rchannels (organ_id, owner_name, channel_name, created_at) VALUES (%d, '%e', '%e', NOW())",
				GetPlayerTeamEx(playerid), GetPlayerNameEx(playerid), inputtext);
			mysql_tquery(mysql, query, "OnCreateRChannel", "d", playerid);
		}
		case DIALOG_SNOW_TYPE:
		{
			switch(listitem)
			{
				case 0:
				{
					SCM(playerid, COLOR_YELLOW, "Начинайте работу снегоуборщика, ездите по чекпоинтам и убирайте снег! Вам выпал первый маршрут.");
					SetPlayerRaceCheckpoint(playerid, 0, -280.5028,-1463.0747,40.2893, 0.0,0.0,0.0, 4.0, RCP_ACTION_TYPE_SNOW_1);
					snow_veh[playerid] = GetPlayerVehicleID(playerid);

	STRING_GLOBAL[0] = EOS;

    UpdateMoneyDonate(playerid);

	switch(index)
	{
		case MENU_MAIN_MAP:
		{
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').showMapBusiness('[[1,1],[2,1],[4,1],[5,1],[7,1],[10,1],[11,1],[12,1],[13,1],[15,1],[16,1],\

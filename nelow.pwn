	BJ_STATUS,
	BJ_TIMER,
	BJ_T_CARD_1[MAX_CARDS],
	BJ_E_CARD_1[MAX_CARDS],
	BJ_T_CARD_2[MAX_CARDS],
	BJ_E_CARD_2[MAX_CARDS]
}
new g_blackjack[MAX_PLAYERS][E_BLACKJACK_STRUCT];


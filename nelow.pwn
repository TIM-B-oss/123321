stock DeleteItems(item_id)
{
	SetPlayerItem(item_id, PI_SQL_ID, 		0);
	SetPlayerItem(item_id, PI_OWNER_ID, 	0);
	SetPlayerItem(item_id, PI_RETURN_ITEMS, 0);

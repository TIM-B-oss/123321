                return 1;
            }
            new donate_price = 1200000;
            format(fmt_text, sizeof fmt_text, "Вы сконвертировали %d.00 RUB. в %d рублей.", money_amount, money_amount * donate_price);
            SCM(playerid, -1, fmt_text);
            format(fmt_text, sizeof fmt_text, "~w~+%d рублей~n~~y~-%d RUB", money_amount * donate_price, money_amount);
            GameText(playerid, fmt_text, 4000, 2);
            GivePlayerDonateRub(playerid, -money_amount);

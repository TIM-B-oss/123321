		{
		    format(STRING_GLOBAL, sizeof(STRING_GLOBAL), "interface('CasinoRullet').showAlert(0, %d, %d, %d)", chislo, GetPVarInt(playerid, "Rull_Bet"), GetIteam(playerid, 293));

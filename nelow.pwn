			kase_osnova[playerid] = CreateDynamicObject(7097, case_x, case_y, Z-0.7, 0.0,0.0,angle);
			SetPVarInt(playerid, "case_type", 16);
		}
		else return SendPacket_1(playerid, s_CefInterface, t_CefHide,"Case");

		ApplyAnimation(playerid, "BOMBER", "BOM_Plant", 4.0, 0, 0, 0, 0, 0);
		Streamer_UpdateEx(playerid, X, Y, Z, GetPlayerVirtualWorld(playerid), GetPlayerInterior(playerid));
		InterpolateCameraPos(playerid, cam_x, cam_y, cam_z, X + (0.95 * floatsin(-angle, degrees)), Y + (0.95 * floatcos(-angle, degrees)), Z + 0.2, 5000, CAMERA_MOVE);
		InterpolateCameraLookAt(playerid, X + (0.5 * floatsin(-angle, degrees)), Y + (0.5 * floatcos(-angle, degrees)), Z - 0.5, case_x, case_y, Z - 0.85, 5000, CAMERA_MOVE);
		SetTimerEx("OpenCase", 7000, false, "i", playerid);
		SetPVarInt(playerid, "CaseFree", 1);
	}
	GameText(playerid, "~g~Успешно", 4000, 2);
	SCM(playerid, 0x5DA130FF, "Награда была добавлена на Ваш аккаунт.");

	format(fmt_text, sizeof fmt_text, "DELETE FROM prizes WHERE id='%d'", id);
	mysql_query(mysql, fmt_text, false);

	LoadMainMenu(playerid, MENU_MAIN_PRIZE);
	return 1;
}
public:MenuInt_OnPlayerKey(playerid)
{
    new json[600] = "[\"\",[";

    strcat(json, "[1,\"Персонаж\",\"Character\",1]");

    if(1 <= GetPlayerTeamEx(playerid) <= 7)
        strcat(json, ",[1,\"Организация\",\"Organization\",2]");

    strcat(json, ",[1,\"Транспорт\",\"Vehicle\",4]");

    if(GetPlayerHouse(playerid) != -1)
        strcat(json, ",[1,\"Недвижимость\",\"Buildings\",7]");

    strcat(json, ",[1,\"Другое\",\"Other\",6]");

    strcat(json, "],[]]");

    SendPacket_2(playerid, s_CefInterface, t_CefShow, "PlayerInteraction", json);
}
public:MenuInt_OnPlayerClickItem(playerid, type, event)
{
    if(event == 0)
    {
        if(type == 0)
        {
           SendPacket_2(playerid, s_CefInterface, t_CefShow, "MainMenu", "[-1, 1, []]");
           LoadMainMenu(playerid, MENU_MAIN_STATS);
        }
        if(type == 1)
        {
           SendPacket_2(playerid, s_CefInterface, t_CefShow, "MainMenu", "[-1, 0, []]");
           LoadMainMenu(playerid, MENU_MAIN_MAP);
        }
        if(type == 2)
        {
                new fmt_text[200];
                format(fmt_text, sizeof fmt_text, "[[0,[\"%s\",%d,\"Дом\",%d,0,%d,%d,%d,\"\"]]]",
                GetPlayerNameEx(playerid),
                GetPlayerData(playerid, P_SEX) ? 1 : 0,
                GetPlayerLevel(playerid),
                GetPlayerSkin(playerid),
                GetPlayerData(playerid, P_LAW_ABIDING),
                0);
                SendPacket_2(playerid, s_CefInterface, t_CefShow, "Docs", fmt_text);
                Action(playerid, "просматривает свой паспорт", _, false);
        }
        if(type == 3) callcmd::anim(playerid, "");
        if(type == 4) callcmd::craft(playerid);
        if(type == 5) callcmd::bugreport(playerid, "");
        if(type == 6) callcmd::mytickets(playerid, "");
        if(type == 7) callcmd::myjobs(playerid);
        if(type == 8) callcmd::warns(playerid);
        if(type == 9) callcmd::plist(playerid, "");
        if(type == 10) callcmd::liclist(playerid);
        if(type == 11) callcmd::leave(playerid);

		//транспорт
        if(type == 12) callcmd::lock(playerid, "1");
        if(type == 13) callcmd::trunk(playerid);
        if(type == 14) SendClientMessage(playerid, 0xCECECEFF, "Используйте: /carpass [ID игрока]");
        if(type == 15) MakeStroboskopes(playerid);
        if(type == 16) MusicCarPlayer(playerid);
        if(type == 19) ShowCarAccessoriesList(playerid);
        if(type == 20) ShowActiveCarAccessoriesList(playerid);

		//другое
        if(type == 17) callcmd::events(playerid);
        if(type == 18) callcmd::leaders(playerid);

        // организация
        if(type == 21) callcmd::r_channel(playerid);
        if(type == 22) callcmd::find(playerid, ""); 
        if(type == 23) callcmd::blist(playerid, "");
        if(type == 24) callcmd::leave(playerid);

        // недвижимость
        if(type == 26) callcmd::home(playerid); 
        if(type == 27) callcmd::sellhome(playerid);
        if(type == 28) callcmd::sellmyhomee(playerid, "");
        if(type == 29) callcmd::use(playerid,""); 
        if(type == 30) callcmd::makestore(playerid, "");
    }
    if(event == 1)
    {
        if(type == 1)
        {
            if(GetPlayerData(playerid, P_TARGET_ID) == INVALID_PLAYER_ID)
                SendPacket_1(playerid, s_CefInterface, t_CefUpdate,"interface('PlayerInteraction').onServerResponse('[\"\",[[0,\"Личная информация\",1,0,0],[0,\"Навигация\",1,1,1],[0,\"Мои документы\",1,2,2],[0,\"Анимации\",1,3,3],[0,\"Скрафтить\",1,4,4],[0,\"Баг-репорт\",1,5,5],[0,\"Список штрафов\",1,6,6],[0,\"Список профессий\",1,7,7],[0,\"Список предупреждений\",1,8,8],[0,\"Бонусы\",1,9,9],[0,\"Списки доступных сотрудников\",1,10,0],[0,\"Уволиться\",1,11,0]]]')");
            else
                SendPacket_1(playerid, s_CefInterface, t_CefUpdate,"interface('PlayerInteraction').onServerResponse('[\"\",[[0,\"Личная информация\",1,0,0],[0,\"Навигация\",1,1,1],[0,\"Мои документы\",1,2,2],[0,\"Анимации\",1,3,3],[0,\"Скрафтить\",1,4,4],[0,\"Обмен предметами\",1,5,5],[0,\"Список штрафов\",1,6,6],[0,\"Список профессий\",1,7,7],[0,\"Список предупреждений\",1,8,8],[0,\"Бонусы\",1,9,9]]]')");
        }
        if(type == 2)
        {
                SendPacket_1(playerid, s_CefInterface, t_CefUpdate,"interface('PlayerInteraction').onServerResponse('[\"\",[[0,\"Рация\",2,21,0],[0,\"Список участников онлайн\",2,22,1],[0,\"Черный список\",2,23,2],[0,\"Выйти из организации\",2,24,3]]]')");
        }
        if(type == 4)
        {
            new vehicleid = GetVehicleModel(GetPlayerVehicleID(playerid));
            if(vehicleid == 15217 || vehicleid == 15620 || vehicleid == 528 || vehicleid == 15143 || vehicleid == 525 || vehicleid == 15186 || vehicleid == 596 || vehicleid == 597 || vehicleid == 598 || vehicleid == 15609 || vehicleid == 15608 || vehicleid == 15607 || vehicleid == 15606 || vehicleid == 15610 || vehicleid == 15241 || vehicleid == 523 || vehicleid == 427 || vehicleid == 15604 || vehicleid == 15282 || vehicleid == 15283 || vehicleid == 599 || vehicleid == 489 || vehicleid == 15157 || vehicleid == 15630)
                SendPacket_1(playerid, s_CefInterface, t_CefUpdate,"interface('PlayerInteraction').onServerResponse('[\"\",[[0,\"Закрыть двери\",4,12,0],[0,\"Багажник\",4,13,1],[0,\"Украшения\",4,19,2],[0,\"Посмотреть тех. паспорт\",4,14,3],[0,\"Стробоскопы\",4,15,4],[0,\"Активные украшения\",4,20,5]]]')");
            else
                SendPacket_1(playerid, s_CefInterface, t_CefUpdate,"interface('PlayerInteraction').onServerResponse('[\"\",[[0,\"Магнитолла\",4,16,0],[0,\"Закрыть двери\",4,12,1],[0,\"Багажник\",4,13,2],[0,\"Украшения\",4,19,3],[0,\"Посмотреть тех. паспорт\",4,14,4],[0,\"Активные украшения\",4,20,5]]]')");
        }
        if(type == 7)
        {
                SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('PlayerInteraction').onServerResponse('[\"\",[[0,\"Мой дом\",7,26,0],[0,\"Слить дом\",7,27,1],[0,\"Продать дом\",7,28,2],[0,\"Открыть Шкаф\",7,29,3],[0,\"Перенести шкаф\",7,30,1]]]')");
        }
        if(type == 6)
        {
            SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('PlayerInteraction').onServerResponse('[\"\",[[0,\"Список событий\",6,17,0],[0,\"Список руководителей\",6,18,1]]]')");
        }
    }
    return true;
}
stock ShowCarAccessoriesList(playerid)
{
    new vehicleid = GetNearestVehicleID(playerid, 6.0),
        vehicleid1 = GetPlayerOwnableCarLast(playerid);

    if(vehicleid1 != vehicleid)
        return SendClientMessage(playerid, 0x4169E1FF, "Вы должны находиться около личного транспорта");

    new index = GetVehicleData(vehicleid, V_ACTION_ID),
        car_id = GetOwnableCarData(index, OC_SQL_ID);

    new query[250], Cache:result;
    mysql_format(mysql, query, sizeof query, "SELECT * FROM cars_accessories WHERE car_id='%d'", car_id);
    result = mysql_query(mysql, query, true);

    new rows = cache_num_rows();
    if(!rows)
    {
        cache_delete(result);
        return SendClientMessage(playerid, 0x4169E1FF, "На данном транспорте не установлены аксессуары");
    }

    SetPVarInt(playerid, "AcsVehicleCar", vehicleid);
    string_dialog[0] = EOS;

    for(new i = 0; i < rows; i++)
    {
        SetPlayerListitemValue(playerid, i, cache_get_field_content_int(i, "id"));
        format(query, sizeof query, "%d. Аксессуар [№%d]\n", i + 1, cache_get_field_content_int(i, "model_id"));
        strcat(string_dialog, query);
    }

    strdel(string_dialog, strlen(string_dialog) - 1, strlen(string_dialog));

    Dialog(playerid, DIALOG_CAR_ACCESSORIES_LIST, DIALOG_STYLE_LIST,
        "{FFD83D}Список украшений", string_dialog, "Снять", "Выйти");

    cache_delete(result);
    return 1;
}
stock ShowActiveCarAccessoriesList(playerid)
{
    new vehicleid = GetNearestVehicleID(playerid, 6.0),
        vehicleid1 = GetPlayerOwnableCarLast(playerid);

    if(vehicleid1 != vehicleid)
        return SendClientMessage(playerid, 0x4169E1FF, "Вы должны находиться около личного транспорта");

    new index = GetVehicleData(vehicleid, V_ACTION_ID),
        car_id = GetOwnableCarData(index, OC_SQL_ID);

    new query[500], Cache:result;
    mysql_format(mysql, query, sizeof query, "SELECT * FROM cars_accessories WHERE car_id='%d'", car_id);
    result = mysql_query(mysql, query, true);

    new rows = cache_num_rows();
    if(!rows)
    {
        cache_delete(result);
        return SendClientMessage(playerid, 0x4169E1FF, "На данном транспорте не установлены активные аксессуары");
    }

    SetPVarInt(playerid, "AcsVehicleCar", vehicleid);
    string_dialog = "Название\tСтатус\n";

    for(new i = 0; i < rows; i++)
    {
        new model_id = cache_get_field_content_int(i, "model_id");
        if(!IsActiveAcsID(model_id)) continue;

        SetPlayerListitemValue(playerid, i, cache_get_field_content_int(i, "id"));

        new status[32];
        if(active_acs_id[playerid] != cache_get_field_content_int(i, "id"))
            format(status, sizeof status, "На транспорте");
        else
            format(status, sizeof status, "Снято с транспорта");

        format(query, sizeof query, "%s\t%s\n", GetActiveAcsName(model_id), status);
        strcat(string_dialog, query);
    }
    if(strlen(string_dialog) > 14)
        strdel(string_dialog, strlen(string_dialog) - 1, strlen(string_dialog));

    Dialog(playerid, DIALOG_CAR_ACTIVE_ACS_LIST, DIALOG_STYLE_TABLIST_HEADERS,
        "{FFFFFF}Активные аксессуары", string_dialog, "Выбор", "Закрыть");

    cache_delete(result);
    return 1;
}
stock AddPlayerAchiv(playerid, type)
{
	if(type == 1)
	{
		new items = GetPlayerJobLoadItems(playerid);

        new pay_sum = items;
        
		pay_sum = pay_sum * g_doubling[DOUBLING_WAGE];

		AddPlayerData(playerid, P_ACHIV_1, +, pay_sum);
        UpdatePlayerDatabaseInt(playerid, "achiv_1", GetPlayerData(playerid, P_ACHIV_1));

		if(GetPlayerData(playerid, P_ACHIV_1) >= 5000000 && GetPlayerData(playerid, P_ACHIV_1_COMPLETED) == 0)
		{
			GivePlayerMyPrizes(playerid, "Донат", 10, 0, 0, 150, 0);
            SendClientMessage(playerid, COLOR_GREEN, "Поздравляем! Вы получили достижение: {FFFF00}\"Делать деньги вот так!\"");
			SendClientMessage(playerid, 0xead671FF, "Вам выдана награда за получение достижения. Используйте {ffffff}клавишу M > Награды, {ead671}чтобы забрать её.");

			SetPlayerData(playerid, P_ACHIV_1_COMPLETED, 1);
            UpdatePlayerDatabaseInt(playerid, "achiv_1_completed", 1);

			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('AchievementNotification').Show()");
		}
	}
	if(type == 2)

public: OnMiniGamePlayerComplete(playerid)
{
	new biz_id = GetPVarInt(playerid, "electro_biz");
	SCM(playerid, COLOR_WHITE, "Вы успешно починили электрику в бизнесе");
	ClearAnimations(playerid);
	zakazi[playerid] ++;
	SendPacket_1(playerid, s_CefInterface, t_CefHide, "Wires");
	GivePlayerMoneyEx(playerid, 10000000);
	new fmt_text[90];
	GiveRandomCase(playerid);
	format(fmt_text, sizeof fmt_text, "UPDATE business SET countlight=100 WHERE id=%d", GetBusinessData(biz_id, B_SQL_ID));
	mysql_query(mysql, fmt_text, true);
}

public: GiveRandomCase(playerid)
{
	new random1 = RandomEx(1,4);

	if(random1 == 1)
	{
		new type = RandomEx(1,134);
		new random111 = RandomEx(5,20);

		if(type == 1) GiveIteam(playerid, 258, 1, random111, 0);
		if(type == 2) GiveIteam(playerid, 261, 1, random111, 0);
		if(type == 3) GiveIteam(playerid, 272, 1, random111, 0);
		if(type == 4) GiveIteam(playerid, 278, 1, random111, 0);
		if(type == 5) GiveIteam(playerid, 284, 1, random111, 0);
		if(type == 6) GiveIteam(playerid, 290, 1, random111, 0);
		if(type == 7) GiveIteam(playerid, 300, 1, random111, 0);
		if(type == 8) GiveIteam(playerid, 328, 1, random111, 0);
		if(type == 9) GiveIteam(playerid, 344, 1, random111, 0);
		if(type == 10) GiveIteam(playerid, 348, 1, random111, 0);
		if(type == 11) GiveIteam(playerid, 350, 1, random111, 0);
		if(type == 12) GiveIteam(playerid, 355, 1, random111, 0);
		if(type == 13) GiveIteam(playerid, 356, 1, random111, 0);
		if(type == 14) GiveIteam(playerid, 360, 1, random111, 0);

		SCM(playerid, COLOR_GREEN, "Вы получили халявные кейсы!");

		return 1;
	}
	else return 1;
}

CMD:eleclist(playerid, params[])
{
	new vehicleid = GetPlayerVehicleID(playerid);
	new modelid = GetVehicleModel(vehicleid);
	if(modelid != 15629) return SCM(playerid, COLOR_RED, "Чтобы начать работу электрика, нужно сидеть в служебной машине.");
	if(GetPlayerData(playerid, P_JOB) != 6) return SCM(playerid, COLOR_RED, "Вы не работаете электриком, трудоустроиться можно в центре занятости!");
	{
		new fmt_text[2640],biz_id,biz_name[123],query[1000],Float: dist;
	    new Cache: result;
		mysql_format(mysql, fmt_text, sizeof fmt_text, "SELECT * FROM business WHERE countlight=0 LIMIT 20");
		result = mysql_query(mysql, fmt_text, true);
		new rows = cache_num_rows();
		if(!rows) return SendClientMessage(playerid, 0x999999FF, "Починка электричества, пока не требуется.");
		else
		{
		    format(fmt_text, sizeof fmt_text, "");
			for(new i = 0; i < rows; i ++)
			{
				biz_id = cache_get_field_content_int(i, "id");
				cache_get_field_content(i, "name", biz_name);
				dist = GetPlayerDistanceFromPoint(playerid, GetBusinessData(biz_id, B_EXIT_POS_X), GetBusinessData(biz_id, B_EXIT_POS_Y), GetBusinessData(biz_id, B_EXIT_POS_Z));
				format(query, sizeof query, "{FFFFFF}%d. - %s (№%d)<t>{FFFFFF}%.2f м.\n", i + 1, biz_name, biz_id, dist);
				strcat(fmt_text, query);
				SetPlayerListitemValue(playerid, i, biz_id);
			}
		}
		Dialog(playerid, DIALOG_ELECTRO_BIZ, DIALOG_STYLE_LIST,"{FFCD00}Выберите бизнес",fmt_text,"Выбрать", "Закрыть");
		cache_delete(result);
	}
	return 1;
}
cmd:game_text(playerid, params[])

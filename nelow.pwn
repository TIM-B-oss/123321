};

enum // типы предложений
{
	OFFER_TYPE_NONE = -1,
	OFFER_TYPE_HANDSHAKE, 		// приветствие
	OFFER_TYPE_WEDDING,         // женитьба
	OFFER_TYPE_SELL_FUEL_ST, 	// продажа АЗС

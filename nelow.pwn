	format(fmt_text, sizeof fmt_text, "Генерал %s[%d] выдал Вам военный билет", GetPlayerNameEx(playerid), playerid);
	SendClientMessage(to_player, 0x6495EDFF, fmt_text);

    SetPlayerData(to_player, P_VOEN, 1);

                  format(query, sizeof query, "UPDATE gardens SET owner_id=0,improvements=0,owner_name='None' WHERE id=%d", GetGardenData(i, G_SQL_ID));
                  mysql_query(mysql, query, false);
                  format(g_garden[i][G_OWNER_NAME], 21, "Государство");
                }
                  for(new i = 0; i < g_kiosk_loaded; i++)
                {
                  if(GetKioskData(i, K_OWNER_ID) == 0) continue;
                  format(query, sizeof query, "UPDATE kiosk SET owner_id=0 WHERE id=%d", GetKioskData(i, K_SQL_ID));
                  mysql_query(mysql, query, false);
                  format(query, sizeof query, "UPDATE accounts_1101 SET kiosk=-1 WHERE id=%d", GetKioskData(i, K_OWNER_ID));
                  mysql_query(mysql, query, false);
                }
                  SendClientMessage(playerid, 0x66CC33FF, "ВСЁ имущество передано в госсобственность.");
                }

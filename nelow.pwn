									GetVehiclePos(i, X,Y,Z);
									SetPlayerVirtualWorld(playerid, biz_id);
									SetVehicleVirtualWorld(i, biz_id);
								    SetPlayerCameraPos(playerid, X- 7, Y, Z+3);
									SetPlayerCameraLookAt(playerid, X, Y, Z+1, 2);
									return 1;
								}
						    }
						}
					 }
				}
		    }
		    if(arendavibor[playerid] == 5)

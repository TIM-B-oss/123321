				DeletePVar(playerid, "jerrican_fill_car");
				
				if(modelid == 15126)
					return SendClientMessage(playerid, 0xCECECEFF, "В транспортном средстве установлен электродвигатель, вы не сможете заправить его бензином.");

				if(modelid == 543)
					return SendClientMessage(playerid, 0xCECECEFF, "В транспортном средстве установлен электродвигатель, вы не сможете заправить его бензином.");

				if(modelid == 15192)

public: DonateCar(playerid)
{
	SendPacket_2(playerid, s_CefInterface, t_CefShow, "DonateItem", "[\"Пуля\",\"Лимитированная коллекция\",30000,1537368800,9999]");


	if(IsPlayerInRangeOfPoint(playerid,6.0, -410.4265,746.6846,12.2719))
	{
		InterpolateCameraPos(playerid, -404.3388,752.5552,13.5498, -404.3388,752.5552,13.5498, 50000);
		InterpolateCameraLookAt(playerid, -412.5965,745.0398,12.4357, -412.5965,745.0398,12.4357, 2000);
	}
	
	if(IsPlayerInRangeOfPoint(playerid,6.0, 1863.8513,2800.5598,11.9720))
	{
		InterpolateCameraPos(playerid, 1866.5756,2808.1641,13.4821, 1866.5756,2808.1641,13.4821, 50000);
		InterpolateCameraLookAt(playerid, 1862.1154,2798.6445,12.0644, 1862.1154,2798.6445,12.0644, 2000);
	}

	if(IsPlayerInRangeOfPoint(playerid,6.0, -1934.6722,2909.2190,5.8838))
	{
		InterpolateCameraPos(playerid, -1940.3756,2903.8860,7.2464, -1940.3756,2903.8860,7.2464, 50000);
		InterpolateCameraLookAt(playerid, -1931.8500,2910.5750,7.1096, -1931.8500,2910.5750,7.1096, 2000);
	}

	if(IsPlayerInRangeOfPoint(playerid,6.0, -2158.8955,-1916.5479,8.9884))
	{
		InterpolateCameraPos(playerid, -2157.4590,-1908.6771,10.5537, -2157.4590,-1908.6771,10.5537, 50000);
		InterpolateCameraLookAt(playerid, -2160.2756,-1919.1246,9.2284, -2160.2756,-1919.1246,9.2284, 2000);
	}	

	if(IsPlayerInRangeOfPoint(playerid,6.0, 1918.4847,-1980.7645,31.3492))
	{
		InterpolateCameraPos(playerid, 1916.3906,-1972.9222,33.100, 1916.3906,-1972.9222,33.100, 50000);
		InterpolateCameraLookAt(playerid, 1918.5548,-1984.1033,32.6395, 1918.5548,-1984.1033,32.6395, 2000);
	}
}


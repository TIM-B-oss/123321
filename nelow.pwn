			[131,0],[132,1],[133,1],[134,1],[135,1],[136,1],[137,1],[138,1],[140,1],[141,1],[143,1],[144,1],[146,1],\
			[147,1],[148,1],[149,1],[150,1],[152,1],[156,1],[157,1],[159,1],[161,1]]')");
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').addMapPoints('[[21,\"Новогодняя ёлка\",[-4478.39,5758.82,8.89]],[21,\"Битва со снеговиками\",[-380.55,1809.10,14.02]],[21,\"Пещеры\",[-1230.22,656.64,74.01]], \
			[21,\"Прыжок в дымоход\",[-1512.98,-981.10,50.02]],[49,\"Дрифт-трасса\",[3133.67,-82.33,14.93]],[103,\"Продажа кристаллов\",[-1184.13,734.09,71.07]]]')");
			new Float: X, Float: Y, Float: A;

			    case 2: ApplyAnimation(playerid, "ped",				"endchat_03",			4.0, true,  1, 1, 1, 0), SetPlayerData(playerid, P_USE_ANIM, true), SendPacket_2(playerid, s_CefInterface, t_CefShow, "Interactions", "[[1, \"Выключить анимацию\"]]");

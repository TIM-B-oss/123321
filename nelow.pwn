						Dialog(playerid, DIALOG_BIZ_INFO, DIALOG_STYLE_MSGBOX, "{33AACC}Информация о бизнесе", string_dialog, "Изменить", "Отмена");
					}
				}
			}
			case DIALOG_PAY_FOR_RENT_HOME:
			{
                if (!response)
                {
                   return 1;
                }
				new houseid = GetPlayerListitemValue(playerid, listitem) + 1;
				
				if(houseid != -1)
				{
					SetPVarInt(playerid, "ownablehouse_id", houseid);

					new fmt_str[256];

					format
					(
						fmt_str, sizeof fmt_str,
						"{FFFFFF}Дом:\t\t\t\t\t№%d (%s)\n"\
						"Оплаченных дней аренды:\t\t%d из 30\n"\
						"Ежедневная квартплата:\t\t%d руб\n"\
						"Субсидия:\t\t\t\t%s\n\n"\
						"На сколько дней Вы хотите оплатить дом?",
						houseid,
						GetHouseData(houseid, H_NAME),
						GetHouseData(houseid, H_RENT_DATE) <= gettime() ? 0 :
						GetElapsedTime(GetHouseData(houseid, H_RENT_DATE), gettime(), CONVERT_TIME_TO_DAYS),
						GetHouseData(houseid, H_IMPROVEMENTS) < 3 ? GetHouseData(houseid, H_RENT_PRICE) : GetHouseData(houseid, H_RENT_PRICE) / 2,
						GetHouseData(houseid, H_IMPROVEMENTS) < 3 ? ("Нет") : ("Есть")
					);
					Dialog(playerid, DIALOG_PAY_FOR_RENT_HOUSE, DIALOG_STYLE_INPUT, "{66CC00}Оплата дома", fmt_str, "Оплатить", "Назад");
				}
			}
			case DIALOG_MUSIX_CATEGORIES:
			{
               if(!response || listitem < 0 || listitem >= CAT_COUNT)
               return 1;

               SetPVarInt(playerid, "BoomboxCategory", listitem);

               new track_list[1024] = "";
               new start = 0, count = 0;

               switch(listitem)
               {
                  case CAT_ISLAM:          { start = 0;  count = 4; }
                  case CAT_MURAT:          { start = 4;  count = 4; }
                  case CAT_KIZARU:         { start = 8;  count = 4; }
                  case CAT_MORGENSHTERN:   { start = 12; count = 4; }
                  case CAT_NYU:            { start = 16; count = 4; }
                  case CAT_TSOI:           { start = 20; count = 4; }
                  case CAT_PASHA_TECHNIK:  { start = 24; count = 4; }
                  case CAT_KINO:           { start = 28; count = 4; }
                  case CAT_SEKTOR_GAZA:    { start = 32; count = 4; }
                  case CAT_KOROL_I_SHUT:   { start = 36; count = 4; }
                  case CAT_ALL:            { start = 0;  count = sizeof(gBoomboxTitles); }
               }

               for(new i = 0; i < count; i++)
               {
               new idx = (listitem == CAT_ALL) ? i : (start + i);
               format(track_list, sizeof(track_list), "%s{FFFFFF}%s\n", track_list, gBoomboxTitles[idx]);
               }

               Dialog(playerid, DIALOG_MUSIX_BOOMBOX_1, DIALOG_STYLE_LIST, "{FFD83D}Выберите трек", track_list, "Играть", "Назад");
               return 1;
            }
            case DIALOG_MUSIX_BOOMBOX_1:
            {
               if(!response) return 1;

               if(BoxInfo[playerid][box_music] != 0) return SendClientMessage(playerid, 0xFF6600FF, "Бумбокс уже используется");

               new cat = GetPVarInt(playerid, "BoomboxCategory");
               new real_index = -1;
               
               if(cat == CAT_ALL)
               {
                  real_index = listitem;
               }
               else
               {
               new start = 0;
               switch(cat)
               {
               case CAT_ISLAM:          start = 0;
               case CAT_MURAT:          start = 4;
               case CAT_KIZARU:         start = 8;
               case CAT_MORGENSHTERN:   start = 12;
               case CAT_NYU:            start = 16;
               case CAT_TSOI:           start = 20;
               case CAT_PASHA_TECHNIK:  start = 24;
               case CAT_KINO:           start = 28;
               case CAT_SEKTOR_GAZA:    start = 32;
               case CAT_KOROL_I_SHUT:   start = 36;
               }
               real_index = start + listitem;
               }

               if(real_index < 0 || real_index >= sizeof(gBoomboxURLs))
               return 1;

               new Float:X, Float:Y, Float:Z, Float:Angle;
               GetPlayerPos(playerid, X, Y, Z);
               GetPlayerFacingAngle(playerid, Angle);

               BoxInfo[playerid][box_x] = X;
               BoxInfo[playerid][box_y] = Y;
               BoxInfo[playerid][box_z] = Z;
               BoxInfo[playerid][box_music] = 1;

               foreach(new i : Player)
               PlayAudioStreamForPlayer(i, gBoomboxURLs[real_index], X, Y, Z, DistanceMusic, 1);

               ApplyAnimation(playerid, "BOMBER", "BOM_Plant", 2, 0, 0, 0, 0, 0);
               BoxInfo[playerid][box_object] = CreateDynamicObject(1747, X, Y + 0.6, Z - 0.8, 0.0, 0.0, Angle);

               new description[256];
               format(description, sizeof(description),
               "{FF8800}JBL Boombox\n" \
               "{FFFFFF}Поставил: {FFD700}%s(%d)\n" \
               "{FFFFFF}Играет: %s\n" \
               "{FFFFFF}Убрать – {FFD700}/boombox_pick",
               GetPlayerNameEx(playerid), playerid, gBoomboxTitles[real_index] );
               BoxInfo[playerid][box_label] = CreateDynamic3DTextLabel(description, -1, X, Y + 0.6, Z + 0.25, 20.0);

               SendClientMessage(playerid, COLOR_GOLD, "Вы успешно установили бумбокс");
               DeletePVar(playerid, "BoomboxCategory");
               return 1;
             }
             case DIALOG_SELLMYHOME_STEP1:
             {
                if(!strlen(inputtext) || !IsNumeric(inputtext))
                return SendClientMessage(playerid, 0xFF6600FF, "Некорректный ID игрока");

                new to_player = strval(inputtext);

                if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player) || to_player == playerid)
                return SendClientMessage(playerid, 0xFF6600FF, "Такого игрока нет");

                SetPVarInt(playerid, "sellhome_target", to_player);

                Dialog(playerid, DIALOG_SELLMYHOME_STEP2, DIALOG_STYLE_INPUT,
                "{FFCD00}Продажа дома",
                "Введите стоимость продажи (в рублях):",
                "Далее", "Отмена");
            }
            case DIALOG_SELLMYHOME_STEP2:
            {
                if(!strlen(inputtext) || !IsNumeric(inputtext))
                return SendClientMessage(playerid, 0xFF6600FF, "Укажите корректную сумму");

                new price = strval(inputtext);

                if(price < 1)
                return SendClientMessage(playerid, 0xFF6600FF, "Стоимость не может быть меньше 1");

                new to_player = GetPVarInt(playerid, "sellhome_target");

                if(!GetILPlayerInt(GetPlayerMoneyEx(to_player), price))
                return SendClientMessage(playerid, 0xFF6600FF, "У игрока недостаточно денег для покупки");

                if((GetPlayerOwnableHouse(to_player) + 1) > GetPlayerHouseSlots(to_player))
                return SendClientMessage(playerid, 0x3399FFFF, "У игрока уже максимальное количество домов");

                SetPVarInt(playerid, "Sellprice", price);
                SetPVarInt(playerid, "to_player", to_player);

                new query[94], Cache: result, biz_id;
                mysql_format(mysql, query, sizeof query, "SELECT * FROM houses WHERE owner_id='%d'", GetPlayerAccountID(playerid));
                result = mysql_query(mysql, query, true);
                new rows = cache_num_rows();

                if(!rows)
                {
                cache_delete(result);
                return SendClientMessage(playerid, 0x999999FF, "У вас нет домов во владении");
                }

                string_dialog[0] = EOS;
                for(new i = 0; i < rows; i++)
                {
                biz_id = cache_get_field_content_int(i, "id");
                new entrance = cache_get_field_content_int(i, "entrance");

                if(entrance == -1)
                {
                if(biz_id == GetPlayerData(playerid, P_ID_SPAWN) && GetPlayerData(playerid, P_SPAWN) == 1)
                format(query, sizeof query, "{FFFFFF}-Дом: %d | (база)\n", biz_id);
                else
                format(query, sizeof query, "{FFFFFF}-Дом: %d\n", biz_id);
                }
                else
                {
                if(biz_id == GetPlayerData(playerid, P_ID_SPAWN) && GetPlayerData(playerid, P_SPAWN) == 1)
                format(query, sizeof query, "{FFFFFF}-Квартира: %d | (база)\n", biz_id);
                else
                format(query, sizeof query, "{FFFFFF}-Квартира: %d\n", biz_id);
                }

                strcat(string_dialog, query);
                SetPlayerListitemValue(playerid, i, biz_id - 1);
                }

                Dialog(playerid, DIALOG_SELL_MY_HOME_LIST, DIALOG_STYLE_LIST,
                "{FFCD00}Выберите дом для продажи",
                string_dialog,
                "Продать", "Отмена");

                cache_delete(result);
            }
			case DIALOG_PAY_FOR_RENT_HOUSE:
			{
				new houseid = GetPVarInt(playerid, "ownablehouse_id");
				if(response)
				{
					new days = strval(inputtext);
					if(days > 0 && IsNumeric(inputtext))
					{
						new fmt_str[128 + 1];

						new time = gettime();
						new rent_time = GetHouseData(houseid, H_RENT_DATE);

						new rent_days = GetElapsedTime(rent_time, time, CONVERT_TIME_TO_DAYS);
						new rent_price = GetHouseData(houseid, H_IMPROVEMENTS) < 3 ? GetHouseData(houseid, H_RENT_PRICE) : GetHouseData(houseid, H_RENT_PRICE) / 2;

						new total_price = rent_price * days;
						if((rent_days + days) <= 30)
						{
							if(GetILPlayerInt(GetPlayerBankMoney(playerid), total_price))
							{
								rent_time = (rent_time - (rent_time % 86400)) + (days * 86400);

								format(fmt_str, sizeof fmt_str, "UPDATE accounts_1101 a,houses h SET a.bank=%s,h.rent_time=%d WHERE a.id=%d AND h.id=%d", SetILPlayerInt(playerid, GetPlayerBankMoney(playerid), -total_price), rent_time, GetPlayerAccountID(playerid), GetHouseData(houseid, H_SQL_ID));
								mysql_query(mysql, fmt_str, false);

								if(!mysql_errno())
								{
									format(g_player[playerid][P_BANK], 21, "%s", SetILPlayerInt(playerid, GetPlayerBankMoney(playerid), -total_price));
									SetHouseData(houseid, H_RENT_DATE, rent_time);

									format(fmt_str, sizeof fmt_str, "С банковского счета снято {3399FF}%d руб", total_price);
									SendClientMessage(playerid, 0xFFFFFFFF, fmt_str);

									format(fmt_str, sizeof fmt_str, "Вы успешно оплатили дом еще на {3399FF}%d дней", days);
									SendClientMessage(playerid, 0x66CC00FF, fmt_str);
								}
							}
							else
							{
								SendClientMessage(playerid, 0xB5B500FF, "На основном банковском счету не хватает денег для оплаты");

								format(fmt_str, sizeof fmt_str, "Для продления аренды на %d дней необходимо %d руб", days, total_price);
								SendClientMessage(playerid, 0x999999FF, fmt_str);
							}
						}
						else SendClientMessage(playerid, 0xB5B500FF, "Вы не можете оплатить за аренду больше чем на 14 дней");
					}
					ShowPlayerHousePayForRent(playerid);
				}
				else ShowPlayerPayForRentDialog(playerid);
			}
			case DIALOG_SPAWN_HOME_LIST:
			{
				new idx = GetPlayerListitemValue(playerid, listitem) + 1;
				SetPVarInt(playerid, "ownablehouse_id", idx);
				new houseid = GetPVarInt(playerid, "ownablehouse_id");

				SetPlayerData(playerid, P_ID_SPAWN, houseid);
				UpdatePlayerDatabaseInt(playerid, "id_spawn", houseid);

				SetPlayerData(playerid, P_SPAWN, 1);
				UpdatePlayerDatabaseInt(playerid, "setting_spawn", 1);
				SendClientMessage(playerid, 0x3399FFFF, "Место появления в игре изменено");
				SendPacket_1(playerid, s_CefInterface, t_CefHide, "SelectSpawn");
			}
			case DIALOG_SELL_MY_HOME_LIST:
			{
				new idx = GetPlayerListitemValue(playerid, listitem) + 1;
				SetPVarInt(playerid, "ownablehouse_id", idx);
				new houseid = GetPVarInt(playerid, "ownablehouse_id");

				if(GetPlayerLevel(playerid) < 2) return SendClientMessage(playerid, 0xCECECEFF, "Продавать дом можно только с {99ff00}2{CECECE} уровня");


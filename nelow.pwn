	format(STRING_GLOBAL, sizeof(STRING_GLOBAL), "Руководитель %s[%d] добавил игроку %s[%d] %d слотов под бизнес", GetPlayerNameEx(playerid), playerid, GetPlayerNameEx(to_player), to_player, slots);

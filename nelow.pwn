public: OpenVorotaDef(playerid)
{
    if(IsPlayerInRangeOfPoint(playerid, 3.5, 2331.62, -1778.24, 1005.77))//13и14
    {
    if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
    if(vorota_status == 0)
    {
        MoveDynamicObject(vorota_fsb13, 2331.62, -1778.24, 1005.77, 0.4, 0.00, 0.00, 90);
        MoveDynamicObject(vorota_fsb14, 2329.35, -1778.24, 1005.77, 0.4, 0.00, 0.00, 90);
        vorota_status = 1;
    }
    else
    {
        MoveDynamicObject(vorota_fsb13, 2331.62, -1778.24, 1005.77, 0.4, 0.00, 0.00, 0);
        MoveDynamicObject(vorota_fsb14, 2329.35, -1778.24, 1005.77, 0.4, 0.00, 0.00, 180);
        vorota_status = 0;
        }
    }
    if(IsPlayerInRangeOfPoint(playerid, 3.5, 2339.72, -1778.19, 1005.75))//15и16
    {
    if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
    if(vorota_status == 0)
    {
        MoveDynamicObject(vorota_fsb15, 2339.72, -1778.19, 1005.75, 0.4, 0.00, 0.00, 90);
        MoveDynamicObject(vorota_fsb16, 2337.44, -1778.18, 1005.75, 0.4, 0.00, 0.00, 90);
        vorota_status = 1;
    }
    else
    {
        MoveDynamicObject(vorota_fsb15, 2339.72, -1778.19, 1005.75, 0.4, 0.00, 0.00, 0);
        MoveDynamicObject(vorota_fsb16, 2337.44, -1778.18, 1005.75, 0.4, 0.00, 0.00, 180);
        vorota_status = 0;
        }
    }
    if(IsPlayerInRangeOfPoint(playerid, 3.5, 2323.52, -1778.17, 1005.84))//17и18
    {
    if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
    if(vorota_status == 0)
    {
        MoveDynamicObject(vorota_fsb17, 2323.52, -1778.17, 1005.84, 0.4, 0.00, 0.00, 90);
        MoveDynamicObject(vorota_fsb18, 2321.23, -1778.2,  1005.84, 0.4, 0.00, 0.00, 90);
        vorota_status = 1;
    }
    else
    {
        MoveDynamicObject(vorota_fsb17, 2323.52, -1778.17, 1005.84, 0.4, 0.00, 0.00, 0);
        MoveDynamicObject(vorota_fsb18, 2321.23, -1778.2, 1005.84, 0.4, 0.00, 0.00, 180);
        vorota_status = 0;
        }
    }
    if(IsPlayerInRangeOfPoint(playerid, 3.5, 2331.6, -1771.18, 1005.85))//19и20
    {
    if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
    if(vorota_status == 0)
    {
        MoveDynamicObject(vorota_fsb19, 2331.6, -1771.18, 1005.85, 0.4, 0.00, 0.00, 90);
        MoveDynamicObject(vorota_fsb20, 2329.34, -1771.2, 1005.85, 0.4, 0.00, 0.00, 90);
        vorota_status = 1;
    }
    else
    {
        MoveDynamicObject(vorota_fsb19, 2331.6, -1771.18, 1005.85, 0.4, 0.00, 0.00, 0);
        MoveDynamicObject(vorota_fsb20, 2329.34, -1771.2, 1005.85, 0.4, 0.00, 0.00, 180);
        vorota_status = 0;
        }
    }
    if(IsPlayerInRangeOfPoint(playerid, 2.5, 1208.6, 3407.24, 10.7427)) // luk 1
    {
        ClearAnimations(playerid);

        if(luk1_status == 0)
        {
            MoveDynamicObject(luk1, 1207.42, 3407.29, 10.6717, 0.4, 0, 0, 0);
            GameText(playerid, "~g~Люк открыт", 1000, 1);
            luk1_status = 1;
        }
        else
        {
            MoveDynamicObject(luk1, 1208.6, 3407.24, 10.7427, 0.4, 0, 0, 0);
            GameText(playerid, "~r~Люк закрыт", 1000, 1);
            luk1_status = 0;
        }
	}
    if(IsPlayerInRangeOfPoint(playerid, 3.5, 2300.14, -1809.5, 21.0913))
    {
        if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
        if(vorota_status == 0) return MoveDynamicObject(vorota_fsb1,2300.14,-1809.5, 21.0913,0.4, 0.00, 0.00, 90), vorota_status = 1;
        else return MoveDynamicObject(vorota_fsb1,2300.14,-1809.5, 21.0913,0.4, 0.00, 0.00, 0), vorota_status = 0;
    }
    if(IsPlayerInRangeOfPoint(playerid, 3.5, 2300.13, -1736.76,21.1919))
    {
        if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
        if(vorota_status == 0) return MoveDynamicObject(vorota_fsb2,2300.13, -1736.76,21.1919,0.4, 0.00, 0.00, 90), vorota_status = 1;
        else return MoveDynamicObject(vorota_fsb2,2300.13, -1736.76,21.1919,0.4, 0.00, 0.00, 0), vorota_status = 0;
    }
    if(IsPlayerInRangeOfPoint(playerid, 5.5, 2300.1111,-1796.7634,21.9730))
    {
    if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
    if(vorota_status == 0)
    {
        MoveDynamicObject(vorota_fsb3,2300.16, -1801.69, 21.1928,0.4, 0.00, 0.00, 90); 
        MoveDynamicObject(vorota_fsb4,2300.14, -1792.49, 21.1928,0.4, 0.00, 0.00, 90); 
        vorota_status = 1;
    }
    else
    {
        MoveDynamicObject(vorota_fsb3,2300.16, -1801.69, 21.1928,0.4, 0.00, 0.00, 0); 
        MoveDynamicObject(vorota_fsb4,2300.14, -1792.49, 21.1928,0.4, 0.00, 0.00, 180);
        vorota_status = 0;
       }
    }
    if(IsPlayerInRangeOfPoint(playerid, 3.5, 2332.13, -1745.99, 1005.81))
    {
    if(GetPlayerTeamEx(playerid) != TEAM_FSB) return SendClientMessage(playerid, -1, "Вы не сотрудник ФСБ");
    if(vorota_status == 0)
    {
        MoveDynamicObject(vorota_fsb5, 2332.13, -1745.99, 1005.81, 0.4, 0.00, 0.00, 90); 
        MoveDynamicObject(vorota_fsb6, 2328.83, -1745.99, 1005.81, 0.4, 0.00, 0.00, 90);
        vorota_status = 1;
    }
    else
    {
        MoveDynamicObject(vorota_fsb5, 2332.13, -1745.99, 1005.81, 0.4, 0.00, 0.00, 0); 
        MoveDynamicObject(vorota_fsb6, 2328.83, -1745.99, 1005.81, 0.4, 0.00, 0.00, 180);
        vorota_status = 0;
        }
    }
    if(IsPlayerInRangeOfPoint(playerid, 3.5,  2327.18, -1751.93, 1005.79))

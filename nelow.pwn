stock UpdateMoneyDonate(playerid)
{
	format(STRING_GLOBAL, sizeof STRING_GLOBAL, "window.setPlayerNickName('%s') || \
	    window.setPlayerLevel('%d') || \
	    window.setPlayerMoney('%s') || \
		window.setPlayerPassedHours('%d') || \
	    window.setPlayerBankMoney('%d') || \
	    window.setPlayerDonate('%d') || \
	    window.setGameVersion('7.4') || \
	    window.setPlayerSkinId('%d')", \
		GetPlayerNameEx(playerid), GetPlayerLevel(playerid), GetPlayerMoneyEx(playerid), \
		ConvertUnixTime(GetPlayerData(playerid, P_GAME_FOR_DAY), CONVERT_TIME_TO_HOURS), \
		GetPlayerData(playerid, P_BANK), GetPlayerCurrentDonate(playerid), GetPlayerSkin(playerid));
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, STRING_GLOBAL);
}

stock GetPlayerCountHouses(playerid)
{
	new count = 0;

	for(new i; i < g_house_loaded; i++)
	{
		if(GetHouseData(i, H_OWNER_ID) == GetPlayerAccountID(playerid))
		{
			count++;
		}
	}
	return count;
}

				SetOwnableCarData(idx, OC_STAGE1, 1);
				SetOwnableCarData(idx, OC_ENGINE_ACCELERATION, GetOwnableCarData(idx, OC_ENGINE_ACCELERATION) + 10.0);
				SetOwnableCarData(idx, OC_MAX_VELOCITY, GetOwnableCarData(idx, OC_MAX_VELOCITY) + 20.0);
				GivePlayerMoneyEx(playerid, -3000000, "Stage", true, true);

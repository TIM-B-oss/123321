};

stock GetBoughtTickets(slot_id, owner_id)
{
    new query[256];
    mysql_format(mysql, query, sizeof(query), "SELECT COUNT(*) AS ticket_count FROM raffle_shop WHERE slot_id=%d AND owner_id=%d", slot_id, owner_id);
    new Cache: result = mysql_query(mysql, query, true);
    if(!result) return 0;
    new tickets = cache_get_field_content_int(0, "ticket_count");
    cache_delete(result);
    return tickets;
}

stock FormatTicketsCount(count, buffer[], maxlen)
{
    format(buffer, maxlen, "%d {FFFFFF}%s", count, ((count % 100) >= 11 && (count % 100) <= 14) ? "билетов" : ((count % 10) == 1) ? "билет" : ((count % 10) >= 2 && (count % 10) <= 4) ? "билета" : "билетов");
}

stock GetCarPriceByModel(modelid)
{
    for(new k = 0; k < sizeof(g_info_raffleshopping); k++)
    {
        if(g_info_raffleshopping[k][IRS_CAR_ID] == modelid)
        {
            return g_info_raffleshopping[k][IRS_PRICE];
        }
    }
    return 24000;
}
stock LoadRaffleFromDB()
{
    new query[256], Cache: result;

    for(new i = 0; i < MAX_RAFFLESHOP; i++)
    {
        g_raffleShop[i][RS_ID] = 400;
        g_raffleShop[i][RS_TIME] = 0;
        g_raffleShop[i][RS_STATUS] = 0;
        g_raffleShop[i][RS_VEHICLE] = INVALID_VEHICLE_ID;
    }

    mysql_format(mysql, query, sizeof(query), "SELECT * FROM raffle_slots");
    result = mysql_query(mysql, query, true);

    new rows = cache_num_rows();

    if(rows > 0)
    {
        for(new i = 0; i < rows && i < MAX_RAFFLESHOP; i++)
        {
            new slot_id = cache_get_field_content_int(i, "id");
            if(slot_id >= 0 && slot_id < MAX_RAFFLESHOP)
            {
                new db_model = cache_get_field_content_int(i, "car_model");
                new db_time = cache_get_field_content_int(i, "end_time");
                new db_status = cache_get_field_content_int(i, "status");

                g_raffleShop[slot_id][RS_ID] = db_model;
                g_raffleShop[slot_id][RS_TIME] = db_time;

                if(db_status == 1 && db_time > gettime())
                {
                    g_raffleShop[slot_id][RS_STATUS] = 1;
                }
                else
                {
                    g_raffleShop[slot_id][RS_STATUS] = 0;
                }

                g_raffleShop[slot_id][RS_VEHICLE] = INVALID_VEHICLE_ID;
            }
        }
    }
    cache_delete(result);
}
stock SetupRaffleSlot(slot, hours = 0, minutes = 0, car_modelid = -1)
{
    if(slot < 0 || slot >= MAX_RAFFLESHOP) return false;

    if(g_raffleShop[slot][RS_VEHICLE] != INVALID_VEHICLE_ID)
    {
        DestroyVehicle(g_raffleShop[slot][RS_VEHICLE]);
        g_raffleShop[slot][RS_VEHICLE] = INVALID_VEHICLE_ID;
    }

    new clear_query[128];
    mysql_format(mysql, clear_query, sizeof(clear_query), "DELETE FROM raffle_shop WHERE slot_id=%d", slot);
    mysql_query(mysql, clear_query, false);

    if(car_modelid == -1 ||
       !((car_modelid >= 400 && car_modelid <= 614) ||
       (car_modelid >= 699 && car_modelid <= 699) ||
       (car_modelid >= 793 && car_modelid <= 799) ||
       (car_modelid >= 907 && car_modelid <= 909) ||
       (car_modelid >= 965 && car_modelid <= 965) ||
       (car_modelid >= 999 && car_modelid <= 999) ||
       (car_modelid >= 1326 && car_modelid <= 1326) ||
       (car_modelid >= 15065 && car_modelid <= 15299) ||
       (car_modelid >= 15600 && car_modelid <= 15699) ||
       (car_modelid == 16782) ||
       (car_modelid >= 17400 && car_modelid <= 17448)))
    {
        new rand_idx = random(sizeof(g_info_raffleshopping));
        car_modelid = g_info_raffleshopping[rand_idx][IRS_CAR_ID];
    }

    new total_seconds = (hours * 3600) + (minutes * 60);
    new end_time = gettime() + total_seconds;

    g_raffleShop[slot][RS_ID] = car_modelid;
    g_raffleShop[slot][RS_TIME] = end_time;
    g_raffleShop[slot][RS_STATUS] = 1;
    g_raffleShop[slot][RS_TICKETS] = 0;

    new veh_id = CreateVehicle(
        car_modelid,
        g_pos_car_raffle[slot][0],
        g_pos_car_raffle[slot][1],
        g_pos_car_raffle[slot][2],
        g_pos_car_raffle[slot][3],
        -1, -1, -1, 0,
        VEHICLE_ACTION_TYPE_RAFFLE_SHOP,
        slot
    );

    if(veh_id != INVALID_VEHICLE_ID)
    {
        g_raffleShop[slot][RS_VEHICLE] = veh_id;
        SetVehicleVirtualWorld(veh_id, 9);
        LinkVehicleToInterior(veh_id, 9);
    }

    new query[256];
    mysql_format(mysql, query, sizeof(query),
        "REPLACE INTO raffle_slots (id, car_model, end_time, status) VALUES (%d, %d, %d, 1)",
        slot, car_modelid, end_time);
    mysql_query(mysql, query, true);

    return true;
}
stock CreateRaffleShopping()
{
    for(new i; i < sizeof g_raffleShop; i++)
    {
        if(g_raffleShop[i][RS_STATUS] != 1 || g_raffleShop[i][RS_TIME] <= gettime())
        {
            SetupRaffleSlot(i, DEFAULT_RAFFLE_HOURS, 0, -1);
        }
        else
        {
            if(g_raffleShop[i][RS_VEHICLE] == INVALID_VEHICLE_ID || !IsValidVehicle(g_raffleShop[i][RS_VEHICLE]))
            {

                new veh_id = CreateVehicle(
                    g_raffleShop[i][RS_ID],
                    g_pos_car_raffle[i][0],
                    g_pos_car_raffle[i][1],
                    g_pos_car_raffle[i][2],
                    g_pos_car_raffle[i][3],
                    -1, -1, -1, 0,
                    VEHICLE_ACTION_TYPE_RAFFLE_SHOP,
                    i
                );

                if(veh_id != INVALID_VEHICLE_ID)
                {
                    g_raffleShop[i][RS_VEHICLE] = veh_id;
                    SetVehicleVirtualWorld(veh_id, 9);
                    LinkVehicleToInterior(veh_id, 9);
                }
            }
        }
    }
}

forward timeRaffleShopping();
public timeRaffleShopping()
{
    for(new i; i < sizeof g_raffleShop; i++)
    {
        if(g_raffleShop[i][RS_STATUS] != 1) continue;

        if(g_raffleShop[i][RS_TIME] <= gettime())
        {
            new fmt_text[256], Cache: result, prize_name[128];
            new winner_account_id = -1;
            new winning_model_id = g_raffleShop[i][RS_ID];

            mysql_format(mysql, fmt_text, sizeof fmt_text, "SELECT owner_id FROM raffle_shop WHERE slot_id=%d", i);
            result = mysql_query(mysql, fmt_text, true);
            new rows = cache_num_rows();

            if(rows > 0)
            {
                new random_row = random(rows);
                winner_account_id = cache_get_field_content_int(random_row, "owner_id");

                format(prize_name, sizeof prize_name, "%s [№%d]", GetVehicleInfo(winning_model_id, VI_NAME), winning_model_id);

                mysql_format(mysql, fmt_text, sizeof fmt_text,
                    "INSERT INTO prizes (owner_id, name, size, item, type, count, indx) VALUES (%d, '%s', %d, %d, %d, %d, %d)",
                    winner_account_id, prize_name, 3, winning_model_id, 0, 1, -1);
                mysql_tquery(mysql, fmt_text, "", "");

                mysql_format(mysql, fmt_text, sizeof fmt_text,
                    "INSERT INTO notification (owner_id, text, note_text, time, status) VALUES (%d, '%s', '%s', NOW(), 1)",
                    winner_account_id, "Розыгрыш", "Вы победили в розыгрыше в ТЦ. Забрать транспорт можно в Мои Награды");
                mysql_query(mysql, fmt_text, false);
            }
            cache_delete(result);

            mysql_format(mysql, fmt_text, sizeof fmt_text, "DELETE FROM raffle_shop WHERE slot_id=%d", i);
            mysql_query(mysql, fmt_text, false);

            mysql_format(mysql, fmt_text, sizeof fmt_text, "UPDATE raffle_slots SET status=0 WHERE id=%d", i);
            mysql_query(mysql, fmt_text, false);

            g_raffleShop[i][RS_TIME] = 0;
            g_raffleShop[i][RS_ID] = -1;
            g_raffleShop[i][RS_STATUS] = 0;

            if(g_raffleShop[i][RS_VEHICLE] != INVALID_VEHICLE_ID)
            {
                DestroyVehicle(g_raffleShop[i][RS_VEHICLE]);
                g_raffleShop[i][RS_VEHICLE] = INVALID_VEHICLE_ID;
            }

            CreateRaffleShopping();
        }
        else
        {
            new Float: x, Float: y, Float: z;
            if(GetVehiclePos(g_raffleShop[i][RS_VEHICLE], x, y, z))
            {
                if(floatabs(x - g_pos_car_raffle[i][0]) > 1.0 || floatabs(y - g_pos_car_raffle[i][1]) > 1.0)
                {
                    SetVehiclePos(g_raffleShop[i][RS_VEHICLE], g_pos_car_raffle[i][0], g_pos_car_raffle[i][1], g_pos_car_raffle[i][2] + 0.1);
                    SetVehicleZAngle(g_raffleShop[i][RS_VEHICLE], g_pos_car_raffle[i][3]);
                    SetVehicleVirtualWorld(g_raffleShop[i][RS_VEHICLE], 9);
                    LinkVehicleToInterior(g_raffleShop[i][RS_VEHICLE], 9);
                }
            }
        }
    }
    return 1;
}

stock FinalizeRaffle(slot)
{
    if(slot < 0 || slot >= MAX_RAFFLESHOP) return false;
    if(g_raffleShop[slot][RS_STATUS] != 1) return false;

    new fmt_text[256], Cache: result, prize_name[128];
    new winner_account_id = -1;
    new winning_model_id = g_raffleShop[slot][RS_ID];

    mysql_format(mysql, fmt_text, sizeof fmt_text, "SELECT owner_id FROM raffle_shop WHERE slot_id=%d", slot);
    result = mysql_query(mysql, fmt_text, true);
    new rows = cache_num_rows();

    if(rows > 0)
    {
        new random_row = random(rows);
        winner_account_id = cache_get_field_content_int(random_row, "owner_id");

        format(prize_name, sizeof prize_name, "%s [№%d]", GetVehicleInfo(winning_model_id, VI_NAME), winning_model_id);

        mysql_format(mysql, fmt_text, sizeof fmt_text,
            "INSERT INTO prizes (owner_id, name, size, item, type, count, indx) VALUES (%d, '%s', %d, %d, %d, %d, %d)",
            winner_account_id, prize_name, 3, winning_model_id, 0, 1, -1);
        mysql_tquery(mysql, fmt_text, "", "");

        mysql_format(mysql, fmt_text, sizeof fmt_text,
            "INSERT INTO notification (owner_id, text, note_text, time, status) VALUES (%d, '%s', '%s', NOW(), 1)",
            winner_account_id, "Розыгрыш", "Вы победили в розыгрыше в ТЦ. Забрать транспорт можно в Мои Награды");
        mysql_query(mysql, fmt_text, false);
    }
    cache_delete(result);

    mysql_format(mysql, fmt_text, sizeof fmt_text, "DELETE FROM raffle_shop WHERE slot_id=%d", slot);
    mysql_query(mysql, fmt_text, false);

    mysql_format(mysql, fmt_text, sizeof fmt_text, "UPDATE raffle_slots SET status=0 WHERE id=%d", slot);
    mysql_query(mysql, fmt_text, false);

    g_raffleShop[slot][RS_TIME] = 0;
    g_raffleShop[slot][RS_ID] = -1;
    g_raffleShop[slot][RS_STATUS] = 0;

    if(g_raffleShop[slot][RS_VEHICLE] != INVALID_VEHICLE_ID)
    {
        DestroyVehicle(g_raffleShop[slot][RS_VEHICLE]);
        g_raffleShop[slot][RS_VEHICLE] = INVALID_VEHICLE_ID;
    }

    CreateRaffleShopping();
    return true;
}
CMD:createraffle(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 7) return 1;
    if(admin_logged[playerid] == false) return SCM(playerid, 0x999999FF, "Авторизуйтесь (/alogin)");

    new slot, hours = 0, minutes, car_modelid;
    if(sscanf(params, "iiii", slot, hours, minutes, car_modelid))
    {
        SCM(playerid, COLOR_WHITE, "Использование: /createraffle [slot] [часы] [минуты] [ID авто]");
        return 1;
    }

    if(slot < 0 || slot >= MAX_RAFFLESHOP) return SCM(playerid, COLOR_RED, "Неверный слот.");
    if(hours < 0 || hours > 720) return SCM(playerid, COLOR_RED, "Неверные часы.");
    if(minutes < 0 || minutes > 59) return SCM(playerid, COLOR_RED, "Неверные минуты.");
    if(hours == 0 && minutes == 0) return SCM(playerid, COLOR_RED, "Время > 0.");

    if(car_modelid == -1 ||!((car_modelid >= 400 && car_modelid <= 614) ||(car_modelid >= 699 && car_modelid <= 699) ||(car_modelid >= 793 && car_modelid <= 799) ||(car_modelid >= 907 && car_modelid <= 909) ||(car_modelid >= 965 && car_modelid <= 965) ||(car_modelid >= 999 && car_modelid <= 999) ||(car_modelid >= 1326 && car_modelid <= 1326) ||(car_modelid >= 15065 && car_modelid <= 15299) ||(car_modelid >= 15600 && car_modelid <= 15699) ||(car_modelid == 16782) ||(car_modelid >= 17400 && car_modelid <= 17448)))
    {
      return SCM(playerid, 0xCECECEFF, "Вы указали неверный id авто. Доступные авто: 400-614, 699, 793-799, 907-909, 965, 999, 1326, 15065-15299, 15600-15699, 17400-17448");
    }
    if(SetupRaffleSlot(slot, hours, minutes, car_modelid))
    {
        SCM(playerid, COLOR_GREEN, "Розыгрыш создан успешно!");
    }
    else
    {
        SCM(playerid, COLOR_RED, "Ошибка создания.");
    }
    return 1;
}
CMD:finishraffle(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 7) return 1;
    if(admin_logged[playerid] == false) return SCM(playerid, 0x999999FF, "Авторизуйтесь (/alogin)");

    new slot;
    if(sscanf(params, "i", slot))
    {
        SCM(playerid, COLOR_WHITE, "Использование: /finishraffle [slot]");
        return 1;
    }

    if(slot < 0 || slot >= MAX_RAFFLESHOP) return SCM(playerid, COLOR_RED, "Неверный слот.");
    if(g_raffleShop[slot][RS_STATUS] != 1) return SCM(playerid, COLOR_RED, "Розыгрыш не активен.");

    FinalizeRaffle(slot);
    SCM(playerid, COLOR_GREEN, "Розыгрыш завершён!");
    return 1;
}

stock openRaffleShop(playerid)
{
    for(new i; i < sizeof g_raffleShop; i++)
    {
        if(!IsPlayerInRangeOfPoint(playerid, 4.5, g_pos_car_raffle[i][0], g_pos_car_raffle[i][1], g_pos_car_raffle[i][2]))
            continue;

        string_dialog[0] = EOS;

        new raffle_time = g_raffleShop[i][RS_TIME] - gettime();
        if(raffle_time < 0) raffle_time = 0;

        new hours = raffle_time / 3600;
        new minutes = (raffle_time % 3600) / 60;

        new tickets = GetBoughtTickets(i, GetPlayerAccountID(playerid));
        new ticket_str[32];
        FormatTicketsCount(tickets, ticket_str, sizeof ticket_str);

        new car_model = g_raffleShop[i][RS_ID];
        new price = GetCarPriceByModel(car_model);

        format
        (
            string_dialog, sizeof string_dialog,
            "{FFFFFF}На данный момент розыгрывается {fdc53c}%s\n\
            {FFFFFF}В конце розыгрыша один из участников случайным образом станет победителем и заберёт автомобиль.\n\n\
            {FFFFFF}До завершения осталось: {fdc53c}%d часов %d минут\n\
            {FFFFFF}Вы приобрели уже {fdc53c}%s участника розыгрыша\n\
            {FFFFFF}Вы готовы заплатить {fdc53c}%d руб. {FFFFFF}за участие?",
            GetVehicleInfo(car_model, VI_NAME),
            hours, minutes, ticket_str, price
        );
        Dialog(playerid, DIALOG_RAFFLE_SHOP, DIALOG_STYLE_MSGBOX, "{FFFFFF}Розыгрыш", string_dialog, "Да", "Нет");
        return true;
    }
    return false;
}

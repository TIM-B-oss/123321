			new fmt_td_text[300];
			format(fmt_td_text, sizeof(fmt_td_text), "interface('Machinist').speed.value = '0-2'");
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, fmt_td_text);
			return 1;
		}
		case RCP_ACTION_TYPE_METRO_TRAIN_3:
		{

					format(fmt_text, sizeof fmt_text, "%s %s[%d] Вы хотите уволится?",
					GetPlayerJob(playerid), GetPlayerJob(playerid), playerid);

					SendMessageToJob(GetPlayerJob(playerid), fmt_text, 0x3399FFFF, playerid);

					format(fmt_text, sizeof fmt_text, "Вы уволились с работы \"%s\"", (GetPlayerJob(playerid)));

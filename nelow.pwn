							else if(GetBusinessData(businessid, B_IZNOS) < 1000) format(nameee, sizeof(nameee), "{ffa420}Средний");
							else if(GetBusinessData(businessid, B_IZNOS) < 250) format(nameee, sizeof(nameee), "{CC3333}Высокий");

							format

				case 4: ApplyAnimation(playerid, "BEACH",			"ParkSit_M_loop",		4.0, true,  0, 0, 0, 0), SetPlayerData(playerid, P_USE_ANIM, true), SendPacket_2(playerid, s_CefInterface, t_CefShow, "Interactions", "[[1, \"Выключить анимацию\"]]");

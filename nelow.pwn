                  mysql_query(mysql, query, false);
                }
                  SetGarageData(i, G_OWNER_ID, 0);
                  format(query, sizeof query, "UPDATE garage SET owner_id=0 WHERE id=%d", GetGarageData(i, G_SQL_ID));
                  mysql_query(mysql, query, false);
                  CallLocalFunction("UpdateGarageLabel", "i", i);

            {
                SCM(playerid, 0xFF6600FF, "Вы не указали сумму или ввели её неверно");

                ShowPlayerConvertDonateDialog(playerid);

                return 1;
            }
            if(strlen(inputtext) > 4) return SCM(playerid,-1,"Максимум 4 символа");
            if(money_amount > 1000)
            {
                SCM(playerid, 0xFF6600FF, "Можно сконвертировать не больше чем 1.000 RUB за раз");
                ShowPlayerConvertDonateDialog(playerid);
                return 1;

							if(GetRentCarData(index, R_RENT_BIZ) == biz_id)
						    {
								if(GetRentCarData(index, R_MESTO) == 4 || GetRentCarData(index, R_MESTO) == 5 || GetRentCarData(index, R_MESTO) == 6 || GetRentCarData(index, R_MESTO) == 7)

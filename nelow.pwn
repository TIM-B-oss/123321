forward OnRegistrationCharacter(playerid, eventid, row, skin);
forward OnRegistrationBonuses(playerid, name[]);
forward OnAuthorizationStart(playerid, password[]);
public EndedInitializeBrowser(playerid)
{
    SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "confirmBrowserInitialize()");
	return 1;
}
public OnRegistrationBonuses(playerid, name[])
{
    if(GetPlayerData(playerid, P_DAILY_CLAIM) != 1 && GetPlayerData(playerid, P_DAILY_CLAIM_COMPLETE) != 4)
	{
        DailyreWards_Time[playerid] = 7200;
	}
	else
	{
		DailyreWards_Time[playerid] = -1;
	}
	if(g_player_auth_inputs[playerid] == 1) return 1;

	if(g_player_account_state[playerid] != 2)
	{
		return printf("%s", GetPlayerNameEx(playerid));
	}
	new str_money[1060];
	new query[540];
	new Cache: result;


	format(g_player[playerid][P_REFER], 21, "%s", name);
	format(g_player[playerid][P_MONEY], 21, ""BONUS_MONEY"");
	format(g_player[playerid][P_DONATE_CURRENT], 21, ""BONUS_DONATE"");
	format(g_player[playerid][P_LEVEL], 21, ""BONUS_LVL"");
	format(g_player[playerid][P_BANK], 21, "0");
	SetPlayerData(playerid, P_SKIN, _player_skin[playerid]);

	mysql_format
	(
		mysql, query, sizeof query,
		"INSERT INTO accounts_1101 "\
			"(name,players_password,email,refer,sex,reg_time,reg_ip,last_ip,last_login,skin,serialid,money,bank) "\
			"VALUES "\
			"('%e','%e','%e','%s',%d,%d,'%e','%e','%d', %d, '%e','%e','%e')",
		GetPlayerNameEx(playerid),
		GetPlayerData(playerid, P_PASSWORD),
		GetPlayerData(playerid, P_EMAIL),
		GetPlayerData(playerid, P_REFER),
		_player_skin_sex{playerid},
		GetPlayerData(playerid, P_REG_TIME),
		GetPlayerData(playerid, P_REG_IP),
		GetPlayerData(playerid, P_LAST_IP),
		GetPlayerData(playerid, P_LAST_LOGIN_TIME),
		GetPlayerData(playerid, P_SKIN),
		GetPlayerData(playerid, P_HARDWARE_ID_TEMP),
		GetPlayerData(playerid, P_MONEY),
		GetPlayerData(playerid, P_BANK)
	);
	result = mysql_query(mysql, query);

	SetPlayerData(playerid, P_ACCOUNT_ID, cache_insert_id());
	cache_delete(result);

	if(DailyreWards_Time[playerid] == 0) DailyreWards_Time[playerid] = 7200;

	if(g_battlepass_time_bonus[playerid] == 0) g_battlepass_time_bonus[playerid] = 7200;

	GiveSkin(playerid, GetPlayerData(playerid, P_SKIN));

	TogglePlayerSpectating(playerid, false);
	SetPlayerData(playerid, P_SELECT_SKIN, -1);
	SetPlayerData(playerid, P_PREMIUM, 0);
	
	SetPlayerData(playerid, P_LEVEL, 3);
	UpdatePlayerDatabaseInt(playerid, "level", GetPlayerData(playerid, P_LEVEL));
	
	AddPlayerData(playerid, P_CAR_SLOTS, +, 2);
	UpdatePlayerDatabaseInt(playerid, "car_slots", GetPlayerData(playerid, P_CAR_SLOTS));

	SetPlayerData(playerid, P_DRIVING_LIC, 1);
	UpdatePlayerDatabaseInt(playerid, "driving_lic", GetPlayerData(playerid, P_DRIVING_LIC));
	SetPlayerData(playerid, P_GARAGE_SLOTS, 1);
	UpdatePlayerDatabaseInt(playerid, "garage_slots", GetPlayerData(playerid, P_GARAGE_SLOTS));
	SetPlayerData(playerid, P_BIZ_SLOTS, 1);
	UpdatePlayerDatabaseInt(playerid, "biz_slots", GetPlayerData(playerid, P_BIZ_SLOTS));
	SetPlayerData(playerid, P_AUCTION_SLOTS, 1);
	UpdatePlayerDatabaseInt(playerid, "auction_slots", GetPlayerData(playerid, P_AUCTION_SLOTS));
	SetPlayerData(playerid, P_HOUSE_SLOTS, 1);
	UpdatePlayerDatabaseInt(playerid, "house_slots", GetPlayerData(playerid, P_HOUSE_SLOTS));
	SetPlayerData(playerid, P_KIOSK_SLOTS, 1);
	UpdatePlayerDatabaseInt(playerid, "kiosk_slots", GetPlayerData(playerid, P_KIOSK_SLOTS));
	SetPlayerData(playerid, P_GARDEN_SLOTS, 1);
	UpdatePlayerDatabaseInt(playerid, "garden_slots", GetPlayerData(playerid, P_GARDEN_SLOTS));

	SetPlayerSkin(playerid, _player_skin[playerid]);
	SetPlayerSpawnInit(playerid);
	SpawnPlayer(playerid);
	
	MainMenuUpdate(playerid);

	RemovePlayerAttachedObject(playerid, A_OBJECT_SLOT_FOREARM);
	SetPlayerInit(playerid);
	SetPlayerInterior(playerid, 0);
	SetPlayerVirtualWorld(playerid, 0);
	SetCameraBehindPlayer(playerid);
	
	SendPacket_2(playerid, s_CefInterface, t_CefShow, "Overlay", "[1000, 2500]");
	SendPacket_1(playerid, s_CefInterface, t_CefHide, "Authorization");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "stopSound()");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "client.setChatStatus(true)");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "showInterface('Hud')");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "client.setHudStatus(true)");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Hud')");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Hud').updateHungerLevel(100)");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Hud').setServer(1)");
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Hud').setShowControls(1)");
		
	format(str_money, sizeof str_money, "window.interface('Hud').info.money = %s", GetPlayerMoneyEx(playerid));
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, str_money);
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "window.setPlayerConnectedStatus(1)");

	format(query, sizeof query, "interface('Hud').setBonus(%d)", g_doubling[1]);
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, query);
	

	format(query, sizeof query, "window.interface('Hud').info.money = window.interface('Hud').moneyFormat(%s)", GetPlayerMoneyEx(playerid));
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, query);

	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "window.stopSound()");
	SetFullness(playerid, 75);
	SetPVarInt(playerid, "Login_1", 1);
	Dialog(playerid, -1, DIALOG_STYLE_MSGBOX,"{"#cW"}Подсказка","{"#cW"}Неподалеку от Вас находится {ff9980}квестовый персонаж\n{"#cW"}у которого Вы можете получить специальные\n{"#cW"}{ff9980}обучающие задания{FFFFFF}.\n\n{"#cW"}Квесты не только познакомят Вас с сервером но и\n{"#cW"}наделят игровыми ценностями, для старта.","Понял", "");
	DestroyPlayerObject(playerid, ObjectTrain[playerid]);
	status_authorization[playerid] = 1;
	g_player_auth_inputs[playerid] = 1;
	SetPlayerWeather(playerid, 0);

	OnBattlePass_TimeTasks(playerid);
	SetPVarInt(playerid, "Login", 1);
	
	return 1;
}

public OnRegistrationCharacter(playerid, eventid, row, skin)
{
	if(eventid == 0)
	{
		if(row == 0){
			_player_skin_sex{playerid} = false;
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Authorization').setSkins('[78,135,137,212,213,230,15327,15353,15354,15355,15524,15525]');");
			new const skins[12] = {78,135,137,212,213,230,15327,15353,15354,15355,15524,15525};
			_player_skin[playerid] = skins[skin];
		}
		if(row == 1){
			_player_skin_sex{playerid} = true;
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Authorization').setSkins('[89,15345,15352,88,39,38,75,15522]');");
			new const skins[8 + 1] = {89,15345,15352,88,39,38,75,15522};
			_player_skin[playerid] = skins[skin];
		}
		SetPlayerData(playerid, P_SEX, _player_skin_sex{playerid});
		SetPlayerSkin(playerid, _player_skin[playerid]);
	}
	if(eventid == 1) SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Authorization').setRegistrationStage(3)");
	
	return true;
}

public OnRegistrationData(playerid, email[], password_first[], password_second[])
{
	if(g_player_account_state[playerid] != 2) return 1;

	if(GetPlayerSqlIDByName(GetPlayerNameEx(playerid)) != -1) return 1;

	SetPlayerData(playerid, P_REG_TIME, gettime());
	SetPlayerData(playerid, P_LAST_LOGIN_TIME, gettime());
	format(g_player[playerid][P_REG_IP], 16, "%s", GetPlayerIpEx(playerid));
	format(g_player[playerid][P_LAST_IP], 16, "%s", GetPlayerIpEx(playerid));
	format(g_player[playerid][P_PASSWORD], 85, "%s", password_first);
	format(g_player[playerid][P_EMAIL], 61, "%s", email);
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Authorization').setRegistrationStage(2)");
	return GetPlayerAccountID(playerid);
}
public OnAuthorizationStart(playerid, password[])
{
    if(strlen(GetPlayerData(playerid, P_PASSWORD)) < 1) return 1;

    if(strfind(password,"~") != -1 || strfind(password,"%") != -1)
    {
        return SendClientMessage(playerid, 0xFF6600FF, "В сообщение присутствуют запрещеные символы");
    }
    if(strlen(password) < 1)
    {
        SendPacket_1(playerid, s_CefInterface, t_CefUpdate,"interface(\"Authorization\").$refs.auth.setError(\"password\", \"Вы не ввели пароль\")");
        return 1;
    }

    new login_step = GetPlayerData(playerid, P_ACCOUNT_STEP_STATE);
    new bool: wrong_password = false;
    new str_len = strlen(password);

    if(1 <= str_len <= 32)
    {
        if(strcmp(password, GetPlayerData(playerid, P_PASSWORD), false))
        {
            wrong_password = true;
            login_step--;
            ShowPlayerLoginDialog(playerid, login_step + 1, wrong_password);
            SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Authorization').$refs.auth.setError(\"password\", \"Неправильный пароль\")");
        }
        else
        {
            SetPVarInt(playerid, "Login_1", 1);
            GetPlayerPassword(playerid, password);
            status_authorization[playerid] = 1;
            SendPacket_2(playerid, s_CefInterface, t_CefShow, "Loading", "[3000]");
            SetTimerEx("OnPlayerLoading", 3000, false, "i", playerid);
        }
    }
    else
    {
        wrong_password = true;
        login_step--;
        ShowPlayerLoginDialog(playerid, login_step + 1, wrong_password);
        SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('Authorization').$refs.auth.setError(\"password\", \"Некорректная длинна пароля\")");
    }
    return 1;
}
stock GetPlayerPassword(playerid, password[])
{
	if(strcmp(password, GetPlayerData(playerid, P_PASSWORD), false))
	{
		printf("[DETECT] Сработала проверка GetPlayerPassword (nick: %s)", GetPlayerNameEx(playerid));
		Kick(playerid);
	}
}
public: OnPlayerLoading(playerid)
{
    new query[512];
	format(query, sizeof query, "UPDATE accounts_1101 SET serialid_temp = '%e' WHERE id=%d LIMIT 1", GetPlayerData(playerid, P_HARDWARE_ID_TEMP), GetPlayerAccountID(playerid));
	mysql_tquery(mysql, query);
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "window.stopSound()");
	if(GetPlayerData(playerid, P_LAST_EXIT) + 300 > gettime())
    {
        Dialog(playerid, DIALOG_SET_SPAWN, DIALOG_STYLE_MSGBOX,"{FFFFFF}Восстановление позиции","Хотите вернуться на место последнего выхода из игры?","Да", "Нет");
	}
	else CallLocalFunction("ShowPlayerLoginDialog", "iii", playerid, LOGIN_STATE_LOAD_ACC, false);

	return 1;
}
stock ClearRoadPlayerInfo(playerid)
{
    r_player[playerid][E_STATE] = STATE_NONE;
    r_player[playerid][E_SALARY] = 0;
    g_vehicle_road[r_player[playerid][E_VEH_ID]][E_VEHICLE_OWNER] = INVALID_PLAYER_ID;
    if(r_player[playerid][E_VEH_ID] != INVALID_VEHICLE_ID) r_player[playerid][E_VEH_ID] = INVALID_VEHICLE_ID;
    r_player[playerid][E_ROAD_ID] = -1;
}
stock OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{

    Fly_OnDialogResponse(playerid, dialogid, response, listitem, inputtext);
    Stoyanka_OnDialogResponse(playerid, dialogid, response, listitem);
    Proslyshka_OnDialogResponse(playerid, dialogid, response, inputtext);
    Sob_OnDialogResponse(playerid, dialogid, response, listitem, inputtext);
    Bonus_OnDialogResponse(playerid, dialogid, response, listitem, inputtext);
    HandleFSBMaskDialog(playerid, dialogid, response, listitem);
    FsbRespawn_OnDialogResponse(playerid, dialogid, response, listitem, inputtext);
    OnAdminShopDialogResponse(playerid, dialogid, response, listitem, inputtext);
    OnGompDialogResponse(playerid, dialogid, response, listitem, inputtext);
    Media_OnDialogResponse(playerid, dialogid, response, listitem, inputtext);
	ChangeItem_OnDialogResponse(playerid, dialogid, response, listitem, inputtext);
    Donate_OnDialogResponse(playerid, dialogid, response, listitem, inputtext);
    
    if(dialogid == DIALOG_AUTOFINKA_TYPE)
    {
    if(!response) return 1;

    new type = strval(inputtext);
    if(type == 0)
    {
        for(new i = 0; i < sizeof(gAutoFinkaAmount); i++)
            gAutoFinkaAmount[i] = 0;

        mysql_tquery(mysql, "DELETE FROM `autofinka`", "", "");
        SendClientMessage(playerid, 0x00FF00FF, "Автофинка удалена со всех типов и из базы данных.");
        return 1;
    }

    if(type < 1 || type >= sizeof(gAutoFinkaAmount))
    {
        SendClientMessage(playerid, 0xFF0000FF, "Неверный ID типа бизнеса!");
        return 1;
    }

    SetPVarInt(playerid, "AutofinkaType", type);
    Dialog(playerid, DIALOG_AUTOFINKA_AMOUNT, DIALOG_STYLE_INPUT,
        "Автофинка: сумма", "Введите сумму автофинки:", "Установить", "Отмена");
    }
    else if(dialogid == DIALOG_AUTOFINKA_AMOUNT)
    {
    if(!response) return 1;

    new amount = strval(inputtext);
    if(amount <= 0)
    {
        SendClientMessage(playerid, 0xFF0000FF, "Сумма должна быть больше 0!");
        return 1;
    }

    new type = GetPVarInt(playerid, "AutofinkaType");
    gAutoFinkaAmount[type] = amount;

    new query[256];
    mysql_format(mysql, query, sizeof(query), "INSERT INTO `autofinka` (`type`, `amount`) VALUES (%d, %d) ON DUPLICATE KEY UPDATE `amount` = VALUES(`amount`)",type, amount);
    mysql_tquery(mysql, query, "", "");

    format(query, sizeof(query), "Автофинка для типа %d установлена", type);
    SendClientMessage(playerid, 0x00FF00FF, query);
    DeletePVar(playerid, "AutofinkaType");
    }
    if (dialogid == DIALOG_BUG_REPORT_LIST)
  {
    if (response)
    {
      if (listitem >= 0 && listitem < MAX_LISTITEMS)
      {
        new report_id = g_player_listitem[playerid][listitem];

        if (report_id > 0)
        {
          ShowBugReportDetail(playerid, report_id);
        }
        else
        {
          SendClientMessage(playerid, -1, "Ошибка: Неверный ID репорта.");
        }
      }
      else
      {
        SendClientMessage(playerid, -1, "Ошибка: Неверный выбор.");
      }
    }
    else
    {
    }
    return 1;
  }
    else if (dialogid == DIALOG_BUG_REPORT_DETAIL)
  {
    if (response)
    {
    }
    else
    {
      ShowBugReportActionDialog(playerid);
    }
    return 1;
  }
    if (dialogid == DIALOG_BUGREPORT_TYPE)
       {
           if (response)
           {
               g_BugReportType[playerid] = listitem;
               ShowBugreportDescriptionDialog(playerid);
           }
           else
           {
           }
           return 1;
       }
    else if (dialogid == DIALOG_BUGREPORT_DESCRIPTION)
   {
       if (response)
       {
           if (g_BugReportType[playerid] != -5)
           {
               if (strlen(inputtext) > -5)
               {
                   SendBugreportToDatabase(playerid, g_BugReportType[playerid], inputtext);
                   g_BugReportType[playerid] = -5;
               }
               else
               {
                   SendClientMessage(playerid, COLOR_RED, "Пожалуйста, введите описание.");
                   ShowBugreportDescriptionDialog(playerid);
               }
           }
           else
           {
               SendClientMessage(playerid, COLOR_RED, "Не удалось получить тип обращения.");
                      }
       }
       return 1;
   }
    else if (dialogid == DIALOG_BUGREPORT_LIST)
    {
        if (response)
        {
            if (listitem != -1)
            {
                new bugreport_index = listitem;
                if (bugreport_index >= 0 && bugreport_index < g_BugreportListSize[playerid])
                {
                }
                else
                {
                    SendClientMessage(playerid, COLOR_RED, "Неверный выбор.");
                }
            }
                else
            {
                SendClientMessage(playerid, COLOR_RED, "Вы ничего не выбрали.");
            }
        }
        return 1;
    }
    else if (dialogid == DIALOG_BUG_REPORT_ACTION)
    {
    new report_id = GetPVarInt(playerid, "current_report_id");

    if (response)
    {
      if (listitem == 0)
        {
            DeleteBugReport(playerid, report_id);
        }
    }
    else
    {
    }
    return 1;
    }
  	if (dialogid == DIALOG_SETLEADER_ORG)
    {
	if (response)
        {
	if (listitem == 7)
            {
	g_SelectedOrg = 0; 
	ShowSetLeaderIDDialog(playerid); 
            }
	else
            {
	g_SelectedOrg = listitem + 1; 
	ShowSetLeaderIDDialog(playerid); 
            }
        }
        else
        {
	SendClientMessage(playerid, 0xFFFFFFFF, "Действие отменено.");
	g_SelectedOrg = -1;
        }
    }
	else if (dialogid == DIALOG_SETLEADER_ID)
    {
	if (response)
        {
	new targetid = strval(inputtext);
	if (!IsPlayerConnected(targetid))
            {
 	SendClientMessage(playerid, 0xFF0000FF, "Ошибка: ID игрока недействителен или игрок не в сети.");
 	g_SelectedOrg = -1;
	return 1;
            }

	SetPlayerOrganization(playerid, targetid, g_SelectedOrg);

	g_SelectedOrg = -1;
        }
	else
        {
	SendClientMessage(playerid, 0xFFFFFFFF, "Действие отменено.");
	g_SelectedOrg = -1;
        }
    }
	Jail_DialogRespones(playerid, dialogid, listitem, response, inputtext);
	if(GetPVarInt(playerid, "Login_1") != 1) 
	{
		printf("[DETECT] Игрок %s попытался использовать диалог не авторизовавшись", GetPlayerNameEx(playerid));
		return 1;
	}
	if(player_DialogID[playerid] != dialogid) return 1;
	player_DialogID[playerid] = -1;

	if(strcmp(inputtext, "#", true) == 0 || strcmp(inputtext, "|", true) == 0 || strcmp(inputtext, "%", true) == 0 || strcmp(inputtext, "@", true) == 0 || strcmp(inputtext, "&", true) == 0) SendClientMessage(playerid, 0xFF6600FF, "В сообщение присутствуют запрещеные символы");
	if(strfind(inputtext,"%") != -1) return SendClientMessage(playerid, 0xFF6600FF, "В сообщение присутствуют запрещеные символы");
    switch(dialogid)
	{
        case DIALOG_GLUSHILKA_MAIN:
        {
            if(!response) return 0;


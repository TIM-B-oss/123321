stock CreateVorota()
{
    for(new i; i < sizeof vorotasystem; i ++)
    {
        if(vorotasystem[i][vorid] == 0) vorotasystem[i][vcreateobj][0] = CreateDynamicObject(vorotasystem[i][vmodel_id], vorotasystem[i][vorota_pos][0], vorotasystem[i][vorota_pos][1], vorotasystem[i][vorota_pos][2], vorotasystem[i][vorota_pos][3], vorotasystem[i][vorota_pos][4],  vorotasystem[i][vorota_pos][5]);
        if(vorotasystem[i][vorid] == 1) vorotasystem[i][vcreateobj][1] = CreateDynamicObject(vorotasystem[i][vmodel_id], vorotasystem[i][vorota_pos][0], vorotasystem[i][vorota_pos][1], vorotasystem[i][vorota_pos][2], vorotasystem[i][vorota_pos][3], vorotasystem[i][vorota_pos][4],  vorotasystem[i][vorota_pos][5]);
        vorotasystem[i][vstatus] = false;
        vorotasystem[i][vcreatesph] = CreateDynamicSphere(vorotasystem[i][vused_pos][0],vorotasystem[i][vused_pos][1],vorotasystem[i][vused_pos][2], 2.5);
    }
    return 1;
}

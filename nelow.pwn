							new fmt_str[128 + 1];

							new rent_time = GetGardenData(businessid, G_RENT_DATE);

							new rent_price = GetGardenData(businessid, G_RENT_PRICE);

							new total_price = rent_price * days;
							if((rent_time + days) <= 14)
							{
								if(GetILPlayerInt(GetPlayerBankMoney(playerid), total_price))
								{

									format(fmt_str, sizeof fmt_str, "UPDATE accounts_1101 a,gardens b SET a.bank=%s,b.rent=%d WHERE a.id=%d AND b.id=%d", SetILPlayerInt(playerid, GetPlayerBankMoney(playerid), -total_price), days + rent_time, GetPlayerAccountID(playerid), GetGardenData(businessid, G_SQL_ID));
									mysql_query(mysql, fmt_str, false);


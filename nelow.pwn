stock ShowBlacklistList(playerid)
{
    new query[256], Cache:result, count;
    static list[1024];
    mysql_format(mysql, query, sizeof(query), "SELECT player_name FROM blacklist WHERE org_id = %d AND STR_TO_DATE(date_end, '%%d.%%m.%%y %%H:%%i') >= NOW()", GetPlayerTeamEx(playerid));
    result = mysql_query(mysql, query, true);
    count = cache_num_rows();
    if(count == 0)
    {
        cache_delete(result);
        SendClientMessage(playerid, 0xFF0000FF, "{FF0000}[Ошибка]{FFFFFF} В черном списке вашей организации нет ни одного игрока. Ваш список чист!");
        ShowBlacklistMenu(playerid);
        return 1;
    }
    list[0] = '\0';
    for(new i; i < count; i++)
    {
        new name[24];
        cache_get_field_content(i, "player_name", name, mysql, sizeof(name));
        format(list, sizeof(list), "%s%s\n", list, name);
    }
    cache_delete(result);
    Dialog(playerid, DIALOG_BLACKLIST_LIST, DIALOG_STYLE_LIST, "Черный список", list, "Ок", "Назад");
    return 1;
}

stock GetPlayerIdByName(name[])
{
    for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(!IsPlayerConnected(i)) continue;
        if(strcmp(GetPlayerNameEx(i), name, true) == 0) return i;
    }
    return INVALID_PLAYER_ID;
}

stock RemoveColors(string[])
{
    new pos = 0;
    while((pos = strfind(string, "{", true, pos)) != -1)
    {
        if(string[pos + 7] == '}')
        {
            strdel(string, pos, pos + 8);
        }
        else
        {
            pos++;
        }
    }
    pos = 0;
    while((pos = strfind(string, "<", true, pos)) != -1)
    {
        new end = strfind(string, ">", true, pos);
        if(end != -1)
        {
            strdel(string, pos, end + 1);
        }
        else
        {
            pos++;
        }
    }
}
stock AddPlayerToBlacklist(playerid, to_player, reason[], days)
{
    new year, month, day, hour, minute;
    getdate(year, month, day);
    gettime(hour, minute);
    new start_str[20];
    format(start_str, sizeof(start_str), "%02d.%02d.%02d %02d:%02d", day, month, year % 100, hour, minute);
    day += days;
    while(day > GetDaysInMonth(month, year))
    {
        day -= GetDaysInMonth(month, year);
        month++;
        if(month > 12)
        {
            month = 1;
            year++;
        }
    }
    new end_str[20];
    format(end_str, sizeof(end_str), "%02d.%02d.%02d %02d:%02d", day, month, year % 100, hour, minute);
    new query[256];
    mysql_format(mysql, query, sizeof(query), "INSERT INTO blacklist (player_name, player_accid, issued_by, org_id, date_start, date_end, reason) VALUES ('%e', %d, '%e', %d, '%s', '%s', '%e')",
        GetPlayerNameEx(to_player),
        GetPlayerAccountID(to_player),
        GetPlayerNameEx(playerid),
        GetPlayerTeamEx(playerid),
        start_str,
        end_str,
        reason);
    mysql_query(mysql, query, false);
    if(GetPlayerTeamEx(to_player) == GetPlayerTeamEx(playerid))
    {
        UnInvite(playerid, to_player);
        SendClientMessage(to_player, 0xFF0000FF, "{FF0000}[Внимание]{FFFFFF} Вы были уволены из организации по причине занесения в черный список. Восстановление возможно только после истечения срока блокировки.");
    }
    return 1;
}

stock AddOfflinePlayerToBlacklist(playerid, name[], accid, reason[], days)
{
    new year, month, day, hour, minute;
    getdate(year, month, day);
    gettime(hour, minute);
    new start_str[20];
    format(start_str, sizeof(start_str), "%02d.%02d.%02d %02d:%02d", day, month, year % 100, hour, minute);
    day += days;
    while(day > GetDaysInMonth(month, year))
    {
        day -= GetDaysInMonth(month, year);
        month++;
        if(month > 12)
        {
            month = 1;
            year++;
        }
    }
    new end_str[20];
    format(end_str, sizeof(end_str), "%02d.%02d.%02d %02d:%02d", day, month, year % 100, hour, minute);
    new query[256];
    mysql_format(mysql, query, sizeof(query), "INSERT INTO blacklist (player_name, player_accid, issued_by, org_id, date_start, date_end, reason) VALUES ('%e', %d, '%e', %d, '%s', '%s', '%e')",
        name,
        accid,
        GetPlayerNameEx(playerid),
        GetPlayerTeamEx(playerid),
        start_str,
        end_str,
        reason);
    mysql_query(mysql, query, false);
    return 1;
}

stock IsPlayerInBlacklist(name[], orgid)
{
    new query[256], Cache:result, found = 0;
    mysql_format(mysql, query, sizeof(query), "SELECT 1 FROM blacklist WHERE player_name = '%e' AND org_id = %d AND STR_TO_DATE(date_end, '%%d.%%m.%%y %%H:%%i') >= NOW() LIMIT 1", name, orgid);
    result = mysql_query(mysql, query, true);
    if(cache_num_rows()) found = 1;
    cache_delete(result);
    return found;
}


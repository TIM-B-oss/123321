public: OnGenerateRandomLicensePlate(playerid, type22)
{
	new numberplate[15] = EOS,
	buyplate[150] = EOS;
	switch(type22)
	{
		case 1:
		{
			format(numberplate, sizeof numberplate, "%s %s", GenerateCarNumber(playerid), GenerateCarNumberRegRu(playerid));
		}
		case 2:
		{
			format(numberplate, sizeof numberplate, "%s %s", GenerateCarNumberKz(playerid), GenerateCarNumberRegKz(playerid));
		}
		case 3:
		{
			format(numberplate, sizeof numberplate, "%s  %s", GenerateCarNumberBy(playerid), GenerateCarNumberRegBy(playerid));
		}
		case 4:
		{
			format(numberplate, sizeof numberplate, "%s", GenerateCarNumberUK(playerid));
		}
		case 5:
		{
			format(numberplate, sizeof numberplate, "%s", GenerateCustomCarNumber(playerid));
		}
	}
    format(buyplate, sizeof buyplate, "interface('MainMenu').setGeneratedCarNumber('%s')", numberplate);
	SendPacket_1(playerid, s_CefInterface, t_CefUpdate, buyplate);
	return 1;
}
public:DS_OnPlayerBuy(playerid,index,listitem,name[]) {
    if(GetPlayerCurrentDonate(playerid) < g_donate_data[index][this.DCurrentPrice]) return Dialog(playerid, -1, DIALOG_STYLE_MSGBOX, "{FF6600}Ошибка", "{FFFFFF}Недостаточно средтсв для покупки", "Назад", "");
    switch(index) {
        case 7: {
            if(listitem < 1 || 2000000000 < listitem) return GameText(playerid, "~r~Неправильное кол-во", 3000, 2);
			if(GetPlayerCurrentDonate(playerid) < listitem) return Dialog(playerid, -1, DIALOG_STYLE_MSGBOX, "{FF6600}Ошибка", "{FFFFFF}Недостаточно средтсв для покупки", "Назад", "");

			SCMF(playerid, 0xFFFF00FF, "Вы сконвертировали {66cc00}%d.00 доната {ffff00}в {66cc00}%d игр.руб.", listitem, listitem * g_donate_data[index][this.DPrice]);
			GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);

			STRING_GLOBAL[0] = EOS;

			format(STRING_GLOBAL, sizeof STRING_GLOBAL, "Конвертация %d руб. в игровую валюту", listitem);
			GivePlayerDonate(playerid, -listitem, STRING_GLOBAL, true, false);
			GivePlayerMoneyEx(playerid, listitem * g_donate_data[index][this.DPrice], STRING_GLOBAL, true, true);

			format(STRING_GLOBAL, sizeof STRING_GLOBAL, "~g~+%d рублей~n~~r~-%d доната", listitem * g_donate_data[index][this.DPrice], listitem);
			GameText(playerid, STRING_GLOBAL, 3000, 2);
			STRING_GLOBAL[0] = EOS;

			format(STRING_GLOBAL, sizeof STRING_GLOBAL, "interface('MainMenu').openCelebrationModal([0, [[1,\"Конвертация валюты\",%d,%d]]])", g_donate_data[index][MainMenu.DPrice], g_donate_data[index][MainMenu.DPrice]);
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, STRING_GLOBAL);
        }
        case 8: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice],"Покупка в магазине");
            GivePlayerMoneyEx(playerid, 22500000,"Покупка в магазине");
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').openCelebrationModal([0, [[1,\"Игровая валюта\",5000,5000]]])");
            GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 9: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice],"Покупка в магазине");
            GivePlayerMoneyEx(playerid, 4170000,"Покупка в магазине");
            SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').openCelebrationModal([0, [[1,\"Игровая валюта\",1000,1000]]])");
            GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 10: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice],"Покупка в магазине");
            GivePlayerMoneyEx(playerid, 1650000,"Покупка в магазине");
            SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').openCelebrationModal([0, [[1,\"Игровая валюта\",500,500]]])");
            GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 11: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice],"Покупка в магазине");
            GivePlayerMoneyEx(playerid, 750000,"Покупка в магазине");
            SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').openCelebrationModal([0, [[1,\"Игровая валюта\",250,250]]])");
            GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 12: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice],"Покупка в магазине");
            GivePlayerMoneyEx(playerid, 300000,"Покупка в магазине");
            SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').openCelebrationModal([0, [[1,\"Игровая валюта\",113,133]]])");
            GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 14..16: return GameText(playerid,"~r~Недоступно", 3000, 3);
        case 21: {
            SetPlayerData(playerid, P_WEAPON_LIC, GetPlayerData(playerid, P_WEAPON_LIC) ^ 1);
			UpdatePlayerDatabaseInt(playerid, "weapon_lic", GetPlayerData(playerid, P_WEAPON_LIC));
			SetPlayerData(playerid, P_DRIVING_LIC, GetPlayerData(playerid, P_DRIVING_LIC) ^ 1);
			UpdatePlayerDatabaseInt(playerid, "driving_lic", GetPlayerData(playerid, P_DRIVING_LIC));
			SetPlayerData(playerid, P_DRIVING_LIC, GetPlayerData(playerid, P_DRIVING_LIC) == 2 ? 0 : 2);
			UpdatePlayerDatabaseInt(playerid, "driving_lic", GetPlayerData(playerid, P_DRIVING_LIC));
			GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice]);
			format(STRING_GLOBAL, sizeof STRING_GLOBAL, "interface('MainMenu').openCelebrationModal([0, [[1,\"Все лицензии\",%d,%d]]])", g_donate_data[index][MainMenu.DPrice], g_donate_data[index][MainMenu.DPrice]);
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, STRING_GLOBAL);
			GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 22:
        {
            if(GetPlayerCurrentDonate(playerid) < g_donate_taty_price[listitem][tatyPrice]) return Dialog(playerid, -1, DIALOG_STYLE_MSGBOX, "{FF6600}Ошибка", "{FFFFFF}Недостаточно средтсв для покупки", "Назад", "");
			GivePlayerDonate(playerid, -g_donate_taty_price[listitem][tatyPrice]);
			SetPlayerData(playerid, P_NAKOLKA, g_donate_taty_price[listitem][tatyid]);
			UpdatePlayerDatabaseInt(playerid, "nakolka", g_donate_taty_price[listitem][tatyid]);
			format(STRING_GLOBAL, sizeof STRING_GLOBAL, "interface('MainMenu').openCelebrationModal([0, [[1,\"Наколка\",%d,%d]]])", g_donate_taty_price[listitem][tatyPrice], g_donate_taty_price[listitem][tatyPrice]);
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, STRING_GLOBAL);
			GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 23: {
            if(GetPlayerData(playerid, P_WARN) == 0) return GameText(playerid, "У вас нет предупреждений", 3000, 2);

			SetPlayerData(playerid, P_WARN, 0);
			UpdatePlayerDatabaseInt(playerid, "warn", 0);
			GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice]);
			format(STRING_GLOBAL, sizeof STRING_GLOBAL, "interface('MainMenu').openCelebrationModal([0, [[1,\"Снять все предупреждения\",%d,%d]]])", g_donate_taty_price[listitem][tatyPrice], g_donate_taty_price[listitem][tatyPrice]);
			SendPacket_1(playerid, s_CefInterface, t_CefUpdate, STRING_GLOBAL);
			GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 24: {
            if(GetPlayerData(playerid, P_WARN) == 0) return GameText(playerid, "У вас нет предупреждений", 3000, 2);

			SetPlayerData(playerid, P_WARN, 0);
			UpdatePlayerDatabaseInt(playerid, "warn", 0);
			GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice]);
        }
        case 25: {
            new len = strlen(name);
			if(4 <= len <= 20)
			{
				new bool: valid_name = true;
				for(new idx; idx < len; idx ++)
				{
					switch(name[idx])
					{
						case 'a'..'z', 'A'..'Z', '[', ']', '_': continue;
						default:
							valid_name = false;
					}
				}
				if(!strcmp(GetPlayerNameEx(playerid), name, true)) SendClientMessage(playerid, 0xFF6600FF, "* Вы уже используете это имя");
				else if(valid_name)
				{
					new query[128];
					new Cache: result, rows;

					mysql_format(mysql, query, sizeof query, "SELECT id FROM accounts_1101 WHERE name='%e' LIMIT 1", name);
					result = mysql_query(mysql, query, true);

					rows = cache_num_rows();
					cache_delete(result);

					if(!rows)
					{
						if(ChangePlayerName(playerid, name, false))
						{

							GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice]);

							SCM(playerid, -1, "{ff8c00}[Уведомление] {ffffff}Вы успешно сменили никнейм. Перезайдите.");
                            GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
							return 1;
						}
						else SendClientMessage(playerid, 0xFF6600FF, "* При смене ника произошла ошибка");

					}
					else SendClientMessage(playerid, 0xFF6600FF, "* Введенное Вами имя уже используется");
				}
				else
				{
					SendClientMessage(playerid, 0xFF6600FF, "* Имя уже используется или содержит недопустимые символы");
					SendClientMessage(playerid, 0xFFFFFFFF, "Используйте латинские буквы a-z A-Z, а также символы [ ] _");
				}
			}
			else SendClientMessage(playerid, 0xFF6600FF, "* Недопустимый формат ввода");
        }
        case 26: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice]);
			SetPlayerData(playerid, P_LAW_ABIDING, GetPlayerData(playerid, P_LAW_ABIDING) + 10);
			UpdatePlayerDatabaseInt(playerid, "law_abiding", GetPlayerData(playerid, P_LAW_ABIDING));
			GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 27: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice]);
			SetPlayerData(playerid, P_VOEN, 1);
			UpdatePlayerDatabaseInt(playerid, "voennik", 1);
			GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 28,29: {
            GivePlayerDonate(playerid, -g_donate_data[index][this.DPrice]);
			SetPlayerData(playerid, P_SKILL_COLT, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_colt", 100);
			SetPlayerData(playerid, P_SKILL_SDPISTOL, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_sdpistol", 100);
			SetPlayerData(playerid, P_SKILL_DEAGLE, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_deagle", 100);
			SetPlayerData(playerid, P_SKILL_SHOTGUN, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_shotgun", 100);
			SetPlayerData(playerid, P_SKILL_MP5, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_mp5", 100);
			SetPlayerData(playerid, P_SKILL_AK47, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_ak47", 100);
			SetPlayerData(playerid, P_SKILL_M4, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_m4", 100);
			SetPlayerData(playerid, P_SKILL_SNIPER_RIFLE, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_sniper_rifle", 100);
			SetPlayerData(playerid, P_SKILL_SAWNOFF, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_sawnoff", 100);
			SetPlayerData(playerid, P_SKILL_COMBAT_SG, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_combat_sg", 100);
			SetPlayerData(playerid, P_SKILL_MICRO_UZI, 100);
			UpdatePlayerDatabaseInt(playerid, "skill_micro_uzi", 100);
			GameText(playerid, "~g~УСПЕШНАЯ ПОКУПКА!", 3000, 2);
        }
        case 30: return GameText(playerid,"~r~Недоступно", 3000, 3);
    }
    return 1;
}
public: DS_OnPlayerBuyVIP(playerid, viptype, useGameMoney, isYearly)
{
    for(new i; i < (isYearly ? sizeof(g_vip_yearly) : sizeof(g_vip_monthly)); i++)
    {
        if((isYearly ? g_vip_yearly[i][V_ID] : g_vip_monthly[i][V_ID]) != viptype) continue;

        new price = useGameMoney ?
            (isYearly ? g_vip_yearly[i][V_PRICE_MONEY] : g_vip_monthly[i][V_PRICE_MONEY]) :
            (isYearly ? g_vip_yearly[i][V_PRICE] : g_vip_monthly[i][V_PRICE]);

        new timePeriod = isYearly ? g_vip_yearly[i][V_TIME] : g_vip_monthly[i][V_TIME];

        if(useGameMoney)
        {
            if(!GetILPlayerInt(GetPlayerMoneyEx(playerid), price))
                return SCM(playerid, -1, "{ff0000}[Ошибка] {ffffff}Недостаточно игровой валюты!");

            GivePlayerMoneyEx(playerid, -price);
        }
        else
        {
            if(GetPlayerCurrentDonate(playerid) < price)
                return SCM(playerid, -1, "{ff0000}[Ошибка] {ffffff}Недостаточно донат валюты!");

            GivePlayerDonate(playerid, -price, "Покупка VIP");
        }

        new currentVIP = GetPlayerData(playerid, P_PREMIUM);

        new newPremiumTime;
        if(currentVIP == (isYearly ? g_vip_yearly[i][V_VIP] : g_vip_monthly[i][V_VIP]))
        {
            newPremiumTime = max(gettime(), GetPlayerData(playerid, P_PREMIUM_TIME)) + timePeriod;
        }
        else
        {
            newPremiumTime = gettime() + timePeriod;
        }

        GameText(playerid, "~g~Успешная покупка", 4000, 2);
        SetPlayerData(playerid, P_PREMIUM, isYearly ? g_vip_yearly[i][V_VIP] : g_vip_monthly[i][V_VIP]);
        SetPlayerData(playerid, P_PREMIUM_TIME, newPremiumTime);
        UpdatePlayerDatabaseInt(playerid, "premium", isYearly ? g_vip_yearly[i][V_VIP] : g_vip_monthly[i][V_VIP]);
        UpdatePlayerDatabaseInt(playerid, "premium_time", newPremiumTime);

        SCMF(playerid, -1, "{ff8c00}[Уведомление] {ffffff}Вы успешно приобрели %s на %d дней.", g_vip_names[viptype], timePeriod / 86400);
    }
    return true;
}
stock MainMenuSendError(playerid,const text[]) {
    STRING_GLOBAL[0] = EOS;
    format(STRING_GLOBAL, sizeof STRING_GLOBAL, "interface('MainMenu').onServerModalResponse([1, \"%s\"])",text);
    SendPacket_1(playerid, s_CefInterface, t_CefUpdate,STRING_GLOBAL);
    return 1;
}
stock MainMenuConfirm(playerid) {
    SendPacket_1(playerid, s_CefInterface, t_CefUpdate, "interface('MainMenu').onServerModalResponse([0, \"\"])");
    GameText(playerid, "~g~Успешно", 3000, 2);
    return 1;
}
stock GetCarId(model_id) {
    for(new i,fa = sizeof(g_vehicle_info);i<fa;i++)
	{
		if(g_vehicle_info[i][VI_ID] != model_id) continue;
		return i;
	}
    return 0;
}
stock GetCountImprovmentes(playerid, type)
{
    if (type == 0)
    {
        str_q[0] = EOS;
        mysql_format(mysql, str_q, sizeof str_q, "SELECT * FROM business WHERE owner_id='%d'", GetPlayerAccountID(playerid));
        new Cache:result = mysql_query(mysql, str_q, true);
        new rows = cache_num_rows();
        cache_delete(result);
        return rows;
    }
    if (type == 1)
    {
        str_q[0] = EOS;
        mysql_format(mysql, str_q, sizeof str_q, "SELECT * FROM ownable_cars WHERE owner_id = '%d'", GetPlayerAccountID(playerid));
        new Cache:result = mysql_query(mysql, str_q, true);
        new rows = cache_num_rows();
        cache_delete(result);
        return rows;
    }
    if (type == 2)
    {
        str_q[0] = EOS;
        mysql_format(mysql, str_q, sizeof str_q, "SELECT * FROM houses WHERE owner_id='%d'", GetPlayerAccountID(playerid));
        new Cache:result = mysql_query(mysql, str_q, true);
        new rows = cache_num_rows();
        cache_delete(result);
        return rows;
    }
    return 0;
}
stock Military_Init()
{
	military_vorota[0] = CreateDynamicObject(18470, 1286.36, 3279.43, 12.8157,   0.00000, 0.00000,0.00000);
	military_vorota[1] = CreateDynamicObject(18470, 1286.36, 3266.85, 12.8185,   0.00000, 0.00000, -180);

	military_vorota[2] = CreateDynamicObject(18470, 1049.47, 3279.39, 12.655,   0.00000, 0.00000,0.00000);
	military_vorota[3] = CreateDynamicObject(18470, 1049.5, 3266.84, 12.6473,   0.00000, 0.00000, -180);

	military_vorota[4] = CreateDynamicObject(17135, 1294.61,3262.85,10.0762,   0.00000, 0.00000, 88);

	AddInteraction("Открыть / Закрыть", E_TYPE_MILITARY_VOROTA, 0, 0, 3.0, 1294.61,3262.85,10.0762, -1, false, TEAM_ARMY);
	AddInteraction("Открыть / Закрыть", E_TYPE_MILITARY_VOROTA, 0, 0, 10.0, 1286.7625,3273.1074,11.3895, -1, false, TEAM_ARMY);
	AddInteraction("Открыть / Закрыть", E_TYPE_MILITARY_VOROTA, 0, 0, 10.0, 1049.0726,3273.0867,11.3043, -1, false, TEAM_ARMY);


	military_boom[0] = CreateDynamicObject(18538, 1189.4, 3408.5, 10.6005,   0.00000, 0.00000, -90);
	CreateDynamicObject(18538, 1259.04, 3206.63, 9.87918,   0.00000, 0.00000, -90.0002);
	military_interaction[0] = AddInteraction("Заминировать забор", E_TYPE_MILITARY_BOOM, 0, 0, 10.0, 1189.4, 3408.5, 10.6005, -1, false, 0);

	CreatePickup(1654, 0, 2402.4104,-1834.7034,19.0850, -1, PICKUP_ACTION_TYPE_BOMBA);
	CreateDynamic3DTextLabel("Покупка взрывчатки\nСтоимость: 1.500.000", 0xFFFFFFFF, 2402.4104,-1834.7034,19.0850 + 0.1, 7.0);
}

stock MilitaryUse(playerid, type)
{
	if(type == 0)
	{
		if(IsPlayerInRangeOfPoint(playerid, 15.0, 1286.7625,3273.1074,11.3895))
		{
			if(vorota_open[0] == 0)
			{
				MoveDynamicObject(military_vorota[0], 1286.4, 3285.11, 12.8356, 4.0, 0.0, 0.0, 0.0);
				MoveDynamicObject(military_vorota[1], 1286.41, 3260.42, 12.8165, 4.0, 0.0, 0.0, -180);
				vorota_open[0] = 1;
			}
			else if(vorota_open[0] == 1)
			{
				MoveDynamicObject(military_vorota[0], 1286.36, 3279.43, 12.8157, 4.0, 0.0, 0.0, 0.0);
				MoveDynamicObject(military_vorota[1], 1286.36, 3266.85, 12.8185, 4.0, 0.0, 0.0, -180);
				vorota_open[0] = 0;
			}
		}

		if(IsPlayerInRangeOfPoint(playerid, 15.0, 1049.0726,3273.0867,11.3043))
		{
			if(vorota_open[1] == 0)
			{
				MoveDynamicObject(military_vorota[2], 1049.49,3284.39,12.6649, 4.0, 0.0, 0.0, 0.0);
				MoveDynamicObject(military_vorota[3], 1049.47,3261.22,12.6617, 4.0, 0.0, 0.0, -180);
				vorota_open[1] = 1;
			}
			else if(vorota_open[1] == 1)
			{
				MoveDynamicObject(military_vorota[2], 1049.47, 3279.39, 12.655, 4.0, 0.0, 0.0, 0.0);
				MoveDynamicObject(military_vorota[3], 1049.5, 3266.84, 12.6473, 4.0, 0.0, 0.0, -180);
				vorota_open[1] = 0;
			}
		}

		if(IsPlayerInRangeOfPoint(playerid, 5.0, 1294.61,3262.85,10.0762))
		{
			if(vorota_open[2] == 0)
			{
				MoveDynamicObject(military_vorota[4], 1294.67, 3262.86, 10.0886, 4.0, 0.0, 0.0, -6);
				vorota_open[2] = 1;
			}
			else if(vorota_open[2] == 1)
			{
				MoveDynamicObject(military_vorota[4], 1294.61,3262.85,10.0762, 4.0, 0.0, 0.0, 88);
				vorota_open[2] = 0;
			}
		}
	}
	if(type == 1)
	{
		if(IsPlayerInRangeOfPoint(playerid, 25.0, 1189.4, 3408.5, 10.6005))
		{
			if(military_bomba[playerid] != 1) return SCM(playerid, COLOR_RED, "У вас нету взрывчатки чтобы взорвать стенку!");
			if(GetPlayerTeamEx(playerid) == TEAM_ARMY) return 1;
			military_timer[1] = SetTimerEx("MilitaryBoom", 15_000, false, "ii", playerid, 1);
			SendClientEventWithArgumentsF(playerid, s_CefInterface, t_CefShow, "InformationTimer", "[\"До взрыва\",%d,0]", gettime() + 15);
			ApplyAnimation(playerid, "BOMBER", "BOM_Plant", 4.0, false, 0, 0, 0, 0);
			SCM(playerid, COLOR_ORANGE, "Вы установили бомбу на забор, взрыв произойдет через 15 сек.");
			SendClientMessageToAll(COLOR_RED, "------------------ВНИМАНИЕ!------------------");
			SendClientMessageToAll(COLOR_RED, "НА ВОЕННУЮ БАЗУ МО БЫЛО СОВЕРШЕНО НАПАДЕНИЕ!!");
			SendClientMessageToAll(COLOR_RED, "НА ВОЕННУЮ БАЗУ МО БЫЛО СОВЕРШЕНО НАПАДЕНИЕ!!");
			SendClientMessageToAll(COLOR_RED, "НА ВОЕННУЮ БАЗУ МО БЫЛО СОВЕРШЕНО НАПАДЕНИЕ!!");
			SendClientMessageToAll(COLOR_RED, "ПОЧИНИТЬ СТЕНУ МОЖНО БУДЕТ ТОЛЬКО ЧЕРЕЗ 10мин");
			SendClientMessageToAll(COLOR_RED, "------------------ВНИМАНИЕ!------------------");
		}
	}
	if(type == 2)
	{
		if(IsPlayerInRangeOfPoint(playerid, 25.0, 1189.4, 3408.5, 10.6005))
		{
			if(military_bstatus == 0) return SCM(playerid, COLOR_WHITE, "Забор не нуждается в ремонте.");
			ApplyAnimationEx(playerid, "BASEBALL", "Bat_4", 3.1, 1, 1, 1, 0, 0, 0, USE_ANIM_TYPE_NONE - 1);
			military_timer[0] = SetTimerEx("MilitaryFix", 30_000, false, "ii", playerid, 1);
		}
	}
	return 1;
}

public: MilitaryFix(playerid)
{
	ClearAnimations(playerid);
	military_bstatus = 0;
	military_boom[0] = CreateDynamicObject(18538, 1189.4, 3408.5, 10.6005,   0.00000, 0.00000, -90);
	military_interaction[0] = AddInteraction("Заминировать забор", E_TYPE_MILITARY_BOOM, 0, 0, 10.0, 1189.4, 3408.5, 10.6005, -1, false, 0);
	DestroyInteraction(military_interaction[1]);
	DestroyDynamicObject(military_boom[1]);
	DestroyDynamicObject(military_boom[2]);
	SCM(playerid, COLOR_GREEN, "Вы успешно восстановили забор после взрыва!");
	GiveRandomCase(playerid);
	KillTimer(military_timer[0]);
}

public: MilitaryBoom(playerid)
{
	if(GetPlayerFamily(playerid) != 0 && GetFamilyData(GetPlayerFamily(playerid),F_GANG) == 1)
	{
		if(GetPlayerTeamEx(playerid) == TEAM_ARMY) return 1;
		if(military_bstatus == 1) return SCM(playerid, COLOR_RED, "СТЕНКА УЖЕ ВЗОРВАНА!");
		DestroyDynamicObject(military_boom[0]);
		military_boom[1] = CreateDynamicObject(18539, 1189.4, 3408.5, 10.6005,   0.00000, 0.00000, -90);
		military_boom[2] = CreateDynamicObject(18685, 1189.4, 3408.5, 10.6005,   0.00000, 0.00000, -90);
		military_bstatus = 1;
		DestroyInteraction(military_interaction[0]);

		KillTimer(military_timer[1]);
		military_timer[2] = SetTimer("MilitaryTimeFix", 150000, true);
	}
	return 1;
}

public: MilitaryTimeFix(playerid)
{
	KillTimer(military_timer[2]);
	military_interaction[1] = AddInteraction("Отремонтировать забор", E_TYPE_MILITARY_FIX, 0, 0, 10.0, 1189.4, 3408.5, 10.6005, -1, false, TEAM_ARMY);
}
public:OnActivateBonusOrPromocode(playerid, name[]) {
    new Cache:result,
        rows,
        count_activation,
        count_time,
        type_prize[6],
        id_prize[6],
        count_prize[6];
    str_q[0] = EOS;
    mysql_format(mysql, str_q, sizeof str_q, "SELECT * FROM promocode_activations WHERE owner_id='%d' AND name='%s'", GetPlayerAccountID(playerid), name);
    result = mysql_query(mysql, str_q, true);
    rows = cache_num_rows();
    cache_delete(result);
    if(rows) return MainMenuSendError(playerid,"Вы уже активировали данный промокодом");
    mysql_format(mysql, str_q, sizeof str_q, "SELECT * FROM prizes_code WHERE name='%s' AND count_activation > 0 AND type_code=1", name);
    result = mysql_query(mysql, str_q, true);
    rows = cache_num_rows();
    if (cache_num_rows())
    {
        count_activation = cache_get_field_content_int(0, "count_activation");
        count_time = cache_get_field_content_int(0, "count_time");
        type_prize[0] = cache_get_field_content_int(0, "type_prize_1");
        id_prize[0] = cache_get_field_content_int(0, "id_prize_1");
        count_prize[0] = cache_get_field_content_int(0, "count_prize_1");
        type_prize[1] = cache_get_field_content_int(0, "type_prize_2");
        id_prize[1] = cache_get_field_content_int(0, "id_prize_2");
        count_prize[1] = cache_get_field_content_int(0, "count_prize_2");
        type_prize[2] = cache_get_field_content_int(0, "type_prize_3");
        id_prize[2] = cache_get_field_content_int(0, "id_prize_3");
        count_prize[2] = cache_get_field_content_int(0, "count_prize_3");
        type_prize[3] = cache_get_field_content_int(0, "type_prize_4");
        id_prize[3] = cache_get_field_content_int(0, "id_prize_4");
        count_prize[3] = cache_get_field_content_int(0, "count_prize_4");
        type_prize[4] = cache_get_field_content_int(0, "type_prize_5");
        id_prize[4] = cache_get_field_content_int(0, "id_prize_5");
        count_prize[4] = cache_get_field_content_int(0, "count_prize_5");
        type_prize[5] = cache_get_field_content_int(0, "type_prize_6");
        id_prize[5] = cache_get_field_content_int(0, "id_prize_6");
        count_prize[5] = cache_get_field_content_int(0, "count_prize_6");
        cache_delete(result);
        if (count_activation > 0)
        {
            mysql_format(mysql, str_q, sizeof str_q, "UPDATE prizes_code SET count_activation='%d' WHERE name='%s'", count_activation - 1, name);
            mysql_query(mysql, str_q, false);
            CreatePlayerPromo(playerid, name, count_time);
            SCMF(playerid, 0x66CC33FF, "{ffff00}Вы активировали промокод \"%s\"", name);
            SCM(playerid, COLOR_GREY, "Примечание: бонусы выдаются во время зарплаты");
            STRING_GLOBAL[0] = EOS;
            for (new i; i < MAX_PRIZES_CODE; i++)
            {
                if (type_prize[i] == 1) format(str_q, sizeof str_q, "{FFFFFF}- %s рублей\n", formatInt(count_prize[i])), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 2) format(str_q, sizeof str_q, "{FFFFFF}- %s донат-монет\n", formatInt(count_prize[i])), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 3) format(str_q, sizeof str_q, "{FFFFFF}- Игровой опыт в количестве %d шт.\n", count_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 4) format(str_q, sizeof str_q, "{FFFFFF}- %s в количестве %d шт.\n", ItemsInfo[id_prize[i]][i_item_name], count_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 5) format(str_q, sizeof str_q, "{FFFFFF}- %s [№%d]\n", GetVehicleInfo(id_prize[i], VI_NAME), id_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 6) format(str_q, sizeof str_q, "{FFFFFF}- Слот на бизнес в количестве %d шт.\n", count_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 7) format(str_q, sizeof str_q, "{FFFFFF}- Слот на дом в количестве %d шт.\n", count_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 8) format(str_q, sizeof str_q, "{FFFFFF}- Слот на гараж в количестве %d шт.\n", count_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 9) format(str_q, sizeof str_q, "{FFFFFF}- Слот на транспорт в количестве %d шт.\n", count_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 10) format(str_q, sizeof str_q, "{FFFFFF}- Слот на киоск в количестве %d шт.\n", count_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 11) format(str_q, sizeof str_q, "{FFFFFF}- Одежда[№%d]\n", id_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 12) format(str_q, sizeof str_q, "{FFFFFF}- Аксессуар[№%d]\n", id_prize[i]), strcat(STRING_GLOBAL, str_q);
                if (type_prize[i] == 13 && id_prize[i] == 1) format(str_q, sizeof str_q, "{FFFFFF}- Купон на выход из Деморгана (%d мин)\n", count_prize[i]), strcat(STRING_GLOBAL, str_q);
            }
            format
            (
                STRING_GLOBAL, sizeof STRING_GLOBAL,
                "{bebfba}Вы активировали промокод \'%s\'\n\
                                    {FFFFFF}После {6cbbea}%02d {FFFFFF}минут игры на сервере (не AFK), Вы получите:\n\n\
                                    %s\n\
                                    Примечание: призы выдаются во время отыгранной зарплаты\n\n\
                                    Успейте выполнить все условия для получения награды",
                name, floatround(count_time / 60), STRING_GLOBAL
            );
            MainMenuConfirm(playerid);
            return 1;
        }
        else return MainMenuSendError(playerid, "Достигнут лимит использований промокода");
    }
    cache_delete(result);
    format(str_q, sizeof str_q, "SELECT * FROM promocode_activations WHERE owner_id='%d' AND name='%s'", GetPlayerAccountID(playerid), name);
    result = mysql_query(mysql, str_q, true);
    rows = cache_num_rows();
    cache_delete(result);
    if (rows) return MainMenuSendError(playerid, "Вы уже активировали данный бонус код");
    format(str_q, sizeof str_q, "SELECT * FROM prizes_code WHERE name='%s' AND count_activation > 0 AND type_code=2", name);
    result = mysql_query(mysql, str_q, true);
    rows = cache_num_rows();
    new type_code;
    if (rows)
    {
        count_activation = cache_get_field_content_int(0, "count_activation");
        type_prize[0] = cache_get_field_content_int(0, "type_prize_1");
        id_prize[0] = cache_get_field_content_int(0, "id_prize_1");
        count_prize[0] = cache_get_field_content_int(0, "count_prize_1");
        type_prize[1] = cache_get_field_content_int(0, "type_prize_2");
        id_prize[1] = cache_get_field_content_int(0, "id_prize_2");
        count_prize[1] = cache_get_field_content_int(0, "count_prize_2");
        type_prize[2] = cache_get_field_content_int(0, "type_prize_3");
        id_prize[2] = cache_get_field_content_int(0, "id_prize_3");
        count_prize[2] = cache_get_field_content_int(0, "count_prize_3");
        type_prize[3] = cache_get_field_content_int(0, "type_prize_4");
        id_prize[3] = cache_get_field_content_int(0, "id_prize_4");
        count_prize[3] = cache_get_field_content_int(0, "count_prize_4");
        type_prize[4] = cache_get_field_content_int(0, "type_prize_5");
        id_prize[4] = cache_get_field_content_int(0, "id_prize_5");
        count_prize[4] = cache_get_field_content_int(0, "count_prize_5");
        type_prize[5] = cache_get_field_content_int(0, "type_prize_6");
        id_prize[5] = cache_get_field_content_int(0, "id_prize_6");
        count_prize[5] = cache_get_field_content_int(0, "count_prize_6");
        type_code = cache_get_field_content_int(0, "type_code");
    }
    cache_delete(result);
    if (!rows || type_code == 1) return MainMenuSendError(playerid, "Бонускод или промокод не найден");
    mysql_format(mysql, str_q, sizeof str_q, "SELECT * FROM promocode_activations WHERE owner_id='%d' AND name='%s'", GetPlayerAccountID(playerid), name);
    result = mysql_query(mysql, str_q, true);
    rows = cache_num_rows();
    if (count_activation > 0)
    {
        mysql_format(mysql, str_q, sizeof str_q, "UPDATE prizes_code SET count_activation='%d' WHERE name='%s'", count_activation - 1, name);
        mysql_query(mysql, str_q, false);
        mysql_format(mysql, str_q, sizeof str_q, "INSERT INTO promocode_activations (owner_id, name, time, type, status) VALUES (%d, '%s', 0, 0, 2)", GetPlayerAccountID(playerid), name);
        mysql_query(mysql, str_q, false);
        STRING_GLOBAL[0] = EOS;
        for (new i; i < MAX_PRIZES_CODE; i++)
        {
            if (type_prize[i] == 1)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Деньги: %d руб {3599f5}за активацию бонус кода", count_prize[i]),
                    GivePlayerMyPrizes(playerid, "Деньги", 5, 0, 0, count_prize[i], 0),
                    format(str_q, sizeof str_q, "{FFFFFF}- %s рублей\n", formatInt(count_prize[i])),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 2)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Донат: %d руб {3599f5}за активацию бонус кода", count_prize[i]),
                    GivePlayerMyPrizes(playerid, "Донат", 10, 0, 0, count_prize[i], 0),
                    format(str_q, sizeof str_q, "{FFFFFF}- %s донат-монет\n", formatInt(count_prize[i])),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 3)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}%d EXP {3599f5}за активацию бонус кода", count_prize[i]),
                    GivePlayerExp(playerid, count_prize[i]),
                    format(str_q, sizeof str_q, "{FFFFFF}- Игровой опыт в количестве %d шт.\n", count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 4)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}%s в количестве %d шт. {3599f5}за активацию бонус кода", ItemsInfo[id_prize[i]][i_item_name], count_prize[i]),
                    format(str_q, sizeof str_q, "%s", ItemsInfo[id_prize[i]][i_item_name]),
                    GivePlayerMyPrizes(playerid, str_q, 8, id_prize[i], 0, count_prize[i], 0),
                    format(str_q, sizeof str_q, "{FFFFFF}- %s в количестве %d шт.\n", ItemsInfo[id_prize[i]][i_item_name], count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 5)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}%s {3599f5}за активацию бонус кода", GetVehicleInfo(id_prize[i], VI_NAME)),
                    format(str_q, sizeof str_q, "%s[№%d]", GetVehicleInfo(id_prize[i], VI_NAME), id_prize[i]),
                    GivePlayerMyPrizes(playerid, str_q, 3, id_prize[i], 0, 1, -1),
                    format(str_q, sizeof str_q, "{FFFFFF}- %s [№%d]\n", GetVehicleInfo(id_prize[i], VI_NAME), id_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 6)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Слот на бизнес в количестве %d шт. {3599f5}за активацию бонус кода", count_prize[i]),
                    AddPlayerData(playerid, P_BIZ_SLOTS, +, count_prize[i]),
                    UpdatePlayerDatabaseInt(playerid, "biz_slots", GetPlayerData(playerid, P_BIZ_SLOTS)),
                    format(str_q, sizeof str_q, "{FFFFFF}- Слот на бизнес в количестве %d шт.\n", count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 7)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Слот на дом в количестве %d шт. {3599f5}за активацию бонус кода", count_prize[i]),
                    AddPlayerData(playerid, P_HOUSE_SLOTS, +, count_prize[i]),
                    UpdatePlayerDatabaseInt(playerid, "house_slots", GetPlayerData(playerid, P_HOUSE_SLOTS)),
                    format(str_q, sizeof str_q, "{FFFFFF}- Слот на дом в количестве %d шт.\n", count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 8)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Слот на гараж в количестве %d шт. {3599f5}за активацию бонус кода", count_prize[i]),
                    AddPlayerData(playerid, P_GARAGE_SLOTS, +, count_prize[i]),
                    UpdatePlayerDatabaseInt(playerid, "garage_slots", GetPlayerData(playerid, P_GARAGE_SLOTS)),
                    format(str_q, sizeof str_q, "{FFFFFF}- Слот на гараж в количестве %d шт.\n", count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 9)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Слот на транспорт в количестве %d шт. {3599f5}за активацию бонус кода", count_prize[i]),
                    AddPlayerData(playerid, P_CAR_SLOTS, +, count_prize[i]),
                    UpdatePlayerDatabaseInt(playerid, "car_slots", GetPlayerData(playerid, P_CAR_SLOTS)),
                    format(str_q, sizeof str_q, "{FFFFFF}- Слот на транспорт в количестве %d шт.\n", count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 10)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Слот на киоск в количестве %d шт. {3599f5}за активацию бонус кода", count_prize[i]),
                    AddPlayerData(playerid, P_KIOSK_SLOTS, +, count_prize[i]),
                    UpdatePlayerDatabaseInt(playerid, "kiosk_slots", GetPlayerData(playerid, P_KIOSK_SLOTS)),
                    format(str_q, sizeof str_q, "{FFFFFF}- Слот на киоск в количестве %d шт.\n", count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 11)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Одежда[№%d] {3599f5}за активацию бонус кода", id_prize[i]),
                    format(str_q, sizeof str_q, "Одежда[№%d]", id_prize[i]),
                    GivePlayerMyPrizes(playerid, str_q, 4, id_prize[i], 0, 1, 0),
                    format(str_q, sizeof str_q, "{FFFFFF}- Одежда[№%d]\n", id_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 12)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Аксессуар[№%d] {3599f5}за активацию бонус кода", id_prize[i]),
                    format(str_q, sizeof str_q, "Аксессуар[№%d]", id_prize[i]),
                    GivePlayerMyPrizes(playerid, str_q, 6, id_prize[i], 0, 1, count_prize[i]),
                    format(str_q, sizeof str_q, "{FFFFFF}- Аксессуар[№%d]\n", id_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
            if (type_prize[i] == 13 && id_prize[i] == 1)
                SCMF(playerid, COLOR_ORANGE, "{3599f5}Вам начислен приз {FFFFFF}Купон на выход из Деморгана (%d мин) {3599f5}за активацию бонус кода", count_prize[i]),
                    format(str_q, sizeof str_q, "Купон для выхода из тюрьмы Деморган (%d мин)", count_prize[i]),
                    GivePlayerMyPrizes(playerid, str_q, 16, count_prize[i], 0, 0, 0),
                    format(str_q, sizeof str_q, "{FFFFFF}- Купон для выхода из Деморган (%d мин)\n", count_prize[i]),
                    strcat(STRING_GLOBAL, str_q);
        }
        format
        (
            STRING_GLOBAL, sizeof STRING_GLOBAL,
            "{bebfba}Вы успешно активировали бонус код и получили:\n\n\
                        %s",
            STRING_GLOBAL
        );
        MainMenuConfirm(playerid);
        return 1;
    }
    else MainMenuSendError(playerid, "Достигнут лимит использований бонус кода");
    return 1;
}
CMD:lpanel(playerid, params[])
{
	if(!(9 <= GetPlayerJob(playerid) <= 10))
		return SendClientMessage(playerid, 0xCECECEFF, "* Функция доступна лидерам организации и их заместителям");

	string_dialog[0] = EOS;
	format
	(
		string_dialog, sizeof string_dialog,
		"{"SERVER_COLOR"}1.{FFFFFF}Сотрудники\t{"SERVER_COLOR"}Cписок всех сотрудников.\n"\
		"{"SERVER_COLOR"}2.{FFFFFF}Список\t{"SERVER_COLOR"}Список каналов Организации.\n"\
		"{"SERVER_COLOR"}3.{FFFFFF}ЧС\t{"SERVER_COLOR"}Чёрный список фракции.\n"\
        "{"SERVER_COLOR"}4.{FFFFFF}Каналы\t{"SERVER_COLOR"}Создания канала для Рации.\n"\
		"{"SERVER_COLOR"}5.{FFFFFF}Пригласить\t{"SERVER_COLOR"}Пригласить человека в Огранизацию"
	);

    Dialog(playerid, DIALOG_PLAYER_LMENU, DIALOG_STYLE_LIST, "Панель Лидера", string_dialog, "Выбрать", "Закрыть");

	return 1;

}
CMD:autofinka(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 8)
        return SendClientMessage(playerid, 0xFF6600FF, "Ваш уровень администратора недостаточен");

    if(admin_logged[playerid] == false)
        return SendClientMessage(playerid, 0x999999FF, "Вы не авторизированы, для этого используйте /alogin");

    new dialog[1024];
    format(dialog, sizeof(dialog),
    "Укажите ID типа бизнеса:\n\n\
    {FFFFFF}1 - 24/7\n\
    2 - Клуб\n\
    3 - Управление статистики\n\
    4 - Риэлторское Агентство\n\
    5 - Одежда\n\
    6 - Отель\n\
    7 - Авторынок\n\
    8 - Казино\n\
    9 - Сотовый салон\n\
    10 - СТО\n\
    11 - Магазин оружия\n\
    12 - Bank\n\
    13 - Комп клуб\n\
    14 - Спортзал\n\
    15 - Детейлинг\n\
    16 - Аренда авто\n\
    17 - Новое СТО\n\
    18 - Ферма\n\
    19 - Детейлинг (старый)\n\
    20 - БУ\n\
    21 - Новые бизы\n\
    22 - Метро\n\
    23 - Шиномонтаж\n\
    24 - Садовод\n\
    25 - Салон Красоты\n\
    26 - Магазин Автозапчастей\n\
    27 - Тир\n\
    28 - Тонировка\n\
    29 - Нотариус\n\
    30 - Прачечная\n\
    31 - Закусочная\n\
    32 - Аптека\n\
    33 - Кондитерская\n\
    34 - Авторынок (низ)\n\
    35 - Авторынок (сред)\n\
    36 - Ветрики\n\
    37 - АЗС\n\
    38 - Автосалон (низ)\n\
    39 - Автосалон (авиа)\n\
    40 - Автосалон (вода)\n\
    41 - Автосалон (мото)\n\
    42 - Автосалон (сред)\n\
    43 - Автомойка\n\
    44 - Транспортная компания\n\
    45 - Магазин рыболова\n\
    \n{FF0000}Удалить автофинку со всех типов — введите '0'");
    Dialog(playerid, DIALOG_AUTOFINKA_TYPE, DIALOG_STYLE_INPUT,
    "Автофинка: выбор типа", dialog, "Далее", "Отмена");
    return 1;
}
CMD:resetbizbalance(playerid, params[])
{
    if (GetPlayerAdminEx(playerid) < 8) return SendClientMessage(playerid, 0x999999FF, "Доступно только для администраторов 6+ уровня.");

    for (new i = 0; i < g_business_loaded; i++)
    {
        SetBusinessData(i, B_BALANCE, 0);
        format(g_business[i][B_BALANCE], 21, "0");
    }
    new query[128];
    format(query, sizeof query, "UPDATE business SET balance = '0'");
    mysql_query(mysql, query, false);

    SendClientMessage(playerid, 0x66CC33FF, "Баланс всех бизнесов успешно обнулён.");
    
    format(string_dialog, sizeof string_dialog, "[A] Администратор %s[%d] очистил баланс всех бизнесов", GetPlayerNameEx(playerid), playerid);
    SendMessageToAdmins(string_dialog, 0x999999FF);
    return 1;
}
stock LoadAutoFinkaFromDB()
{
    for(new i = 0; i < sizeof(gAutoFinkaAmount); i++)
        gAutoFinkaAmount[i] = 0;

    new Cache: result = mysql_query(mysql, "SELECT `type`, `amount` FROM `autofinka`", true);
    if (!result)
    {
        printf("[AutoFinka] Ошибка загрузки из БД");
        return;
    }

    new rows = cache_num_rows();
    if (rows <= 0)
    {
        printf("[AutoFinka] В таблице autofinka нет записей");
        cache_delete(result);
        return;
    }

    for (new i = 0; i < rows; i++)
    {
        new type = cache_get_field_content_int(i, "type");
        new amount = cache_get_field_content_int(i, "amount");

        if (type >= 1 && type < sizeof(gAutoFinkaAmount))
        {
            gAutoFinkaAmount[type] = amount;
        }
        else
        {
            printf("[AutoFinka] Предупреждение: пропущен недопустимый тип %d", type);
        }
    }

    cache_delete(result);
    printf("[AutoFinka] Загружено %d записей", rows);
}
stock ApplyAutoFinka()
{
    if (g_bAutoFinkaApplying)
    {
        printf("[AutoFinka] Отмена: уже выполняется начисление!");
        return;
    }
    g_bAutoFinkaApplying = true;

    new applied = 0;

    for (new i = 0; i < g_business_loaded; i++)
    {
        if (GetBusinessData(i, B_OWNER_ID) <= 0)
            continue;

        new type = GetBusinessData(i, B_TYPE);
        if (type < 1 || type >= sizeof(gAutoFinkaAmount))
            continue;

        new amount = gAutoFinkaAmount[type];
        if (amount <= 0)
            continue;

        if (AddBusinessProfitNoPlayer(i, amount))
        {
            applied++;
            printf("[AutoFinka] Бизнес SQL_ID=%d (тип=%d) получил +%d", GetBusinessData(i, B_SQL_ID), type, amount);
        }
    }

    printf("[AutoFinka] Завершено. Начислено на %d бизнесов", applied);
    SetTimer("ResetAutoFinkaFlag", 5000, false);
}
stock AddBusinessProfitNoPlayer(businessid, profit)
{
    if (businessid < 0 || businessid >= g_business_loaded)
        return 0;

    new current = strval(g_business[businessid][B_BALANCE]);

    if (profit > 0 && (2147483647 - current) < profit)
    {
        printf("[AutoFinka:ERROR] Переполнение! Бизнес SQL_ID=%d, текущий баланс=%d, прибыль=%d",
               GetBusinessData(businessid, B_SQL_ID), current, profit);
        return 0;
    }

    new new_balance = current + profit;
    if (new_balance < 0) return 0; 

    new new_balance_str[21];
    valstr(new_balance_str, new_balance);

    format(g_business[businessid][B_BALANCE], 21, "%s", new_balance_str);

    new query[256];
    mysql_format(mysql, query, sizeof(query),"UPDATE `business` SET `balance` = '%e' WHERE `id` = %d",new_balance_str, GetBusinessData(businessid, B_SQL_ID));
    mysql_tquery(mysql, query, "", "");

    return 1;
}
forward ResetAutoFinkaFlag();
public ResetAutoFinkaFlag()
{
    g_bAutoFinkaApplying = false;
}
CMD:resetmoney(playerid, params[])
{
    if(GetPlayerAdminEx(playerid) < 7) return 1;
    if(!admin_logged[playerid]) return SCM(playerid, 0x999999FF, "Вы не авторизированы, для этого используйте /alogin");
    if(GetPlayerData(playerid, P_BUYADMIN) == 1) return SCM(playerid, 0x999999FF, "Покупным администраторам недоступна данная функция");

    new to_player, type;
    new amount_str[32];

    if(sscanf(params, "ids[31]", to_player, type, amount_str))
    {
        SCM(playerid, 0xCECECEFF, "Используйте: /resetmoney [ID] [тип] [сумма]");
        SCM(playerid, 0xCECECEFF, "Типы: 1 — деньги, 2 — донат, 3 — RUB");
        return 1;
    }

    if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
        return SCM(playerid, 0xCECECEFF, "Такого игрока нет");

    if(type < 1 || type > 3)
        return SCM(playerid, 0xFF6600FF, "Неверный тип! Используйте: 1 — деньги, 2 — донат, 3 — RUB");

    if(!IsILNumeric(amount_str) || strlen(amount_str) == 0 || strfind(amount_str, "-") != -1)
        return SCM(playerid, 0xFF6600FF, "Сумма должна быть положительным числом");

    new real_amount_str[32];
    format(real_amount_str, sizeof real_amount_str, "%s", amount_str);
    while(strlen(real_amount_str) > 1 && real_amount_str[0] == '0')
        strdel(real_amount_str, 0, 1);

    new reason[144];

    switch(type)
    {
        case 1: 
        {
            if(!GetILPlayerStr(GetPlayerMoneyEx(to_player), real_amount_str)) return SCM(playerid, 0xFF6600FF, "У игрока недостаточно средств");

            new cash_str[34];
            format(cash_str, sizeof cash_str, "-%s", real_amount_str);

            GivePlayerMoneyStr(to_player, cash_str);

            format(reason, sizeof reason, "Администратор %s списал с вас %s рублей", GetPlayerNameEx(playerid), formatStr(real_amount_str));
            SCM(to_player, 0xFF6600FF, reason);

            format(reason, sizeof reason, "[A] %s[%d] списал %s руб у %s[%d]", GetPlayerNameEx(playerid), playerid, formatStr(real_amount_str), GetPlayerNameEx(to_player), to_player);
            SendMessageToAdmins(reason, 0xFFFF00FF);
        }
        case 2:
        {
            new amount_int = strval(real_amount_str);
            if(amount_int <= 0 || amount_int > 2147483647) return SCM(playerid, 0xFF6600FF, "Сумма доната не может превышать 2.147.483.647");

            if(GetPlayerCurrentDonate(to_player) < amount_int) return SCM(playerid, 0xFF6600FF, "У игрока недостаточно доната");

            GivePlayerDonate(to_player, -amount_int, "Списание администрацией", true, true);

            format(reason, sizeof reason, "Администратор %s списал с вас %d доната", GetPlayerNameEx(playerid), amount_int);
            SCM(to_player, 0xFF6600FF, reason);

            format(reason, sizeof reason, "[A] %s[%d] списал %d доната у %s[%d]", GetPlayerNameEx(playerid), playerid, amount_int, GetPlayerNameEx(to_player), to_player);
            SendMessageToAdmins(reason, 0xFF6600FF);

            format(reason, sizeof reason, "Списал донат %s[%d] на %d доната", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), amount_int);
            SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, reason);
        }
        case 3: 
        {
            new amount_int = strval(real_amount_str);
            if(amount_int <= 0 || amount_int > 2147483647) return SCM(playerid, 0xFF6600FF, "Сумма RUB не может превышать 2.147.483.647");

            if(GetPlayerRUB(to_player) < amount_int) return SCM(playerid, 0xFF6600FF, "У игрока недостаточно RUB");

            GivePlayerDonateRub(to_player, -amount_int);

            format(reason, sizeof reason, "Администратор %s списал с вас %d "MIN_RUB"", GetPlayerNameEx(playerid), amount_int);
            SCM(to_player, 0xFF6600FF, reason);

            format(reason, sizeof reason, "[A] %s[%d] списал %d "MIN_RUB" у %s[%d]", GetPlayerNameEx(playerid), playerid, amount_int, GetPlayerNameEx(to_player), to_player);
            SendMessageToAdmins(reason, COLOR_GREY);

            format(reason, sizeof reason, "Списал RUB %s[%d] на %d "MIN_RUB"", GetPlayerNameEx(to_player), GetPlayerAccountID(to_player), amount_int);
            SendLog(playerid, LOG_TYPE_SUPERADMIN_ACTION, reason);
        }
    }

    SCM(playerid, 0x66CC00FF, "{ff8c00}Сумма успешно списана");
    return 1;
}
cmd:trunk(playerid)
{
	new Float:POS[5];
	new vehicleid;
    new Float:Distance_ = 15.0;

    for(new i = 0; i < MAX_VEHICLES; i++)
	{
	    if(GetVehicleData(i, V_ACTION_TYPE) == VEHICLE_ACTION_TYPE_OWNABLE_CAR)
	    {
		    new iddx = GetVehicleData(i, V_ACTION_ID);
	        if(GetOwnableCarData(iddx,OC_OWNER_ID) == GetPlayerAccountID(playerid))
	        {
				new Float:Distance = D_PlayerVehicle(playerid, i);
		    	if(Distance < Distance_)
				{
					Distance_ = Distance;
					vehicleid = i;
	            }
	        }
        }
	}
	if(Distance_ == 15.0) return 1;

	if(vehicleid != -1)
	{
		new index = GetVehicleData(vehicleid, V_ACTION_ID);

		new car_sql_id = GetOwnableCarData(index, OC_SQL_ID);

		SetPVarInt(playerid, "vehicleid", car_sql_id);

		GetCoordVehicle(vehicleid, VEHICLE_COORD_TYPE_BOOT, POS[0], POS[1], POS[2], POS[3], POS[4]);

		if(!IsPlayerInRangeOfPoint(playerid, 4.0, POS[0], POS[1], POS[2])) return 1;

		if(status_authorization[playerid] != 1) return true;

		SetVehicleParam(vehicleid, V_BOOT, VEHICLE_PARAM_ON);

		inventory_trunk_id[playerid] = car_sql_id;

		UpdateWeapons(playerid), LoadInventory(playerid), StateCheck(playerid);

		STRING_GLOBAL[0] = EOS;

        if(inventory_bag_id[playerid] == 1) format(STRING_GLOBAL, sizeof STRING_GLOBAL, "[0,[\"%s\",%d,%d,%d,%d,%d,%d.00,30.00,20],[[2,\"Рюкзак\",%d.00,50.00,24],[3,\"Багажник\",0.10,50.00,24]],[%s]]", GetPlayerNameEx(playerid), playerid, GetPlayerMoney(playerid), GetPlayerSkin(playerid), GetIteam(playerid, 293), GetPlayerPremium(playerid), GetWorkLoadItems(playerid, 0), GetWorkLoadItems(playerid, 1), load_inventory[playerid]);
        else format(STRING_GLOBAL, sizeof STRING_GLOBAL, "[0,[\"%s\",%d,%d,%d,%d,%d,%d.00,30.00,20],[[3,\"Багажник\",0.10,50.00,24]],[%s]]", GetPlayerNameEx(playerid), playerid, GetPlayerMoney(playerid), GetPlayerSkin(playerid), GetIteam(playerid, 293), GetPlayerPremium(playerid), GetWorkLoadItems(playerid, 0), load_inventory[playerid]);


		SendPacket_2(playerid, s_CefInterface, t_CefShow, "InventoryNew", STRING_GLOBAL);
	}
	return 1;
}
stock ShowOwnableCarPass(playerid, vehicleid)
{
    new model_id = GetVehicleData(vehicleid, V_MODELID);

    if(model_id && IsAOwnableCar(vehicleid))
    {
        new fmt_str[800];
        new idx = GetVehicleData(vehicleid, V_ACTION_ID);
        new index = GetVehicleData(vehicleid, V_ACTION_ID);
        new numberss[25];
        new fuels[25];
        
        if(GetVehicleInfo(model_id, VI_TYPE_FUEL) == 33) format(fuels, sizeof fuels, "Дизель");
        if(GetVehicleInfo(model_id, VI_TYPE_FUEL) == 92) format(fuels, sizeof fuels, "92");
        if(GetVehicleInfo(model_id, VI_TYPE_FUEL) == 95) format(fuels, sizeof fuels, "95");
        if(GetVehicleInfo(model_id, VI_TYPE_FUEL) == 98) format(fuels, sizeof fuels, "98");
        
        if(GetOwnableCarData(index, OC_NUMBERTYPE) == 0) format(numberss, sizeof numberss, "[номера нет]");
        if(GetOwnableCarData(index, OC_NUMBERTYPE) == 1) format(numberss, sizeof numberss, "[RU %s %s]", GetOwnableCarData(index, OC_NUMBER), GetOwnableCarData(index, OC_REGION));
        if(GetOwnableCarData(index, OC_NUMBERTYPE) == 2) format(numberss, sizeof numberss, "[KZ %s %s]", GetOwnableCarData(index, OC_NUMBER), GetOwnableCarData(index, OC_REGION));
        if(GetOwnableCarData(index, OC_NUMBERTYPE) == 3) format(numberss, sizeof numberss, "[BY %s%s]", GetOwnableCarData(index, OC_NUMBER), GetOwnableCarData(index, OC_REGION));
        if(GetOwnableCarData(index, OC_NUMBERTYPE) == 4) format(numberss, sizeof numberss, "[UA %s%s]", GetOwnableCarData(index, OC_NUMBER), GetOwnableCarData(index, OC_REGION));
        if(GetOwnableCarData(index, OC_NUMBERTYPE) == 5) format(numberss, sizeof numberss, "[CUS %s]", GetOwnableCarData(index, OC_NUMBER));
        
        format
        (
            fmt_str, sizeof fmt_str,
            "[[8,[[\"%s\",\"%s\",\"%s\",%d,\"%s\",%d,%d]]]]",
            GetVehicleInfo(model_id, VI_NAME),
            GetPlayerNameEx(GetPVarInt(playerid, "owenrname")),
            numberss,
            GetVehicleInfo(model_id, VI_PRICE),
            fuels,
            GetOwnableCarData(idx, OC_COLOR_1),
            GetVehicleData(vehicleid, V_IZNOS)
        );
        
        SendClientEventWithArg(playerid, s_CefInterface, t_CefShow, "Docs", fmt_str);
        return 1;
    }
    return 0;
}


CMD:carpass(playerid, params[])
{
	new vehicleid = GetPlayerOwnableCarLast(playerid);
	if(vehicleid == INVALID_VEHICLE_ID)
	{
		if(GetPlayerOwnableCars(playerid) == 0)
			return SendClientMessage(playerid, 0xFF6600FF, "У Вас нет личного транспорта");
		else
			return SendClientMessage(playerid, 0xFF6600FF, "Ваш личный транспорт не загружен на сервер");
	}

	if(!strlen(params))
		return SendClientMessage(playerid, 0xCECECEFF, "Используйте: /carpass [ID игрока]");

	extract params -> new to_player;

	if(!IsPlayerInRangeOfPlayer(playerid, to_player, 3.0))
		return SendClientMessage(playerid, 0xCECECEFF, "Игрок слишком далеко");

	if(!IsPlayerConnected(to_player) || !IsPlayerLogged(to_player))
		return SendClientMessage(playerid, 0xFF6600FF, "Такого игрока нет");

	ShowOwnableCarPass(to_player, vehicleid);
	SetPVarInt(to_player, "owenrname", playerid);
	return 1;
}


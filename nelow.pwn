		{
			EditStage2Player[vehicleid] = CreateDynamicObject(tempcomponent[playerid], x, y, z, 0.0, 0.0, 180.0);
			EditDynamicObject(playerid, EditStage2Player[vehicleid]);
			SetPVarInt(playerid, "stage_edit_2", 1);

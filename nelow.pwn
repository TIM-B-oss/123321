 	FirstPerson[playerid] = CreateObject(19300, 0, 0, 0, 0, 0, 0);
 	ChangeView(playerid, 0, 1);
}
stock OnFirstPersonMetro(playerid)
{
	switch_fp[playerid] = true;
 	FirstPerson[playerid] = CreateObject(19300, 0, 0, 0, 0, 0, 0);
 	ChangeView(playerid, 0, 4);
}
stock OffFirstPerson(playerid)
{

{
    IRS_CAR_ID,
    IRS_PRICE
};

new g_info_raffleshopping[54][E_INFO_RAFFLE_SHOPPING_STRUCT] =
{
    {400, 24000}, {402, 24000}, {409, 24000}, {410, 24000}, {419, 24000},
    {421, 24000}, {429, 24000}, {436, 24000}, {445, 24000}, {451, 24000},
    {458, 24000}, {461, 24000}, {462, 24000}, {463, 24000}, {466, 24000},
    {468, 24000}, {475, 24000}, {477, 24000}, {480, 24000}, {489, 24000},
    {490, 24000}, {491, 24000}, {495, 24000}, {494, 24000}, {502, 24000},
    {503, 24000}, {506, 24000}, {505, 24000}, {507, 24000}, {515, 24000},
    {516, 24000}, {534, 24000}, {536, 24000}, {543, 24000}, {551, 24000},
    {550, 24000}, {559, 24000}, {560, 24000}, {612, 24000}, {999, 24000},
    {909, 24000}, {795, 24000}, {796, 24000}, {797, 24000}, {908, 24000},
    {907, 24000}, {15065, 24000}, {15066, 24000}, {15068, 24000}, {15069, 24000},

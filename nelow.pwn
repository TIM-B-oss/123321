						new player_rank = GetPlayerJob(playerid); 
						new string[1024], temp[64];
						strcat(string, "interface('UniversalStore').addItems([");

						new skin, bool:first = true;
						for (new i = 0; i < 10; i++)
						{
							skin = GetTeamData(team_id, O_SKINS)[i];
							if (skin <= 0) continue;

							static last_skin = -1;
							if (skin == last_skin) continue;
							last_skin = skin;

							new required_rank = i + 1;
							if (player_rank < required_rank) continue;

							if (!first) strcat(string, ",");
							format(temp, sizeof temp, "[%d,\"Скин %d\"]", skin, skin);
							strcat(string, temp);
							first = false;
						}

						strcat(string, "])");

						SendPacket_2(playerid, s_CefInterface, t_CefShow, "UniversalStore", "[\"Раздевалка\"]");
						SendPacket_1(playerid, s_CefInterface, t_CefUpdate, string);
						SendPacket_1(playerid, s_CefInterface, t_CefUpdate, string);
